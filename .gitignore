# Build output (regenerable via `python scripts/build.py`)
site/

# Debug / intermediate artifacts (regenerable via build --debug or migration scripts)
output/

# Intermediate extraction data (should be committed only if edited by hand)
_extracted_coins.json

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.venv
venv/
.pytest_cache/

# IDE / OS
.vscode/
.idea/
*.swp
.DS_Store

# Claude Code session metadata (local-only)
.claude/

# Environment / Secrets / API keys (NEVER commit)
.env
.env.local
local.env
.numista_api_key

# Numista refs scratch (regenerable via scripts/maintenance/enrich_numista_refs.py)
scripts/numista_refs.json

# One-off / scratch scripts (see CLAUDE.md "Git workflow"). Anything that runs
# once on a specific dataset and won't be re-applied lives here. Truly reusable
# utilities go directly under scripts/.
scripts/oneoff/

# V2 pipeline diagnostic output (regenerable on every script run).
# `match_uncertainty/<entity>.yml` lists low-confidence merge candidates
# the auto-merger couldn't auto-route — for investigation only, not
# curator input (decisions go into `data/v2/merge_decisions/` instead).
# See docs/V2_PIPELINE.md §5.2.
data/v2/match_uncertainty/
