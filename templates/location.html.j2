{#
  Location page template. Renders one fuss per card,
  with phases grouped by Kurant/Scheide sub-categories.
#}
<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ tree.location.name|t(lang) }} · Müntzfüße</title>
<link rel="stylesheet" href="{{ base_url }}/assets/style.css">
<script src="{{ base_url }}/assets/app.js" defer></script>
<script>(function(){var t='v3';try{var s=localStorage.getItem('mz-theme');if(s==='v1'||s==='v2'||s==='v3')t=s;}catch(e){}document.documentElement.dataset.theme=t;})();</script>
</head>
<body>

{%- macro coin_row(coin) %}
<tr{% if coin.raw.kind == 'scheide' %} class="rw-sch"{% endif %}>
  <td class="c-nom">{{ coin.raw.nominal }}</td>
  <td class="c-year">{{ coin.raw.year_label }}</td>
  <td>{{ coin.raw.ruler or '—' }}</td>
  <td class="c-km">
    {%- for prefix, vals in coin.catalog_groups -%}
      {%- if prefix -%}
        <span class="cat-group"><span class="cat-prefix">{{ prefix }}#</span> {{ vals | join(', ') }}</span>
      {%- else -%}
        <span class="cat-group cat-plain">{{ vals | join('; ') }}</span>
      {%- endif -%}
      {%- if not loop.last %}<br>{% endif -%}
    {%- endfor -%}
  </td>
  <td class="c-metal">
    {%- if coin.raw.metal -%}
      {%- set metals = {
        'silver': {'de': 'Silber', 'en': 'Silver', 'uk': 'Срібло'},
        'gold':   {'de': 'Gold',   'en': 'Gold',   'uk': 'Золото'},
        'billon': {'de': 'Billon', 'en': 'Billon', 'uk': 'Білон'},
        'copper': {'de': 'Kupfer', 'en': 'Copper', 'uk': 'Мідь'}
      } -%}
      {{ metals[coin.raw.metal][lang] }}
      {%- if coin.raw.fineness %} .{{ (coin.raw.fineness * 1000)|round|int }}{% endif -%}
      {%- if not coin.raw.fineness_verified %} <span class="unverified" data-tooltip="{{ ui_get('marker.unverified') }}">(?)</span>{% endif -%}
    {%- else -%}—{%- endif -%}
  </td>
  <td class="c-w">
    {%- if coin.raw.weight_rough_g -%}
      {{ fmt_num(coin.raw.weight_rough_g, decimals=2) }}
      {%- if not coin.raw.weight_rough_verified %} <span class="unverified">(?)</span>{% endif -%}
    {%- elif coin.raw.weight_rough_label -%}
      {{ coin.raw.weight_rough_label|t(lang) }}
    {%- else -%}—{%- endif -%}
  </td>
  <td class="c-w">
    {%- if coin.weight_fein_g -%}
      {{ fmt_num(coin.weight_fein_g, decimals=5) }}
      {%- if coin.derived_unverified %} <span class="unverified" data-tooltip="{{ ui_get('marker.derived_unverified') }}">(?)</span>{% endif -%}
    {%- else -%}—{%- endif -%}
  </td>
  <td class="c-d">
    {%- if coin.raw.diameter_mm -%}
      {{ fmt_num(coin.raw.diameter_mm, decimals=1, unit='mm') }}
      {%- if not coin.raw.diameter_mm_verified %} <span class="unverified" data-tooltip="{{ ui_get('marker.unverified') }}">(?)</span>{% endif -%}
    {%- else -%}—{%- endif -%}
  </td>
  <td class="c-mint">
    {%- if coin.raw.mint -%}{{ coin.raw.mint }}{%- if not coin.raw.mint_verified %} <span class="unverified" data-tooltip="{{ ui_get('marker.unverified') }}">(?)</span>{% endif -%}
    {%- else -%}—{%- endif -%}
  </td>
  <td class="c-entity">
    {%- set ent = issuing_entities.get(coin.raw.issuing_entity) if coin.raw.issuing_entity else None -%}
    {%- if ent -%}
      <span class="ent-badge ent-{{ coin.raw.issuing_entity }}" data-tooltip="{{ ent.name|t(lang) }} — {{ (ent.description|t(lang))|striptags if ent.description else '' }}">{{ ent.abbrev }}</span>
    {%- else -%}—{%- endif -%}
  </td>
  <td class="c-note">{{ (coin.raw.note|t(lang))|safe if coin.raw.note else '' }}</td>
  <td class="c-soll">
    {%- if coin.soll_fein_g -%}
      {{ fmt_num(coin.soll_fein_g, decimals=5) }}
    {%- else -%}—{%- endif -%}
  </td>
  <td class="c-delta">
    {%- if coin.delta_g is not none -%}
      {# 4-state Δ palette: under-deep (<-1%), under-mild (-1% … 0), over-mild (0 … +1%), over-strong (>+1%) #}
      {%- if coin.delta_pct < -1.0 -%}{%- set sd_cls = 'under-deep' -%}
      {%- elif coin.delta_pct < 0   -%}{%- set sd_cls = 'under-mild' -%}
      {%- elif coin.delta_pct <= 1.0 -%}{%- set sd_cls = 'over-mild' -%}
      {%- else -%}{%- set sd_cls = 'over-strong' -%}
      {%- endif %}
      <span class="sd {{ sd_cls }}">{{ fmt_delta(coin.delta_g, coin.delta_pct)|safe }}</span>
      {%- if coin.derived_unverified %} <span class="unverified" data-tooltip="{{ ui_get('marker.derived_unverified') }}">(?)</span>{% endif -%}
    {%- elif coin.raw.metal == 'copper' -%}
      <span class="sd-na" data-tooltip="{{ ui_get('marker.copper_nodelta') }}">—</span>
    {%- else -%}—{%- endif -%}
  </td>
  <td class="c-fuss">
    {# When the coin has no computable fein weight (no fineness or no rough weight),
       collapse the Stopa column to a single plain rendering of the fuss name. The
       "▸ Primär:" prefix only carries meaning when contrasted with a Sekundär/Tertiär
       line; for unknown-fein coins it adds visual noise without information. #}
    {%- if coin.weight_fein_g is none -%}
      <span class="fuss-nominal">{{ coin.fuss.name|t(lang) }}</span>
    {%- elif coin.raw.fuss_refs -%}
      {%- for ref in coin.raw.fuss_refs -%}
        <span class="sf-line {{ ref.rank }}">{{ ref.label|t(lang)|safe }}</span>
      {%- endfor -%}
    {%- else -%}
      <span class="fuss-nominal">{{ coin.fuss.name|t(lang) }}</span>
    {%- endif -%}
    {# Auto-computed implied Fuß — appended whenever the coin meaningfully deviates
       from its declared standard (>2%) AND fuss_refs doesn't already document an
       "Ist-Wert" note. Quantifies seigniorage gap for Scheidemünzen. #}
    {%- if coin.implied_fuss and not coin.has_manual_implied
           and coin.delta_pct is not none and coin.delta_pct|abs > 2 -%}
      {%- set impl_label = {'de':'Ist','en':'Actual','uk':'Факт'}[lang] -%}
      {# Pick the Fuß-unit label by the fuss id (stable across DE/EN/UK names):
         every Krone-mønt fuss has 'kronemont' in its id (kronemont, kronemont_chr_iv,
         kronemont_fine); gold fuesse default to Dukatenfuß. Otherwise fall back
         to the generic Thaler-Fuß. #}
      {%- if coin.fuss.metal == 'gold' -%}
        {%- set fuss_unit = 'Dukatenfuß' -%}
      {%- elif 'kronemont' in coin.fuss.id -%}
        {%- set fuss_unit = 'Krone-Fuß' -%}
      {%- else -%}
        {%- set fuss_unit = 'Thaler-Fuß' -%}
      {%- endif -%}
      <span class="sf-line implied">↳ {{ impl_label }} ≈ {{ fmt_num(coin.implied_fuss, decimals=2, unit='') }}-{{ fuss_unit }}{%- if coin.derived_unverified %} <span class="unverified" data-tooltip="{{ ui_get('marker.derived_unverified') }}">(?)</span>{% endif -%}</span>
    {%- endif -%}
  </td>
  <td class="c-ref">
    {%- for s in coin.raw.sources -%}
      {%- if s.url -%}
        <a href="{{ s.url }}" target="_blank" rel="noopener">{{ s.ref or s.type }}</a>
      {%- else -%}
        {{ s.ref or s.type }}
      {%- endif -%}
      {%- if not loop.last %} · {% endif -%}
    {%- endfor -%}
  </td>
</tr>
{%- endmacro %}

{%- macro coin_table(coins) %}
<div class="mt-scroll"><table class="mt">
  <thead>
    <tr>
      <th>{{ ui_get('col.nominal') }}</th>
      <th>{{ ui_get('col.year') }}</th>
      <th>{{ ui_get('col.ruler') }}</th>
      <th>{{ ui_get('col.catalog') }}</th>
      <th>{{ ui_get('col.metal_fineness') }}</th>
      <th>{{ ui_get('col.rough') }}</th>
      <th>{{ ui_get('col.fine') }}</th>
      <th>{{ ui_get('col.diameter') }}</th>
      <th>{{ ui_get('col.mint') }}</th>
      <th data-tooltip="{{ ui_get('col.entity_tooltip') }}">{{ ui_get('col.entity') }}</th>
      <th>{{ ui_get('col.note') }}</th>
      <th data-tooltip="{{ ui_get('col.soll_tooltip') }}">{{ ui_get('col.soll') }}</th>
      <th data-tooltip="{{ ui_get('col.delta_tooltip') }}">{{ ui_get('col.delta') }}</th>
      <th data-tooltip="{{ ui_get('col.fuss_tooltip') }}">{{ ui_get('col.fuss') }}</th>
      <th>{{ ui_get('col.source') }}</th>
    </tr>
  </thead>
  <tbody>
    {% for coin in coins %}{{ coin_row(coin) }}{% endfor %}
  </tbody>
</table></div>
{%- endmacro %}

{# Copper petty-coin row — pure copper tokens have no silver target, so Soll/Δ/Fuß
   are dropped entirely. Fine-weight column is also omitted (always zero for copper). #}
{%- macro coin_row_copper(coin) %}
<tr class="rw-cp">
  <td class="c-nom">{{ coin.raw.nominal }}</td>
  <td class="c-year">{{ coin.raw.year_label }}</td>
  <td>{{ coin.raw.ruler or '—' }}</td>
  <td class="c-km">
    {%- for prefix, vals in coin.catalog_groups -%}
      {%- if prefix -%}
        <span class="cat-group"><span class="cat-prefix">{{ prefix }}#</span> {{ vals | join(', ') }}</span>
      {%- else -%}
        <span class="cat-group cat-plain">{{ vals | join('; ') }}</span>
      {%- endif -%}
      {%- if not loop.last %}<br>{% endif -%}
    {%- endfor -%}
  </td>
  <td class="c-metal">
    {%- set metals = {
      'copper': {'de': 'Kupfer', 'en': 'Copper', 'uk': 'Мідь'},
      'bronze': {'de': 'Bronze', 'en': 'Bronze', 'uk': 'Бронза'},
      'brass':  {'de': 'Messing','en': 'Brass',  'uk': 'Латунь'}
    } -%}
    {{ metals[coin.raw.metal][lang] if coin.raw.metal in metals else coin.raw.metal }}
  </td>
  <td class="c-w">
    {%- if coin.raw.weight_rough_g -%}
      {{ fmt_num(coin.raw.weight_rough_g, decimals=2) }}
      {%- if not coin.raw.weight_rough_verified %} <span class="unverified">(?)</span>{% endif -%}
    {%- elif coin.raw.weight_rough_label -%}
      {{ coin.raw.weight_rough_label|t(lang) }}
    {%- else -%}—{%- endif -%}
  </td>
  <td class="c-d">
    {%- if coin.raw.diameter_mm -%}
      {{ fmt_num(coin.raw.diameter_mm, decimals=1, unit='mm') }}
      {%- if not coin.raw.diameter_mm_verified %} <span class="unverified">(?)</span>{% endif -%}
    {%- else -%}—{%- endif -%}
  </td>
  <td class="c-mint">
    {%- if coin.raw.mint -%}{{ coin.raw.mint }}{%- if not coin.raw.mint_verified %} <span class="unverified" data-tooltip="{{ ui_get('marker.unverified') }}">(?)</span>{% endif -%}
    {%- else -%}—{%- endif -%}
  </td>
  <td class="c-entity">
    {%- set ent = issuing_entities.get(coin.raw.issuing_entity) if coin.raw.issuing_entity else None -%}
    {%- if ent -%}
      <span class="ent-badge ent-{{ coin.raw.issuing_entity }}" data-tooltip="{{ ent.name|t(lang) }}">{{ ent.abbrev }}</span>
    {%- else -%}—{%- endif -%}
  </td>
  <td class="c-note">{{ (coin.raw.note|t(lang))|safe if coin.raw.note else '' }}</td>
  <td class="c-ref">
    {%- for s in coin.raw.sources -%}
      {%- if s.url -%}
        <a href="{{ s.url }}" target="_blank" rel="noopener">{{ s.ref or s.type }}</a>
      {%- else -%}
        {{ s.ref or s.type }}
      {%- endif -%}
      {%- if not loop.last %} · {% endif -%}
    {%- endfor -%}
  </td>
</tr>
{%- endmacro %}

{%- macro coin_table_copper(coins) %}
<div class="mt-scroll"><table class="mt mt-copper">
  <thead>
    <tr>
      <th>{{ ui_get('col.nominal') }}</th>
      <th>{{ ui_get('col.year') }}</th>
      <th>{{ ui_get('col.ruler') }}</th>
      <th>{{ ui_get('col.catalog') }}</th>
      <th>{{ ui_get('col.metal') }}</th>
      <th>{{ ui_get('col.rough') }}</th>
      <th>{{ ui_get('col.diameter') }}</th>
      <th>{{ ui_get('col.mint') }}</th>
      <th data-tooltip="{{ ui_get('col.entity_tooltip') }}">{{ ui_get('col.entity') }}</th>
      <th>{{ ui_get('col.note') }}</th>
      <th>{{ ui_get('col.source') }}</th>
    </tr>
  </thead>
  <tbody>
    {% for coin in coins %}{{ coin_row_copper(coin) }}{% endfor %}
  </tbody>
</table></div>
{%- endmacro %}



<nav class="nav">
  <a href="../../index.html">{{ ui_get('nav.home') }}</a>
  <span style="color: var(--text-muted);">/</span>
  <strong>{{ tree.location.name|t(lang) }}</strong>
  <div class="switchers">
    <div class="theme-switch" role="group" aria-label="Theme">
      <button type="button" class="th th-v1" data-theme="v1" title="Museum Atlas — paper &amp; gold" aria-label="Museum Atlas">
        <span class="th-swatch" aria-hidden="true"><i class="sw sw-1"></i><i class="sw sw-2"></i><i class="sw sw-3"></i></span>
        <span class="th-label">Atlas</span>
      </button>
      <button type="button" class="th th-v2" data-theme="v2" title="Editorial Codex — ink &amp; vermilion" aria-label="Editorial Codex">
        <span class="th-swatch" aria-hidden="true"><i class="sw sw-1"></i><i class="sw sw-2"></i><i class="sw sw-3"></i></span>
        <span class="th-label">Codex</span>
      </button>
      <button type="button" class="th th-v3 active" data-theme="v3" title="Refined Dark — graphite &amp; gold" aria-label="Refined Dark">
        <span class="th-swatch" aria-hidden="true"><i class="sw sw-1"></i><i class="sw sw-2"></i><i class="sw sw-3"></i></span>
        <span class="th-label">Noir</span>
      </button>
    </div>
    <div class="lang-switch">
      {% for l in languages -%}
        {%- if l == lang -%}
          <a class="active">{{ l|upper }}</a>
        {%- else -%}
          <a href="../{{ l }}/">{{ l|upper }}</a>
        {%- endif -%}
      {%- endfor %}
    </div>
  </div>
</nav>

{# Compute hero stats — counts walked across the rendered fuss tree so
   the Münzfüße / Münzen tiles match the visible content (skipping
   fuesse without phases / period / Grundwerte that the template hides). #}
{% set ns = namespace(fuss_count=0, coin_total=0) %}
{% set fp_lookup = tree.location.fuss_periods %}
{% for sg in tree.fuesse %}
  {% set sp = fp_lookup.get(sg.fuss.id) if fp_lookup else None %}
  {% if sg.nonempty_phases or sp or sg.fuss.grundwerte %}
    {% set ns.fuss_count = ns.fuss_count + 1 %}
    {% set ns.coin_total = ns.coin_total + (sg.nonempty_phases | sum(attribute='total') if sg.nonempty_phases else 0) %}
  {% endif %}
{% endfor %}
{% set hero_refs = (references.entries | length) if references and references.entries else 0 %}

<section class="hero">
  <div class="hero-text">
    <h1 class="h1">{{ ui_get('hero.eyebrow') }}<em class="h1-sub">{{ tree.location.name|t(lang) }}</em></h1>
    <p class="deck">{{ tree.location.summary|t(lang) }}</p>
  </div>
  <div class="hero-stats">
    {% if tree.location.timeline %}
    <div class="hs-stat">
      <span class="hs-lbl">{{ ui_get('hero.stat.zeitraum') }}</span>
      <span class="hs-val">{{ tree.location.timeline.year_from }}<sub>—{{ tree.location.timeline.year_to }}</sub></span>
    </div>
    {% endif %}
    <div class="hs-stat">
      <span class="hs-lbl">{{ ui_get('hero.stat.muenzfuesse') }}</span>
      <span class="hs-val">{{ ns.fuss_count }}<sub>{{ ui_get('hero.stat.standards_unit') }}</sub></span>
    </div>
    <div class="hs-stat">
      <span class="hs-lbl">{{ ui_get('hero.stat.muenzen') }}</span>
      <span class="hs-val">{{ ns.coin_total }}<sub>{{ ui_get('hero.stat.coins_unit') }}</sub></span>
    </div>
    {% if hero_refs %}
    <div class="hs-stat">
      <span class="hs-lbl">{{ ui_get('hero.stat.quellen') }}</span>
      <span class="hs-val">{{ hero_refs }}<sub>{{ ui_get('hero.stat.refs_unit') }}</sub></span>
    </div>
    {% endif %}
    <div class="hs-stat hs-stat-wide">
      <span class="hs-lbl">{{ ui_get('hero.stat.revision') }}</span>
      <span class="hs-val hs-val-date">{{ fmt_date(generated_date) }}</span>
    </div>
  </div>
</section>

{% set tl = tree.location.timeline %}
{% if tl %}
{% set tl_span = (tl.year_to - tl.year_from) %}
<div class="tl">
  <div class="tl-title">{{ tl.title|t(lang) }}</div>
  <div class="tl-grid">
    {%- macro tl_bar_html(bar, tl, tl_span, lang, extra_class='') -%}
      {%- set raw_left  = (bar.year_from - tl.year_from) / tl_span * 100 -%}
      {%- set raw_right = (bar.year_to   - tl.year_from) / tl_span * 100 -%}
      {%- set clamped_left  = [raw_left, 0]  | max -%}
      {%- set clamped_right = [raw_right, 100] | min -%}
      {%- set left_pct  = clamped_left | round(2) -%}
      {%- set width_pct = (clamped_right - clamped_left) | round(2) -%}
      {# Bars under ~22 % of the timeline cannot fit a typical bar_label
         («1566 — ca. 1622 · ~56 J.» ≈ 24 chars × 7 px = 168 px in mono;
         a 22 %-wide bar on a 900 px track is ~198 px — the cutoff). Below
         this threshold the label renders as a floating tag overlaid on
         the bar (overflow visible, halo text-shadow for legibility). #}
      {%- set narrow = width_pct < 21 -%}
      {# Auto-derive a year-range label if the YAML doesn't set one explicitly.
         Keeps narrow bars (e.g. 30-Thaler-Fuß · Vereinsthaler 1866–1871) from
         rendering as bare swatches with no temporal info. #}
      {%- set _label = bar.bar_label|t(lang) if bar.bar_label else (bar.year_from|string + '—' + bar.year_to|string) -%}
      <div class="tl-bar tl-bar-{{ bar.id }} {{ bar.color_class }}{% if bar.dashed %} tl-bar-dashed{% endif %}{% if raw_left < 0 %} tl-bar-cut-left{% endif %}{% if raw_right > 100 %} tl-bar-cut-right{% endif %}{% if narrow %} tl-bar-narrow{% endif %} {{ extra_class }}"
           style="left:{{ left_pct }}%;width:{{ width_pct }}%"
           {% if bar.bar_title %}data-tooltip="{{ bar.bar_title|t(lang) }}"{% endif %}>
        {%- if narrow -%}
          <span class="tl-bar-label-float">{{ _label }}</span>
        {%- else -%}
          {{ _label }}
        {%- endif -%}
      </div>
    {%- endmacro -%}

    {% for group in tl.bars | group_bars %}
      {% set primary = group.primary %}
      <div class="tl-label{% if primary.indented %} tl-label-sub{% endif %}">
        {{ primary.label|t(lang) }}
        {% if primary.small %}<small>{{ primary.small|t(lang) }}</small>{% endif %}
        {% for ov in group.overlays %}
        <div class="tl-sublabel{% if ov.indented %} tl-label-sub{% endif %}">
          {{ ov.label|t(lang) }}
          {% if ov.small %}<small>{{ ov.small|t(lang) }}</small>{% endif %}
        </div>
        {% endfor %}
      </div>
      <div class="tl-track{% if primary.compact %} tl-track-compact{% endif %}">
        {{ tl_bar_html(primary, tl, tl_span, lang) }}
        {% for ov in group.overlays %}
          {{ tl_bar_html(ov, tl, tl_span, lang, 'tl-bar-overlay') }}
        {% endfor %}
        {# Phase sub-divisions are intentionally NOT rendered on the timeline
           — that level of detail belongs in the per-fuss section below where
           each phase has its own card with title, dates, description and
           coin tables. The timeline is just the year-range overview. #}
      </div>
    {% endfor %}
    <div></div>
    <div class="tl-axis">
      {# Snap axis labels to round years (1550, 1600, …) for legibility — instead
         of starting at year_from (1559) which produces awkward 1559/1609/1659…
         labels. Off-scale ticks are clamped between 0 % and 100 %. #}
      {% set first_tick = (tl.year_from // tl.axis_step) * tl.axis_step %}
      {% if first_tick < tl.year_from %}{% set first_tick = first_tick + tl.axis_step %}{% endif %}
      {% set last_tick = (tl.year_to // tl.axis_step) * tl.axis_step %}
      {% set tick_count = ((last_tick - first_tick) // tl.axis_step) + 1 if last_tick >= first_tick else 0 %}
      {% for i in range(tick_count) %}
        {% set year = first_tick + i * tl.axis_step %}
        {% set pos = ((year - tl.year_from) / tl_span * 100) | round(2) %}
        <span style="left:{{ pos }}%">{{ year }}</span>
      {% endfor %}
    </div>
  </div>
</div>
{% endif %}

{% set fuss_periods = tree.location.fuss_periods %}
{% for sg in tree.fuesse %}
{% set sp = fuss_periods.get(sg.fuss.id) if fuss_periods else None %}
{# Render the Müntzfuß block if it has phases OR a period description OR grundwerte — so a standard that applied in the location but without its own coin issues (e.g. Prussian Vereinsthaler here) still appears as header + grundwerte + closing. #}
{% if sg.nonempty_phases or sp or sg.fuss.grundwerte %}

<section class="fuss-block fuss-{{ sg.fuss.id }}">
<div class="phase-header">
  <span class="pname">{{ sg.fuss.name|t(lang) }}</span>
  {% if sp and sp.pdate_label %}
    <span class="pdate">{{ sp.pdate_label|t(lang)|safe }}</span>
  {% endif %}
  {# Short summary in the title — uses hintergrund directly. Each fuss is
     expected to keep hintergrund short (1–3 sentences); longer historical
     elaboration belongs in `details` and lives inside the details toggle. #}
  {% if sp and sp.hintergrund %}
    <span class="psub">{{ sp.hintergrund|t(lang)|safe }}</span>
  {% elif sg.fuss.description %}
    <span class="psub" style="white-space: pre-line;">{{ sg.fuss.description|t(lang) }}</span>
  {% endif %}
</div>

{% set gw = sg.fuss.grundwerte %}
{% if gw %}
<section class="gw">
  <div class="gw-head">
    <div class="gw-head-text">
      {% if gw.heading %}<div class="gw-heading">{{ gw.heading|t(lang) }}</div>{% endif %}
      {% if gw.subheading %}<div class="gw-subheading">{{ gw.subheading|t(lang) }}</div>{% endif %}
    </div>
    {% if gw.badge %}<span class="bx {{ sg.fuss.metal }}">{{ gw.badge|t(lang) }}</span>{% endif %}
  </div>
  <div class="gw-body">
    {% if gw.rows %}
    <div class="gw-rows">
      {% for row in gw.rows %}
      <div class="gw-row">
        <div class="gw-k">{{ row.key|t(lang) }}</div>
        <div class="gw-v">{{ row.value|t(lang)|safe }}</div>
      </div>
      {% endfor %}
    </div>
    {% endif %}
    {% if gw.rechnungsfraktionen %}
    <div class="gw-fr">
      {% if gw.rechnungsfraktionen_label %}
      <span class="gw-fr-label">{{ gw.rechnungsfraktionen_label|t(lang) }}</span>
      {% endif %}
      {{ gw.rechnungsfraktionen|t(lang)|safe }}
    </div>
    {% endif %}
  </div>
</section>
{% endif %}

{# A single fuss-level toggle that reveals the long historical detail (sp.details)
   and ALL phase blocks with their tables already expanded. The <summary> doubles
   as a stats bar — phase / coin / Grundwerte counts on the left, Details pill
   on the right (per design). #}
{% if sg.nonempty_phases or (sp and sp.details) %}
{% set ph_n = sg.nonempty_phases|length %}
{% set coin_n = sg.nonempty_phases|sum(attribute='total') if sg.nonempty_phases else 0 %}
{% set base_n = (sg.fuss.grundwerte.rows|length) if (sg.fuss.grundwerte and sg.fuss.grundwerte.rows) else 0 %}
<details class="fuss-details" data-fuss="{{ sg.fuss.id }}">
  <summary class="fuss-summary">
    <div class="fs-stats">
      <div class="fs-stat">
        <span class="fs-num">{{ ph_n }}</span>
        <span class="fs-lbl">{{ ui_get('fuss.stat.phase_one') if ph_n == 1 else ui_get('fuss.stat.phase_many') }}</span>
      </div>
      <div class="fs-stat">
        <span class="fs-num">{{ coin_n }}</span>
        <span class="fs-lbl">{{ ui_get('fuss.stat.coins_logged') }}</span>
      </div>
      {% if base_n %}
      <div class="fs-stat">
        <span class="fs-num">{{ base_n }}</span>
        <span class="fs-lbl">{{ ui_get('fuss.stat.base_values') }}</span>
      </div>
      {% endif %}
    </div>
    <span class="fs-toggle">
      <span class="fs-toggle-icon" aria-hidden="true">+</span>
      <span class="fd-label fd-label-show">{{ ui_get('fuss.show_details') }}</span>
      <span class="fd-label fd-label-hide">{{ ui_get('fuss.hide_details') }}</span>
      <span class="fd-count">({{ coin_n }})</span>
    </span>
  </summary>
  <div class="fuss-details-body">

    {# Long-form historical detail — only inside the details toggle. The title
       block already shows the short hintergrund summary; this is the place
       for paragraphs of historical context, sourcing notes, etc. #}
    {% if sp and sp.details %}
    <div class="fuss-hintergrund">{{ sp.details|t(lang)|safe }}</div>
    {% endif %}

    {% for pg in sg.nonempty_phases %}
    <div class="ph" data-phase="{{ pg.phase.id }}">
      {% if pg.phase.id in ('single', 'only', 'einzige') %}
        {{ pg.phase.title|t(lang) }} · {{ pg.phase.from_label }} → {{ pg.phase.to_label }}
      {% else %}
        {% if lang == 'de' %}Phase{% elif lang == 'en' %}Phase{% else %}Фаза{% endif %} {{ pg.phase.id }} · {{ pg.phase.from_label }} → {{ pg.phase.to_label }} · {{ pg.phase.title|t(lang) }}
      {% endif %}
    </div>
    {% if pg.phase.description %}
    <div class="phd">{{ pg.phase.description|t(lang)|safe }}</div>
    {% endif %}

    <div class="phc">
      {% if pg.phase.context %}
      <div class="phc-context">{{ pg.phase.context|t(lang)|safe }}</div>
      {% endif %}

      {% if pg.phase.mt_caption %}
      <div class="mt-caption">{{ pg.phase.mt_caption|t(lang)|safe }}</div>
      {% endif %}

      {# Display order: main coins (kurant / tarif) before subsidiary coins
         (scheide / copper). This puts the headline coin of the standard first
         and its petty subdivisions after — the standard numismatic-catalogue
         convention. #}
      {% if pg.kurant_coins %}
        {% if pg.is_mixed or pg.tarif_coins %}
        <div class="mt-subcat kurant">
          ✦ {{ ui_get('label.kurant') }}
          <span class="sc-desc">{{ ui_get('kurant.desc') }}</span>
        </div>
        {% endif %}
        {{ coin_table(pg.kurant_coins) }}
      {% endif %}

      {% if pg.tarif_coins %}
        {% if pg.tarif_deviant_coins or pg.tarif_subunit_coins or pg.scheide_coins or pg.copper_coins %}
        <div class="mt-subcat kurant">
          ✦ {{ ui_get('label.tarif') }}
          <span class="sc-desc">{{ ui_get('tarif.desc') }}</span>
        </div>
        {% endif %}
        {{ coin_table(pg.tarif_coins) }}
      {% endif %}

      {% if pg.tarif_deviant_coins %}
        <div class="mt-subcat scheide">
          ∘ {{ ui_get('label.tarif_deviant') }}
          <span class="sc-desc">{{ ui_get('tarif_deviant.desc') }}</span>
        </div>
        {{ coin_table(pg.tarif_deviant_coins) }}
      {% endif %}

      {% if pg.tarif_subunit_coins %}
        <div class="mt-subcat kurant">
          ∘ {{ ui_get('label.tarif_subunit') }}
          <span class="sc-desc">{{ ui_get('tarif_subunit.desc') }}</span>
        </div>
        {{ coin_table(pg.tarif_subunit_coins) }}
      {% endif %}

      {% if pg.scheide_coins %}
        <div class="mt-subcat scheide">
          ∘ {{ ui_get('label.scheide') }}
          <span class="sc-desc">{{ ui_get('scheide.desc') }}</span>
        </div>
        {{ coin_table(pg.scheide_coins) }}
      {% endif %}

      {% if pg.copper_coins %}
        <div class="mt-subcat copper">
          ∘ {{ ui_get('label.copper') }}
          <span class="sc-desc">{{ ui_get('copper.desc') }}</span>
        </div>
        {{ coin_table_copper(pg.copper_coins) }}
      {% endif %}

      {% if pg.gedenk_coins %}
        <div class="mt-subcat kurant">✦ {{ ui_get('label.gedenk') }}</div>
        {{ coin_table(pg.gedenk_coins) }}
      {% endif %}
    </div>
    {% endfor %}

    <div class="fd-foot">
      <button type="button" class="fd-close">
        <span class="fd-close-icon">▴</span>
        <span class="fd-close-label">{{ ui_get('fuss.hide_details') }}</span>
      </button>
    </div>
  </div>
</details>
{% endif %}

{% if sp and sp.closing %}
<div class="terr">
  {% if sp.closing_label %}<span class="tlb">{{ sp.closing_label|t(lang) }}</span>{% endif %}
  {{ sp.closing|t(lang)|safe }}
</div>
{% endif %}
</section>

{% endif %}
{% endfor %}

{% if tree.location.methodology %}
<hr class="rsep">
<h2 class="refs-title" id="methodik">{{ (tree.location.methodology_heading|t(lang)) if tree.location.methodology_heading else 'Methodische Anmerkungen' }}</h2>
<div class="methodology">{{ tree.location.methodology|t(lang)|safe }}</div>
{% endif %}

{% if references and references.entries %}
<hr class="rsep">
<h2 class="refs-title">{{ references.heading }}</h2>
<ol class="refs">
  {# value="N" overrides the auto-counter so the visible item number matches the
     ref ID and the inline [N] citations even if a future edit drops some entries
     and leaves gaps in the numbering. Currently 1..23 are sequential, but this
     guards against silent renumbering on future cleanups. #}
  {% for entry in references.entries %}
  <li id="{{ entry.id }}" value="{{ entry.id|replace('ref', '') }}">{{ entry.content | safe }}</li>
  {% endfor %}
</ol>
{% endif %}

<footer>
  <span class="ftr-l">{{ ui_get('meta.generated') }}: {{ fmt_date(generated_date) }}{% if repo_url %} · <a href="{{ repo_url }}">{{ ui_get('meta.source_data') }}</a>{% endif %}</span>
  <span class="ftr-r">Müntzfüße · CC-BY-SA</span>
</footer>

</body>
</html>
