{#
  Location page template. Renders one fuss per card,
  with phases grouped by Kurant/Scheide sub-categories.
#}
<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ tree.location.name|t(lang) }} · Müntzfüße</title>
<link rel="stylesheet" href="{{ base_url }}/assets/style.css">
<script src="{{ base_url }}/assets/app.js" defer></script>
<script>(function(){var t='v3';try{var s=localStorage.getItem('mz-theme');if(s==='v1'||s==='v2'||s==='v3')t=s;}catch(e){}document.documentElement.dataset.theme=t;})();</script>
</head>
<body>

{%- macro coin_row(coin) %}
<tr{% if coin.raw.kind == 'scheide' %} class="rw-sch"{% endif %}>
  <td class="c-nom">{{ coin.raw.nominal|nominal_nbsp|safe }}</td>
  <td class="c-year">{%- if coin.raw.year_label -%}
    {%- set parts = coin.raw.year_label.split(',') -%}
    {%- for p in parts %}<span class="yr-chunk">{{ p.strip() }}{% if not loop.last %},{% endif %}</span>{% endfor -%}
  {%- endif -%}</td>
  <td>{{ coin.raw.ruler|ruler(lang) }}</td>
  <td class="c-km">
    {%- for prefix, vals in coin.catalog_groups -%}
      {%- if prefix -%}
        <span class="cat-group"><span class="cat-prefix">{{ prefix }}#</span> {{ vals | join(', ') }}</span>
      {%- else -%}
        {%- for v in vals -%}
          <span class="cat-group cat-plain">{{ v }}</span>
          {%- if not loop.last %}<br>{% endif -%}
        {%- endfor -%}
      {%- endif -%}
      {%- if not loop.last %}<br>{% endif -%}
    {%- endfor -%}
  </td>
  <td class="c-metal">
    {%- if coin.raw.metal -%}
      {%- set metals = {
        'silver': {'de': 'Silber', 'en': 'Silver', 'uk': 'Срібло'},
        'gold':   {'de': 'Gold',   'en': 'Gold',   'uk': 'Золото'},
        'billon': {'de': 'Billon', 'en': 'Billon', 'uk': 'Білон'},
        'copper': {'de': 'Kupfer', 'en': 'Copper', 'uk': 'Мідь'}
      } -%}
      {{ metals[coin.raw.metal][lang] }}
      {%- if not coin.raw.metal_verified %} <span class="unverified" data-tooltip="{{ ui_get('marker.unverified') }}">(?)</span>{% endif -%}
      {%- if coin.fineness_groups -%}
        {%- for g in coin.fineness_groups %}
          {%- set _txt = '.' ~ ((g.value * 1000)|round|int) %}
          {%- if g.is_unanimous %} {{ _txt }}
          {%- else %} <span class="alt-source" data-tooltip="{{ g.sources|join('\n') }}">{{ _txt }}</span>
          {%- endif %}
        {%- endfor %}
      {%- endif -%}
      {%- if not coin.raw.fineness_verified %} <span class="unverified" data-tooltip="{{ ui_get('marker.unverified') }}">(?)</span>{% endif -%}
    {%- else -%}—{%- endif -%}
  </td>
  <td class="c-w">
    {%- if coin.weight_groups -%}
      {%- set _qmark -%}{%- if not coin.raw.weight_rough_verified %} <span class="unverified">(?)</span>{% endif -%}{%- endset -%}
      {%- for g in coin.weight_groups -%}
        {%- set _txt = fmt_num(g.value, decimals=2, unit='') -%}
        {%- if g.is_unanimous and not g.sources -%}{{ _txt }}{{ _qmark|safe }}
        {%- elif g.is_unanimous -%}{{ _txt }}{{ _qmark|safe }}
        {%- else %}<span class="alt-source" data-tooltip="{{ g.sources|join('\n') }}">{{ _txt }}{{ _qmark|safe }}</span>
        {%- endif -%}
      {%- endfor -%}
    {%- elif coin.raw.weight_rough_label -%}
      {{ coin.raw.weight_rough_label|t(lang) }}{%- if not coin.raw.weight_rough_verified %} <span class="unverified">(?)</span>{% endif -%}
    {%- else -%}—{%- endif -%}
  </td>
  <td class="c-w">
    {%- if coin.weight_fein_groups -%}
      {%- set _qmark -%}{%- if coin.derived_unverified %} <span class="unverified" data-tooltip="{{ ui_get('marker.derived_unverified') }}">(?)</span>{% endif -%}{%- endset -%}
      {%- for g in coin.weight_fein_groups -%}
        {%- set _txt = fmt_num(g.value, decimals=5, unit='') -%}
        {%- if g.is_unanimous and not g.sources -%}{{ _txt }}{{ _qmark|safe }}
        {%- elif g.is_unanimous -%}{{ _txt }}{{ _qmark|safe }}
        {%- else %}<span class="alt-source" data-tooltip="{{ g.sources|join('\n') }}">{{ _txt }}{{ _qmark|safe }}</span>
        {%- endif -%}
      {%- endfor -%}
    {%- else -%}—{%- endif -%}
  </td>
  <td class="c-d">
    {%- if coin.diameter_groups -%}
      {%- set _qmark -%}{%- if not coin.raw.diameter_mm_verified %} <span class="unverified" data-tooltip="{{ ui_get('marker.unverified') }}">(?)</span>{% endif -%}{%- endset -%}
      {%- for g in coin.diameter_groups -%}
        {%- set _txt = fmt_num(g.value, decimals=1, unit='') -%}
        {%- if g.is_unanimous and not g.sources -%}{{ _txt }}{{ _qmark|safe }}
        {%- elif g.is_unanimous -%}{{ _txt }}{{ _qmark|safe }}
        {%- else %}<span class="alt-source" data-tooltip="{{ g.sources|join('\n') }}">{{ _txt }}{{ _qmark|safe }}</span>
        {%- endif -%}
      {%- endfor -%}
    {%- else -%}—{%- endif -%}
  </td>
  <td class="c-mint">
    {%- if coin.raw.mint -%}
      {%- if coin.raw.mint is string -%}{{ coin.raw.mint }}
      {%- else -%}{{ coin.raw.mint|join(', ') }}
      {%- endif -%}
      {%- if not coin.raw.mint_verified %} <span class="unverified" data-tooltip="{{ ui_get('marker.unverified') }}">(?)</span>{% endif -%}
    {%- else -%}—{%- endif -%}
  </td>
  <td class="c-entity">
    {%- set ent = issuing_entities.get(coin.raw.issuing_entity) if coin.raw.issuing_entity else None -%}
    {%- if ent -%}
      <span class="ent-badge ent-{{ coin.raw.issuing_entity }}" data-tooltip="{{ ((ent.name|t(lang)) ~ ' — ' ~ ((ent.description|t(lang))|striptags if ent.description else '')) | nb_dashes }}">{{ ent.abbrev }}</span>
    {%- else -%}—{%- endif -%}
  </td>
  <td class="c-note">{{ (coin.raw.note|t(lang))|safe if coin.raw.note else '' }}</td>
  <td class="c-soll">
    {%- if coin.soll_fein_g -%}
      {{ fmt_num(coin.soll_fein_g, decimals=5, unit='') }}
    {%- else -%}—{%- endif -%}
  </td>
  <td class="c-delta">
    {%- if coin.delta_groups -%}
      {# 4-state Δ palette: under-deep (<-1%), under-mild (-1% … 0),
         over-mild (0 … +1%), over-strong (>+1%). Each unique Δ value
         renders as one badge; sources that produced the same value
         collapse into one entry with a combined tooltip. When ALL
         sources yield the same Δ (single group), drop both the
         alt-source styling AND the tooltip — same convention as the
         weight / fineness columns above (consensus = plain badge). #}
      {%- set _qmark -%}{%- if coin.derived_unverified %} <span class="unverified" data-tooltip="{{ ui_get('marker.derived_unverified') }}">(?)</span>{% endif -%}{%- endset -%}
      {%- for g in coin.delta_groups -%}
        {%- set dp = g.delta_pct if g.delta_pct is not none else 0 -%}
        {%- if dp < -1.0 -%}{%- set sd_cls = 'under-deep' -%}
        {%- elif dp < 0   -%}{%- set sd_cls = 'under-mild' -%}
        {%- elif dp <= 1.0 -%}{%- set sd_cls = 'over-mild' -%}
        {%- else -%}{%- set sd_cls = 'over-strong' -%}
        {%- endif -%}
        {%- if g.is_unanimous or not g.sources -%}
          <span class="sd {{ sd_cls }}">{{ fmt_delta(g.value, dp)|safe }}{{ _qmark|safe }}</span>
        {%- else -%}
          <span class="sd {{ sd_cls }} alt-source" data-tooltip="{{ g.sources|join('\n') }}">{{ fmt_delta(g.value, dp)|safe }}{{ _qmark|safe }}</span>
        {%- endif -%}
      {%- endfor -%}
    {%- elif coin.raw.metal == 'copper' -%}
      <span class="sd-na" data-tooltip="{{ ui_get('marker.copper_nodelta') }}">—</span>
    {%- else -%}—{%- endif -%}
  </td>
  <td class="c-fuss">
    {# When the coin has no computable fein weight (no fineness or no rough weight),
       collapse the Stopa column to a single plain rendering of the fuss name. The
       "▸ Primär:" prefix only carries meaning when contrasted with a Sekundär/Tertiär
       line; for unknown-fein coins it adds visual noise without information. #}
    {%- if coin.weight_fein_g is none -%}
      <span class="fuss-nominal">{{ coin.fuss.name|t(lang) }}</span>
    {%- elif coin.raw.fuss_refs -%}
      {%- for ref in coin.raw.fuss_refs -%}
        <span class="sf-line {{ ref.rank }}">{{ ref.label|t(lang)|safe }}</span>
      {%- endfor -%}
    {%- else -%}
      <span class="fuss-nominal">{{ coin.fuss.name|t(lang) }}</span>
    {%- endif -%}
    {# Auto-computed implied Fuß — appended whenever ANY source's reading
       meaningfully deviates from the declared standard (>2 %) AND fuss_refs
       doesn't already document an "Ist-Wert" note. The compute layer pre-
       filters to only the > 2 % entries and groups identical implied_fuss
       values, so the renderer just iterates: one line per unique implied
       Fuß, with combined source tooltip when multiple sources agree.
       Quantifies seigniorage gap for Scheidemünzen. #}
    {%- if coin.implied_fuss_groups and not coin.has_manual_implied -%}
      {%- set impl_label = {'de':'Ist','en':'Actual','uk':'Факт'}[lang] -%}
      {# Pick the Fuß-unit label by the fuss id (stable across DE/EN/UK names):
         every Krone-mønt fuss has 'kronemont' in its id (kronemont, kronemont_chr_iv,
         kronemont_fine); gold fuesse default to Dukatenfuß. Otherwise fall back
         to the generic Thaler-Fuß. #}
      {%- if coin.fuss.metal == 'gold' -%}
        {%- set fuss_unit = 'Dukatenfuß' -%}
      {%- elif 'kronemont' in coin.fuss.id -%}
        {%- set fuss_unit = 'Krone-Fuß' -%}
      {%- else -%}
        {%- set fuss_unit = 'Thaler-Fuß' -%}
      {%- endif -%}
      {# Implied Fuß always carries source attribution in its tooltip
         even when there's a single group — unlike weight/Δ where a
         single group means consensus across ALL sources, here it only
         means consensus across the SUBSET whose |delta| > 2 %. The
         tooltip stays so the reader can trace which source(s) drove
         the implied value. The alt-source orange tint only kicks in
         when multiple distinct implied values coexist. #}
      {%- for g in coin.implied_fuss_groups -%}
        {%- set _alt_cls = '' if loop.length == 1 else ' alt-source' -%}
        {%- if g.sources -%}
          <span class="sf-line implied{{ _alt_cls }}" data-tooltip="{{ g.sources|join('\n') }}">↳ {{ impl_label }} ≈ <span class="fuss-name">{{ fmt_num(g.value, decimals=2, unit='') }}-{{ fuss_unit }}</span>{%- if loop.length == 1 and coin.derived_unverified %} <span class="unverified" data-tooltip="{{ ui_get('marker.derived_unverified') }}">(?)</span>{% endif -%}</span>
        {%- else -%}
          <span class="sf-line implied">↳ {{ impl_label }} ≈ <span class="fuss-name">{{ fmt_num(g.value, decimals=2, unit='') }}-{{ fuss_unit }}</span>{%- if coin.derived_unverified %} <span class="unverified" data-tooltip="{{ ui_get('marker.derived_unverified') }}">(?)</span>{% endif -%}</span>
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
  </td>
  <td class="c-ref">
    {%- for s in coin.raw.sources -%}
      <span class="ref-line">
      {%- if s.url -%}
        <a href="{{ s.url }}" target="_blank" rel="noopener">{{ s.ref or s.type }}</a>
      {%- else -%}
        {{ s.ref or s.type }}
      {%- endif -%}
      </span>
    {%- endfor -%}
  </td>
</tr>
{%- endmacro %}

{%- macro coin_table(coins) %}
<div class="mt-scroll"><table class="mt">
  <thead>
    <tr>
      <th>{{ ui_get('col.nominal') }}</th>
      <th>{{ ui_get('col.year') }}</th>
      <th>{{ ui_get('col.ruler') }}</th>
      <th>{{ ui_get('col.catalog') }}</th>
      <th>{{ ui_get('col.metal_fineness') }}</th>
      <th>{{ ui_get('col.rough') }}</th>
      <th>{{ ui_get('col.fine') }}</th>
      <th>{{ ui_get('col.diameter') }}</th>
      <th>{{ ui_get('col.mint') }}</th>
      <th data-tooltip="{{ ui_get('col.entity_tooltip') }}">{{ ui_get('col.entity') }}</th>
      <th>{{ ui_get('col.note') }}</th>
      <th data-tooltip="{{ ui_get('col.soll_tooltip') }}">{{ ui_get('col.soll') }}</th>
      <th data-tooltip="{{ ui_get('col.delta_tooltip') }}">{{ ui_get('col.delta') }}</th>
      <th data-tooltip="{{ ui_get('col.fuss_tooltip') }}">{{ ui_get('col.fuss') }}</th>
      <th>{{ ui_get('col.source') }}</th>
    </tr>
  </thead>
  <tbody>
    {% for coin in coins %}{{ coin_row(coin) }}{% endfor %}
  </tbody>
</table></div>
{%- endmacro %}

{# Copper petty-coin row — pure copper tokens have no silver target, so Soll/Δ/Fuß
   are dropped entirely. Fine-weight column is also omitted (always zero for copper). #}
{%- macro coin_row_copper(coin) %}
<tr class="rw-cp">
  <td class="c-nom">{{ coin.raw.nominal|nominal_nbsp|safe }}</td>
  <td class="c-year">{%- if coin.raw.year_label -%}
    {%- set parts = coin.raw.year_label.split(',') -%}
    {%- for p in parts %}<span class="yr-chunk">{{ p.strip() }}{% if not loop.last %},{% endif %}</span>{% endfor -%}
  {%- endif -%}</td>
  <td>{{ coin.raw.ruler|ruler(lang) }}</td>
  <td class="c-km">
    {%- for prefix, vals in coin.catalog_groups -%}
      {%- if prefix -%}
        <span class="cat-group"><span class="cat-prefix">{{ prefix }}#</span> {{ vals | join(', ') }}</span>
      {%- else -%}
        {%- for v in vals -%}
          <span class="cat-group cat-plain">{{ v }}</span>
          {%- if not loop.last %}<br>{% endif -%}
        {%- endfor -%}
      {%- endif -%}
      {%- if not loop.last %}<br>{% endif -%}
    {%- endfor -%}
  </td>
  <td class="c-metal">
    {%- set metals = {
      'copper': {'de': 'Kupfer', 'en': 'Copper', 'uk': 'Мідь'},
      'bronze': {'de': 'Bronze', 'en': 'Bronze', 'uk': 'Бронза'},
      'brass':  {'de': 'Messing','en': 'Brass',  'uk': 'Латунь'}
    } -%}
    {{ metals[coin.raw.metal][lang] if coin.raw.metal in metals else coin.raw.metal }}
  </td>
  <td class="c-w">
    {%- if coin.weight_groups -%}
      {%- set _qmark -%}{%- if not coin.raw.weight_rough_verified %} <span class="unverified">(?)</span>{% endif -%}{%- endset -%}
      {%- for g in coin.weight_groups -%}
        {%- set _txt = fmt_num(g.value, decimals=2, unit='') -%}
        {%- if g.is_unanimous -%}{{ _txt }}{{ _qmark|safe }}
        {%- else %}<span class="alt-source" data-tooltip="{{ g.sources|join('\n') }}">{{ _txt }}{{ _qmark|safe }}</span>
        {%- endif -%}
      {%- endfor -%}
    {%- elif coin.raw.weight_rough_label -%}
      {{ coin.raw.weight_rough_label|t(lang) }}{%- if not coin.raw.weight_rough_verified %} <span class="unverified">(?)</span>{% endif -%}
    {%- else -%}—{%- endif -%}
  </td>
  <td class="c-d">
    {%- if coin.diameter_groups -%}
      {%- set _qmark -%}{%- if not coin.raw.diameter_mm_verified %} <span class="unverified">(?)</span>{% endif -%}{%- endset -%}
      {%- for g in coin.diameter_groups -%}
        {%- set _txt = fmt_num(g.value, decimals=1, unit='') -%}
        {%- if g.is_unanimous -%}{{ _txt }}{{ _qmark|safe }}
        {%- else %}<span class="alt-source" data-tooltip="{{ g.sources|join('\n') }}">{{ _txt }}{{ _qmark|safe }}</span>
        {%- endif -%}
      {%- endfor -%}
    {%- else -%}—{%- endif -%}
  </td>
  <td class="c-mint">
    {%- if coin.raw.mint -%}
      {%- if coin.raw.mint is string -%}{{ coin.raw.mint }}
      {%- else -%}{{ coin.raw.mint|join(', ') }}
      {%- endif -%}
      {%- if not coin.raw.mint_verified %} <span class="unverified" data-tooltip="{{ ui_get('marker.unverified') }}">(?)</span>{% endif -%}
    {%- else -%}—{%- endif -%}
  </td>
  <td class="c-entity">
    {%- set ent = issuing_entities.get(coin.raw.issuing_entity) if coin.raw.issuing_entity else None -%}
    {%- if ent -%}
      <span class="ent-badge ent-{{ coin.raw.issuing_entity }}" data-tooltip="{{ ent.name|t(lang) }}">{{ ent.abbrev }}</span>
    {%- else -%}—{%- endif -%}
  </td>
  <td class="c-note">{{ (coin.raw.note|t(lang))|safe if coin.raw.note else '' }}</td>
  <td class="c-ref">
    {%- for s in coin.raw.sources -%}
      <span class="ref-line">
      {%- if s.url -%}
        <a href="{{ s.url }}" target="_blank" rel="noopener">{{ s.ref or s.type }}</a>
      {%- else -%}
        {{ s.ref or s.type }}
      {%- endif -%}
      </span>
    {%- endfor -%}
  </td>
</tr>
{%- endmacro %}

{%- macro coin_table_copper(coins) %}
<div class="mt-scroll"><table class="mt mt-copper">
  <thead>
    <tr>
      <th>{{ ui_get('col.nominal') }}</th>
      <th>{{ ui_get('col.year') }}</th>
      <th>{{ ui_get('col.ruler') }}</th>
      <th>{{ ui_get('col.catalog') }}</th>
      <th>{{ ui_get('col.metal') }}</th>
      <th>{{ ui_get('col.rough') }}</th>
      <th>{{ ui_get('col.diameter') }}</th>
      <th>{{ ui_get('col.mint') }}</th>
      <th data-tooltip="{{ ui_get('col.entity_tooltip') }}">{{ ui_get('col.entity') }}</th>
      <th>{{ ui_get('col.note') }}</th>
      <th>{{ ui_get('col.source') }}</th>
    </tr>
  </thead>
  <tbody>
    {% for coin in coins %}{{ coin_row_copper(coin) }}{% endfor %}
  </tbody>
</table></div>
{%- endmacro %}



<nav class="nav">
  <a href="../../index.html">{{ ui_get('nav.home') }}</a>
  <span style="color: var(--text-muted);">/</span>
  <strong>{{ tree.location.name|t(lang) }}</strong>
  <div class="switchers">
    <div class="theme-switch" role="group" aria-label="Theme">
      <button type="button" class="th th-v1" data-theme="v1" title="Museum Atlas — paper &amp; gold" aria-label="Museum Atlas">
        <span class="th-swatch" aria-hidden="true"><i class="sw sw-1"></i><i class="sw sw-2"></i><i class="sw sw-3"></i></span>
        <span class="th-label">Atlas</span>
      </button>
      <button type="button" class="th th-v2" data-theme="v2" title="Editorial Codex — ink &amp; vermilion" aria-label="Editorial Codex">
        <span class="th-swatch" aria-hidden="true"><i class="sw sw-1"></i><i class="sw sw-2"></i><i class="sw sw-3"></i></span>
        <span class="th-label">Codex</span>
      </button>
      <button type="button" class="th th-v3 active" data-theme="v3" title="Refined Dark — graphite &amp; gold" aria-label="Refined Dark">
        <span class="th-swatch" aria-hidden="true"><i class="sw sw-1"></i><i class="sw sw-2"></i><i class="sw sw-3"></i></span>
        <span class="th-label">Noir</span>
      </button>
    </div>
    <div class="lang-switch">
      {% for l in languages -%}
        {%- if l == lang -%}
          <a class="active">{{ l|upper }}</a>
        {%- else -%}
          <a href="../{{ l }}/">{{ l|upper }}</a>
        {%- endif -%}
      {%- endfor %}
    </div>
  </div>
</nav>

{# Compute hero stats — counts walked across the rendered fuss tree so
   the Münzfüße / Münzen tiles match the visible content (skipping
   fuesse without phases / period / Grundwerte that the template hides). #}
{% set ns = namespace(fuss_count=0, coin_total=0) %}
{% set fp_lookup = tree.location.fuss_periods %}
{% for sg in tree.fuesse %}
  {% set sp = fp_lookup.get(sg.fuss.id) if fp_lookup else None %}
  {% if sg.nonempty_phases or sp or sg.fuss.grundwerte %}
    {% set ns.fuss_count = ns.fuss_count + 1 %}
    {% set ns.coin_total = ns.coin_total + (sg.nonempty_phases | sum(attribute='total') if sg.nonempty_phases else 0) %}
  {% endif %}
{% endfor %}
{% set hero_refs = (references.entries | length) if references and references.entries else 0 %}

<section class="hero">
  <div class="hero-text">
    <h1 class="h1">{{ ui_get('hero.eyebrow') }}<em class="h1-sub">{{ tree.location.name|t(lang) }}</em></h1>
    <p class="deck">{{ tree.location.summary|t(lang) }}</p>
  </div>
  <div class="hero-stats">
    {% if tree.location.timeline %}
    <div class="hs-stat">
      <span class="hs-lbl">{{ ui_get('hero.stat.zeitraum') }}</span>
      <span class="hs-val">{{ tree.location.timeline.year_from }}—{{ tree.location.timeline.year_to }}</span>
    </div>
    {% endif %}
    <div class="hs-stat">
      <span class="hs-lbl">{{ ui_get('hero.stat.muenzfuesse') }}</span>
      <span class="hs-val">{{ ns.fuss_count }}<sub>{{ ui_get('hero.stat.standards_unit') }}</sub></span>
    </div>
    <div class="hs-stat">
      <span class="hs-lbl">{{ ui_get('hero.stat.muenzen') }}</span>
      <span class="hs-val">{{ ns.coin_total }}<sub>{{ ui_get('hero.stat.coins_unit') }}</sub></span>
    </div>
    {% if hero_refs %}
    <div class="hs-stat">
      <span class="hs-lbl">{{ ui_get('hero.stat.quellen') }}</span>
      <span class="hs-val">{{ hero_refs }}<sub>{{ ui_get('hero.stat.refs_unit') }}</sub></span>
    </div>
    {% endif %}
    <div class="hs-stat hs-stat-wide">
      <span class="hs-lbl">{{ ui_get('hero.stat.revision') }}</span>
      <span class="hs-val hs-val-date">{{ fmt_date(generated_date) }}</span>
    </div>
  </div>
</section>

{% set tl = tree.location.timeline %}
{% if tl %}
{% set tl_span = (tl.year_to - tl.year_from) %}
<div class="tl">
  <div class="tl-header">
    <div class="tl-title">{{ tl.title|t(lang) }}</div>
    {# Per-entity filter chips: one checkbox per issuing entity, labelled
       with its 2-letter abbrev («RH» / «HG» / «DK» / «DK+» / …), preceded
       by a single «All» master chip. All unchecked by default —
       interactive behaviour to be wired up separately. Per-entity order
       matches data/i18n/issuing_entities.yml; entities with no coins in
       this location are skipped (no marker would ever show, so the chip
       would be dead weight — e.g. `prussian_province` in schleswig_holstein.yml,
       since post-1866 Reichsmark coinage isn't modelled as a Fuß here). #}
    <div class="tl-filters">
      <label class="tl-filter tl-filter-all">
        <input type="checkbox" name="tl-filter-all" />
        <span class="tl-filter-label">{{ ui_get('tl.filter.all') }}</span>
      </label>
      {%- for ent_id, ent in issuing_entities.items() -%}
        {%- if ent_id in active_entity_ids -%}
          <label class="tl-filter tl-filter-{{ ent_id }}"
                 {% if ent.name %}data-tooltip="{{ ent.name|t(lang) }}"{% endif %}>
            <input type="checkbox" name="tl-filter-{{ ent_id }}" />
            <span class="tl-filter-label">{{ ent.abbrev }}</span>
          </label>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
  <div class="tl-grid">
    {%- macro tl_bar_html(bar, tl, tl_span, lang, extra_class='', layers=None, year_runs=None, zones=None) -%}
      {# A year is a 1-year-wide block, not a point — the bar runs through
         year `year_to` inclusive, so the right edge sits at point
         `(year_to + 1)`. Same convention used by `.tl-bar-layer` (in
         lib/categorize.compute_bar_layers) and `.tl-coin-year` (in
         compute_coin_year_runs); without this `+ 1` the marker for the
         last minted year visibly overshoots the bar's right edge. #}
      {%- set raw_left  = (bar.year_from     - tl.year_from) / tl_span * 100 -%}
      {%- set raw_right = (bar.year_to + 1   - tl.year_from) / tl_span * 100 -%}
      {%- set clamped_left  = [raw_left, 0]  | max -%}
      {%- set clamped_right = [raw_right, 100] | min -%}
      {%- set left_pct  = clamped_left | round(2) -%}
      {%- set width_pct = (clamped_right - clamped_left) | round(2) -%}
      {# Bars under ~22 % of the timeline cannot fit a typical bar_label
         («1566 — ca. 1622 · ~56 J.» ≈ 24 chars × 7 px = 168 px in mono;
         a 22 %-wide bar on a 900 px track is ~198 px — the cutoff). Below
         this threshold the label renders as a floating tag overlaid on
         the bar (overflow visible, halo text-shadow for legibility). #}
      {%- set narrow = width_pct < 21 -%}
      {# Bar label: use the YAML-set bar_label if present. Auto-derived
         «year_from—year_to» is suppressed when the bar carries layers
         (mint × {anywhere, holstein}, status × …, circulation × …) —
         per user feedback the auto-years confuse readers because the
         single «1566—1764» on a multi-layer bar reads as «one period»,
         while the actual mint / status / circulation periods may end
         at different years. The detailed years live in per-layer
         tooltips instead. Layer-less bars keep the auto-derived label
         so a narrow swatch with no layers (e.g. a stub fuss) still
         shows temporal context. #}
      {%- if bar.bar_label -%}
        {%- set _label = bar.bar_label|t(lang) -%}
      {%- elif layers -%}
        {%- set _label = '' -%}
      {%- else -%}
        {%- set _label = bar.year_from|string + '—' + bar.year_to|string -%}
      {%- endif -%}
      {# When the bar has period × scope layers (mint / status / circulation
         × anywhere / holstein), render them as siblings BEFORE the .tl-bar
         so they paint underneath the label. Each layer is a flat-colour
         block at 1/6 alpha with `mix-blend-mode: plus-lighter`, so 6
         overlapping layers sum to the full base colour and any subset
         renders proportionally fainter. The .tl-bar itself becomes a
         transparent label-only box (no gradient) when layers are present. #}
      {%- if layers or year_runs -%}
        {# `.tl-bar-layers` wraps BOTH the period × scope colour layers AND
           the per-year mintage markers in a single isolation group so:
             1. `mix-blend-mode: plus-lighter` on `.tl-bar-layer` starts
                from a transparent backdrop (NOT the track's dark bg,
                which would otherwise be additively summed in).
             2. Hover tooltips on layers AND on markers — both `::after`
                pseudo-elements with `z-index: 100` — render on top of
                every other element in the same stacking context, including
                the markers themselves. Markers used to sit OUTSIDE this
                isolation with `z-index: 3`, which made layer tooltips
                (locked inside the isolation, whose context sat at
                `z-auto` in the track) paint UNDERNEATH markers. #}
        <div class="tl-bar-layers">
        {%- if layers -%}
          {# Pre-compute per-layer tooltip text into `_tts.parts[i]`. Used
             below for the visual layer divs themselves AND for the
             hover-zone overlay divs (which join the active layers'
             texts into a single `data-tooltip` per zone). #}
          {%- set _tts = namespace(parts=[]) -%}
          {%- for layer in layers -%}
            {%- set _kind_parts = [] -%}
            {%- for k in (layer.kinds or [layer.kind]) -%}
              {%- if _kind_parts.append(ui_get('tl.layer.' ~ k)) -%}{%- endif -%}
            {%- endfor -%}
            {%- set _kind_lbl = _kind_parts | join(' · ') -%}
            {%- if layer.scope == 'holstein' -%}
              {%- set _scope_lbl = ui_get(layer.scope_label_key or 'tl.scope.schleswig_holstein') -%}
            {%- elif layer.anywhere_label -%}
              {%- set _scope_lbl = layer.anywhere_label|t(lang) -%}
            {%- else -%}
              {%- set _scope_lbl = '—' -%}
            {%- endif -%}
            {%- set _y0 = ('~' ~ layer.first) if layer.first_approx else layer.first -%}
            {%- set _y1 = ('~' ~ layer.last) if layer.last_approx else layer.last -%}
            {%- set _txt = (_kind_lbl ~ ': ' ~ _scope_lbl ~ ', ' ~ _y0 ~ '—' ~ _y1) | nb_dashes -%}
            {%- set _tts.parts = _tts.parts + [_txt] -%}
          {%- endfor -%}
          {# Render the visual colour layers. They carry their tooltip part
             in `data-tt-part` (read by zone-rendering below), but no
             `data-tooltip` and no pointer-events — they don't trigger
             ::after themselves.

             Merged layers (`layer.kinds | length > 1` — when several
             period × scope events share an identical span and were
             collapsed in `categorize.py`) emit ONE visual `<div>` per
             merged kind, all stacked at the same `[left, width]`. Each
             div contributes its own 1/6 alpha through `mix-blend-mode:
             plus-lighter`, restoring the additive saturation that an
             unmerged layer set would have produced naturally. Without
             this, a 3-kinds merge renders at 1/6 alpha while three
             distinct-span layers would sum to 3/6 — making merged bars
             appear visibly darker than non-merged bars even when their
             period × scope coverage is identical. The merge is purely
             a tooltip-deduplication concern; the visual must reflect
             the underlying event count. #}
          {%- for layer in layers -%}
            {%- set _kinds = layer.kinds or [layer.kind] -%}
            {%- set _tt_idx = loop.index0 -%}
            {%- for _kind in _kinds -%}
              <div class="tl-bar-layer {{ bar.color_class }} tl-bar-layer-{{ layer.kind }} tl-bar-layer-{{ layer.scope }}{% if layer.first_approx %} tl-bar-layer-fade-start{% endif %}{% if layer.last_approx %} tl-bar-layer-fade-end{% endif %}"
                   style="left:{{ layer.left_pct }}%;width:{{ layer.width_pct }}%"
                   data-tt-part="{{ _tts.parts[_tt_idx] }}"
                   aria-hidden="true"></div>
            {%- endfor -%}
          {%- endfor -%}
        {%- endif -%}
        {%- if zones -%}
          {# Hover zones — one transparent overlay per year segment in which
             the active layer set is constant. Each zone's `data-tooltip`
             is the '\n'-joined text of all layers active in that segment.
             Browser-native `:hover::after` renders the joined text;
             no JavaScript runs per cursor pixel, so there is no
             rapid-mousemove flicker. Zone left/width are pre-computed
             in `compute_hover_zones` (categorize.py). #}
          {%- for zone in zones -%}
            {%- set _zone_parts = [] -%}
            {%- for idx in zone.layer_indices -%}
              {%- if _zone_parts.append(_tts.parts[idx]) -%}{%- endif -%}
            {%- endfor -%}
            <div class="tl-bar-hover-zone"
                 style="left:{{ zone.left_pct }}%;width:{{ zone.width_pct }}%;--tt-cx:{{ zone.tt_offset_pct }}%"
                 data-tooltip="{{ _zone_parts | join('\n') }}"
                 aria-hidden="true"></div>
          {%- endfor -%}
        {%- endif -%}
        {%- if year_runs -%}
          {%- for run in year_runs -%}
            {%- if run.first == run.last -%}
              {%- set _years_lbl = run.first|string -%}
            {%- else -%}
              {%- set _years_lbl = run.first|string ~ '—' ~ run.last|string -%}
            {%- endif -%}
            {%- set _orig = run.orig_entities|join(',') -%}
            {# One DOM `<div>` per non-empty subset of the run's entity set.
               JS picks at most one variant to render visible per rect:
               the variant whose `data-ents` exactly equals the checked-
               filter intersection with `data-orig` («highest match»).
               Variants share `[left, width]`, so they overlap perfectly;
               only the matching one carries `tl-coin-year-show` and
               flips into `display: block`. Tooltip per variant lists
               only the entities present in THAT subset's coin counts. #}
            {%- for variant in run.variants -%}
              {%- set _ents = variant.entities|join(',') -%}
              {%- if variant.entities|length == 1 -%}
                {%- set _color_class = 'tl-coin-year-' ~ variant.entities[0] -%}
              {%- else -%}
                {%- set _color_class = 'tl-coin-year-shared' -%}
              {%- endif -%}
              {%- set ns = namespace(parts=[_years_lbl]) -%}
              {%- for ent_id, cnt in variant.entity_counts -%}
                {%- if issuing_entities.get(ent_id) -%}
                  {%- set _name = issuing_entities.get(ent_id).name|t(lang) -%}
                  {%- set ns.parts = ns.parts + [_name ~ ': ' ~ cnt|string] -%}
                {%- endif -%}
              {%- endfor -%}
              <div class="tl-coin-year {{ _color_class }}"
                   data-orig="{{ _orig }}"
                   data-ents="{{ _ents }}"
                   style="left:{{ run.left_pct }}%;width:{{ run.width_pct }}%"
                   data-tooltip="{{ (ns.parts | join('\n')) | nb_dashes }}"
                   aria-hidden="true"></div>
            {%- endfor -%}
          {%- endfor -%}
        {%- endif -%}
        </div>
      {%- endif -%}
      <div class="tl-bar tl-bar-{{ bar.id }} {{ bar.color_class }}{% if layers %} tl-bar-layered{% endif %}{% if bar.dashed %} tl-bar-dashed{% endif %}{% if raw_left < 0 %} tl-bar-cut-left{% endif %}{% if raw_right > 100 %} tl-bar-cut-right{% endif %}{% if narrow %} tl-bar-narrow{% endif %} {{ extra_class }}"
           style="left:{{ left_pct }}%;width:{{ width_pct }}%"
           {%- if not layers and bar.bar_title %} data-tooltip="{{ bar.bar_title|t(lang) | nb_dashes }}"{%- endif %}>
        {%- if narrow -%}
          <span class="tl-bar-label-float">{{ _label }}</span>
        {%- else -%}
          {{ _label }}
        {%- endif -%}
      </div>
    {%- endmacro -%}

    {%- set _fuss_section_ids = [] -%}
    {%- for sg in tree.fuesse -%}
      {%- set _sp = fp_lookup.get(sg.fuss.id) if fp_lookup else None -%}
      {%- if sg.nonempty_phases or _sp or sg.fuss.grundwerte -%}
        {%- set _ = _fuss_section_ids.append(sg.fuss.id) -%}
      {%- endif -%}
    {%- endfor -%}

    {% for group in tl.bars | group_bars %}
      {% set primary = group.primary %}
      <div class="tl-label{% if primary.indented %} tl-label-sub{% endif %}">
        {%- if primary.id in _fuss_section_ids -%}
          <a class="tl-label-link" href="#fuss-{{ primary.id }}">{{ primary.label|t(lang) }}</a>
        {%- else -%}
          {{ primary.label|t(lang) }}
        {%- endif -%}
        {% if primary.small %}<small>{{ primary.small|t(lang) }}</small>{% endif %}
        {% for ov in group.overlays %}
        <div class="tl-sublabel{% if ov.indented %} tl-label-sub{% endif %}">
          {%- if ov.id in _fuss_section_ids -%}
            <a class="tl-label-link" href="#fuss-{{ ov.id }}">{{ ov.label|t(lang) }}</a>
          {%- else -%}
            {{ ov.label|t(lang) }}
          {%- endif -%}
          {% if ov.small %}<small>{{ ov.small|t(lang) }}</small>{% endif %}
        </div>
        {% endfor %}
      </div>
      <div class="tl-track{% if primary.compact %} tl-track-compact{% endif %}">
        {{ tl_bar_html(primary, tl, tl_span, lang, layers=bar_layers.get(primary.id, []) if bar_layers else [], year_runs=coin_years.get(primary.id, []) if coin_years else [], zones=hover_zones.get(primary.id, []) if hover_zones else []) }}
        {% for ov in group.overlays %}
          {{ tl_bar_html(ov, tl, tl_span, lang, 'tl-bar-overlay', layers=bar_layers.get(ov.id, []) if bar_layers else [], year_runs=coin_years.get(ov.id, []) if coin_years else [], zones=hover_zones.get(ov.id, []) if hover_zones else []) }}
        {% endfor %}
        {# Phase sub-divisions are intentionally NOT rendered on the timeline
           — that level of detail belongs in the per-fuss section below where
           each phase has its own card with title, dates, description and
           coin tables. The timeline is just the year-range overview. #}
      </div>
    {% endfor %}
    <div></div>
    <div class="tl-axis">
      {# Snap axis labels to round years (1550, 1600, …) for legibility — instead
         of starting at year_from (1559) which produces awkward 1559/1609/1659…
         labels. Off-scale ticks are clamped between 0 % and 100 %. #}
      {% set first_tick = (tl.year_from // tl.axis_step) * tl.axis_step %}
      {% if first_tick < tl.year_from %}{% set first_tick = first_tick + tl.axis_step %}{% endif %}
      {% set last_tick = (tl.year_to // tl.axis_step) * tl.axis_step %}
      {% set tick_count = ((last_tick - first_tick) // tl.axis_step) + 1 if last_tick >= first_tick else 0 %}
      {% for i in range(tick_count) %}
        {% set year = first_tick + i * tl.axis_step %}
        {% set pos = ((year - tl.year_from) / tl_span * 100) | round(2) %}
        <span style="left:{{ pos }}%">{{ year }}</span>
      {% endfor %}
    </div>
  </div>
</div>
{% endif %}

{% set fuss_periods = tree.location.fuss_periods %}
{% for sg in tree.fuesse %}
{% set sp = fuss_periods.get(sg.fuss.id) if fuss_periods else None %}
{# Render the Müntzfuß block if it has phases OR a period description OR grundwerte — so a standard that applied in the location but without its own coin issues (e.g. Prussian Vereinsthaler here) still appears as header + grundwerte + closing. #}
{% if sg.nonempty_phases or sp or sg.fuss.grundwerte %}

<section class="fuss-block fuss-{{ sg.fuss.id }}" id="fuss-{{ sg.fuss.id }}">
<div class="phase-header">
  <div class="ph-left">
    {# Period-correct synonym (Reichsmüntzfuß, Speciesfuß, Kurantmøntfod,
       Rigsbankfod, Vereinsmüntzfuß, Kronemøntfod, …) is nested INSIDE
       .pname as an <em>, mirroring the hero's `<h1 class="h1"> …
       <em class="h1-sub">…</em></h1>` pattern. The nesting is what makes
       the `font-size: 0.62em` rule on .phistorical compute relative to
       pname's 56-60 px instead of the body default. #}
    <span class="pname">{{ sg.fuss.name|t(lang) }}{% if sg.fuss.historical_name %}<em class="phistorical">{{ sg.fuss.historical_name }}</em>{% endif %}</span>
    {# Short summary in the title — uses hintergrund directly. Each fuss is
       expected to keep hintergrund short (1–3 sentences); longer historical
       elaboration belongs in `details` and lives inside the details toggle. #}
    {% if sp and sp.hintergrund %}
      <span class="psub">{{ sp.hintergrund|t(lang)|safe }}</span>
    {% elif sg.fuss.description %}
      <span class="psub" style="white-space: pre-line;">{{ sg.fuss.description|t(lang) }}</span>
    {% endif %}
  </div>
  {% if sp and sp.pdate_label %}
    <div class="ph-right">
      <span class="pdate">{{ sp.pdate_label|t(lang)|safe }}</span>
    </div>
  {% endif %}
</div>

{% set gw = sg.fuss.grundwerte %}
{% if gw %}
<section class="gw">
  <div class="gw-head">
    <div class="gw-head-text">
      {% if gw.heading %}<div class="gw-heading">{{ gw.heading|t(lang) }}</div>{% endif %}
      {% if gw.subheading %}<div class="gw-subheading">{{ gw.subheading|t(lang) }}</div>{% endif %}
    </div>
    {% if gw.badge %}<span class="bx {{ sg.fuss.metal }}">{{ gw.badge|t(lang) }}</span>{% endif %}
  </div>
  <div class="gw-body">
    {% if gw.rows %}
    <div class="gw-rows">
      {% for row in gw.rows %}
      <div class="gw-row">
        <div class="gw-k">{{ row.key|t(lang) }}</div>
        <div class="gw-v">{{ row.value|t(lang)|safe }}</div>
      </div>
      {% endfor %}
    </div>
    {% endif %}
    {% if gw.rechnungsfraktionen %}
    <div class="gw-fr">
      {% if gw.rechnungsfraktionen_label %}
      <span class="gw-fr-label">{{ gw.rechnungsfraktionen_label|t(lang) }}</span>
      {% endif %}
      {{ gw.rechnungsfraktionen|t(lang)|safe }}
    </div>
    {% endif %}
  </div>
</section>
{% endif %}

{# A single fuss-level toggle that reveals the long historical detail (sp.details)
   and ALL phase blocks with their tables already expanded. The <summary> doubles
   as a stats bar — phase / coin / Grundwerte counts on the left, Details pill
   on the right (per design). #}
{# Show the collapsible details toggle only when this Müntzfuß has at
   least one coin documented on this page. A fuss with curated `details`
   text but no coins (e.g. kronemont_chr_iv on the SH page — a Kopenhagen-
   only standard with no Holstein issues) renders only its header,
   Grundwerte and closing summary; the details toggle is hidden because
   there's no coin table for it to expand into. The details prose, when
   it matters as standalone history, lives elsewhere — in `hintergrund`
   or `closing`, both shown unconditionally. #}
{% if sg.nonempty_phases %}
{% set ph_n = sg.nonempty_phases|length %}
{% set coin_n = sg.nonempty_phases|sum(attribute='total') if sg.nonempty_phases else 0 %}
{# Distinct `nominal` strings across all coins of this fuss on this page.
   Replaces an earlier `len(grundwerte.rows)` count — Grundwerte rows
   describe the Müntzfuß's metric specs (Feingewicht, Tarif, Verbreitung
   …), not denominations, and the previous «N базових величин» label
   was confusing. Computed in `categorize.FussGroup.unique_nominals`. #}
{% set nom_n = sg.unique_nominals %}
<details class="fuss-details" data-fuss="{{ sg.fuss.id }}">
  <summary class="fuss-summary">
    <div class="fs-stats">
      <div class="fs-stat">
        <span class="fs-num">{{ ph_n }}</span>
        <span class="fs-lbl">{{ ui_get('fuss.stat.phase_one') if ph_n == 1 else ui_get('fuss.stat.phase_many') }}</span>
      </div>
      <div class="fs-stat">
        <span class="fs-num">{{ coin_n }}</span>
        <span class="fs-lbl">{{ ui_get('fuss.stat.coins_logged') }}</span>
      </div>
      {% if nom_n %}
      <div class="fs-stat">
        <span class="fs-num">{{ nom_n }}</span>
        <span class="fs-lbl">{{ ui_get('fuss.stat.nominal_one') if nom_n == 1 else ui_get('fuss.stat.nominal_many') }}</span>
      </div>
      {% endif %}
    </div>
    <span class="fs-toggle">
      <span class="fs-toggle-icon" aria-hidden="true">+</span>
      <span class="fd-label fd-label-show">{{ ui_get('fuss.show_details') }}</span>
      <span class="fd-label fd-label-hide">{{ ui_get('fuss.hide_details') }}</span>
      <span class="fd-count">({{ coin_n }})</span>
    </span>
  </summary>
  <div class="fuss-details-body">

    {# Long-form historical detail — only inside the details toggle. The title
       block already shows the short hintergrund summary; this is the place
       for paragraphs of historical context, sourcing notes, etc. #}
    {% if sp and sp.details %}
    <div class="fuss-hintergrund">{{ sp.details|t(lang)|safe }}</div>
    {% endif %}

    {% for pg in sg.nonempty_phases %}
    <div class="ph" data-phase="{{ pg.phase.id }}">
      {% if pg.phase.id in ('single', 'only', 'einzige') %}
        {{ pg.phase.title|t(lang) }} · {{ pg.phase.from_label }} → {{ pg.phase.to_label }}
      {% else %}
        {% if lang == 'de' %}Phase{% elif lang == 'en' %}Phase{% else %}Фаза{% endif %} {{ pg.phase.id }} · {{ pg.phase.from_label }} → {{ pg.phase.to_label }} · {{ pg.phase.title|t(lang) }}
      {% endif %}
    </div>
    {% if pg.phase.description %}
    <div class="phd">{{ pg.phase.description|t(lang)|safe }}</div>
    {% endif %}

    <div class="phc">
      {% if pg.phase.context %}
      <div class="phc-context">{{ pg.phase.context|t(lang)|safe }}</div>
      {% endif %}

      {% if pg.phase.mt_caption %}
      <div class="mt-caption">{{ pg.phase.mt_caption|t(lang)|safe }}</div>
      {% endif %}

      {# Display order: main coins (kurant / tarif) before subsidiary coins
         (scheide / copper). This puts the headline coin of the standard first
         and its petty subdivisions after — the standard numismatic-catalogue
         convention. #}
      {% if pg.kurant_coins %}
        {% if pg.is_mixed or pg.tarif_coins %}
        <div class="mt-subcat kurant">
          ✦ {{ ui_get('label.kurant') }}
          <span class="sc-desc">{{ ui_get('kurant.desc') }}</span>
        </div>
        {% endif %}
        {{ coin_table(pg.kurant_coins) }}
      {% endif %}

      {% if pg.tarif_coins %}
        {% if pg.tarif_deviant_coins or pg.tarif_subunit_coins or pg.scheide_coins or pg.copper_coins %}
        <div class="mt-subcat kurant">
          ✦ {{ ui_get('label.tarif') }}
          <span class="sc-desc">{{ ui_get('tarif.desc') }}</span>
        </div>
        {% endif %}
        {{ coin_table(pg.tarif_coins) }}
      {% endif %}

      {% if pg.tarif_deviant_coins %}
        <div class="mt-subcat scheide">
          ∘ {{ ui_get('label.tarif_deviant') }}
          <span class="sc-desc">{{ ui_get('tarif_deviant.desc') }}</span>
        </div>
        {{ coin_table(pg.tarif_deviant_coins) }}
      {% endif %}

      {% if pg.tarif_subunit_coins %}
        <div class="mt-subcat kurant">
          ∘ {{ ui_get('label.tarif_subunit') }}
          <span class="sc-desc">{{ ui_get('tarif_subunit.desc') }}</span>
        </div>
        {{ coin_table(pg.tarif_subunit_coins) }}
      {% endif %}

      {% if pg.scheide_coins %}
        <div class="mt-subcat scheide">
          ∘ {{ ui_get('label.scheide') }}
          <span class="sc-desc">{{ ui_get('scheide.desc') }}</span>
        </div>
        {{ coin_table(pg.scheide_coins) }}
      {% endif %}

      {% if pg.copper_coins %}
        <div class="mt-subcat copper">
          ∘ {{ ui_get('label.copper') }}
          <span class="sc-desc">{{ ui_get('copper.desc') }}</span>
        </div>
        {{ coin_table_copper(pg.copper_coins) }}
      {% endif %}

      {% if pg.gedenk_coins %}
        <div class="mt-subcat kurant">✦ {{ ui_get('label.gedenk') }}</div>
        {{ coin_table(pg.gedenk_coins) }}
      {% endif %}
    </div>
    {% endfor %}

    <div class="fd-foot">
      <button type="button" class="fd-close">
        <span class="fd-close-icon">▴</span>
        <span class="fd-close-label">{{ ui_get('fuss.hide_details') }}</span>
      </button>
    </div>
  </div>
</details>
{% endif %}

{% if sp and sp.closing %}
<div class="terr">
  {% if sp.closing_label %}<span class="tlb">{{ sp.closing_label|t(lang) }}</span>{% endif %}
  {{ sp.closing|t(lang)|safe }}
</div>
{% endif %}
</section>

{% endif %}
{% endfor %}

{% if tree.location.methodology %}
<hr class="rsep">
<h2 class="refs-title" id="methodik">{{ (tree.location.methodology_heading|t(lang)) if tree.location.methodology_heading else 'Methodische Anmerkungen' }}</h2>
<div class="methodology">{{ tree.location.methodology|t(lang)|safe }}</div>
{% endif %}

{% if references and references.entries %}
<hr class="rsep">
<h2 class="refs-title">{{ references.heading }}</h2>
<ol class="refs">
  {# value="N" overrides the auto-counter so the visible item number matches the
     ref ID and the inline [N] citations even if a future edit drops some entries
     and leaves gaps in the numbering. Currently 1..23 are sequential, but this
     guards against silent renumbering on future cleanups. #}
  {% for entry in references.entries %}
  <li id="{{ entry.id }}" value="{{ entry.id|replace('ref', '') }}">{{ entry.content | safe }}</li>
  {% endfor %}
</ol>
{% endif %}

<footer>
  <span class="ftr-l">{{ ui_get('meta.generated') }}: {{ fmt_date(generated_date) }}{% if repo_url %} · <a href="{{ repo_url }}">{{ ui_get('meta.source_data') }}</a>{% endif %}</span>
  <span class="ftr-r">Müntzfüße · CC-BY-SA</span>
</footer>

</body>
</html>
