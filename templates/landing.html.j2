<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ ui_get('landing.title') }}</title>
<link rel="stylesheet" href="{{ base_url }}/assets/style.css">
<script src="{{ base_url }}/assets/app.js" defer></script>
<script>(function(){var t='v3';try{var s=localStorage.getItem('mz-theme');if(s==='v1'||s==='v2'||s==='v3')t=s;}catch(e){}document.documentElement.dataset.theme=t;})();</script>
</head>
<body>

<nav class="nav">
  <strong>{{ ui_get('nav.home') }}</strong>
  <div class="switchers">
    <div class="theme-switch" role="group" aria-label="Theme">
      <button type="button" class="th th-v1" data-theme="v1" title="Museum Atlas — paper &amp; gold" aria-label="Museum Atlas">
        <span class="th-swatch" aria-hidden="true"><i class="sw sw-1"></i><i class="sw sw-2"></i><i class="sw sw-3"></i></span>
        <span class="th-label">Atlas</span>
      </button>
      <button type="button" class="th th-v2" data-theme="v2" title="Editorial Codex — ink &amp; vermilion" aria-label="Editorial Codex">
        <span class="th-swatch" aria-hidden="true"><i class="sw sw-1"></i><i class="sw sw-2"></i><i class="sw sw-3"></i></span>
        <span class="th-label">Codex</span>
      </button>
      <button type="button" class="th th-v3 active" data-theme="v3" title="Refined Dark — graphite &amp; gold" aria-label="Refined Dark">
        <span class="th-swatch" aria-hidden="true"><i class="sw sw-1"></i><i class="sw sw-2"></i><i class="sw sw-3"></i></span>
        <span class="th-label">Noir</span>
      </button>
    </div>
    <div class="lang-switch">
      {% for l in languages -%}
        {%- if l == lang -%}
          <a class="active">{{ l|upper }}</a>
        {%- else -%}
          <a href="../{{ l }}/">{{ l|upper }}</a>
        {%- endif -%}
      {%- endfor %}
    </div>
  </div>
</nav>

<h1 class="h1">{{ ui_get('landing.title') }}</h1>
<p style="color: var(--text-secondary); font-size: 13px;">{{ ui_get('landing.subtitle') }}</p>

<h2 style="font-size: 13px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-top: 24px;">
  {{ ui_get('landing.select_location') }}
</h2>

<div class="loc-grid">
  {% for loc in locations %}
  <a class="loc-card" href="../../{{ loc.id }}/{{ lang }}/">
    <h3>{{ loc.name|t(lang) }}</h3>
    <p>{{ loc.summary|t(lang) }}</p>
  </a>
  {% endfor %}
</div>

{# --- German Müntzfüße overview ----------------------------------------
   A flat catalogue under data/shared/german_fuesse.yml — populated from
   the chat-generated v6 reference. Renders only when the YAML provides
   entries; gracefully degrades to a no-op when the file is absent or
   empty. Body content is German-primary with i18n.t fallback (see
   docs note at top of german_fuesse.yml). #}
{% if german_fuesse %}
<section class="gf-section">
  <p class="gf-subheading">{{ ui_get('landing.gf.subheading') }}</p>

  {# Each German Müntzfuß renders as a `<section class="gw">` — the same
     base-values component used on the per-location pages (see
     templates/location.html.j2 ~line 700). Reusing the .gw / .bx /
     .gw-rows / .gw-fr classes gives matching typography, spacing and
     theming across landing and location pages. Wrapper additions for
     this catalogue (.gf-years above the head, phase-header/summary
     dividers inside the body, .gw-fr-territories at the bottom) are the
     only landing-specific styles. #}
  {% for gf in german_fuesse %}
  {# Each entry wrapped in a .fuss-block — same component the per-location
     pages use for each Müntzfuß section (templates/location.html.j2:672).
     The .fuss-block + .fuss-block { margin-top: 56px } rule supplies the
     vertical spacing between entries. Inside, the .phase-header pattern:
     primary numeric form (gf.name) in .pname; period synonym(s) in
     gf.historical_name nested as <em class="phistorical">; gf.years_label
     in .pdate top-right. Subtitle becomes .psub directly below. #}
  <section class="fuss-block" id="gf-{{ gf.id }}">
  <div class="phase-header">
    <div class="ph-left">
      <span class="pname">{{ gf.name|t(lang) }}{% if gf.historical_name %}<em class="phistorical">{{ gf.historical_name|t(lang) }}</em>{% endif %}</span>
      {% if gf.subtitle %}<span class="psub">{{ gf.subtitle|t(lang)|safe }}</span>{% endif %}
    </div>
    <div class="ph-right">
      <span class="pdate">{{ gf.years_label|t(lang) }}</span>
    </div>
  </div>
  <section class="gw">
    <div class="gw-head">
      <div class="gw-head-text">
        <div class="gw-heading">{{ ui_get('landing.gf.gw_heading') }}</div>
      </div>
      <span class="bx {{ gf.metal }}">{{ ui_get('landing.gf.metal.' ~ gf.metal) }}</span>
    </div>
    <div class="gw-body">
      {% for block in gf.body %}
        {% if block.kind == 'rows' %}
          <div class="gw-rows">
            {% for row in block['items'] %}
            <div class="gw-row">
              <div class="gw-k">{{ row.key|t(lang) }}</div>
              <div class="gw-v">{{ row.value|t(lang)|safe }}</div>
            </div>
            {% endfor %}
          </div>
        {% elif block.kind == 'prose' %}
          <div class="gw-fr">
            <span class="gw-fr-label">{{ block.label|t(lang) }}</span>
            {{ block.content|t(lang)|safe }}
          </div>
        {% elif block.kind == 'phase_header' %}
          <div class="gf-phase-header">{{ block.title|t(lang) }}</div>
        {% elif block.kind == 'phase_summary' %}
          <div class="gf-phase-summary">{{ block.content|t(lang)|safe }}</div>
        {% endif %}
      {% endfor %}
    </div>
  </section>
  {% if gf.territories %}
  <div class="terr">
    <span class="tlb">{{ gf.territories.label|t(lang) }}</span>
    {{ gf.territories.content|t(lang)|safe }}
  </div>
  {% endif %}
  </section>
  {% endfor %}
</section>
{% endif %}

<footer>
  <span class="ftr-l">{{ ui_get('meta.generated') }}: {{ fmt_date(generated_date) }}{% if repo_url %} · <a href="{{ repo_url }}">{{ ui_get('meta.source_data') }}</a>{% endif %}{% if contact_email %} · <a href="mailto:{{ contact_email }}">{{ ui_get('meta.contact') }}</a>{% endif %}</span>
  <span class="ftr-r">Müntzfüße · CC-BY-SA</span>
</footer>

</body>
</html>
