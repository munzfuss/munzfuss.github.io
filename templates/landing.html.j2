<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ ui_get('landing.title') }}</title>
<link rel="stylesheet" href="{{ base_url }}/assets/style.css">
<script src="{{ base_url }}/assets/app.js" defer></script>
<script>(function(){var t='v3';try{var s=localStorage.getItem('mz-theme');if(s==='v1'||s==='v2'||s==='v3')t=s;}catch(e){}document.documentElement.dataset.theme=t;})();</script>
</head>
<body>

<nav class="nav">
  <strong>{{ ui_get('landing.title') }}</strong>
  <div class="switchers">
    <div class="theme-switch" role="group" aria-label="Theme">
      <button type="button" class="th th-v1" data-theme="v1" title="Museum Atlas — paper &amp; gold" aria-label="Museum Atlas">
        <span class="th-swatch" aria-hidden="true"><i class="sw sw-1"></i><i class="sw sw-2"></i><i class="sw sw-3"></i></span>
        <span class="th-label">Atlas</span>
      </button>
      <button type="button" class="th th-v2" data-theme="v2" title="Editorial Codex — ink &amp; vermilion" aria-label="Editorial Codex">
        <span class="th-swatch" aria-hidden="true"><i class="sw sw-1"></i><i class="sw sw-2"></i><i class="sw sw-3"></i></span>
        <span class="th-label">Codex</span>
      </button>
      <button type="button" class="th th-v3 active" data-theme="v3" title="Refined Dark — graphite &amp; gold" aria-label="Refined Dark">
        <span class="th-swatch" aria-hidden="true"><i class="sw sw-1"></i><i class="sw sw-2"></i><i class="sw sw-3"></i></span>
        <span class="th-label">Noir</span>
      </button>
    </div>
    <div class="lang-switch">
      {% for l in languages -%}
        {%- if l == lang -%}
          <a class="active">{{ l|upper }}</a>
        {%- else -%}
          <a href="../{{ l }}/">{{ l|upper }}</a>
        {%- endif -%}
      {%- endfor %}
    </div>
  </div>
</nav>

<h1 class="h1">{{ ui_get('landing.title') }}</h1>
<p style="color: var(--text-secondary); font-size: 13px;">{{ ui_get('landing.subtitle') }}</p>

<h2 style="font-size: 13px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-top: 24px;">
  {{ ui_get('landing.select_location') }}
</h2>

<div class="loc-grid">
  {% for loc in locations %}
  <a class="loc-card" href="../../{{ loc.id }}/{{ lang }}/">
    <h3>{{ loc.name|t(lang) }}</h3>
    <p>{{ loc.summary|t(lang) }}</p>
  </a>
  {% endfor %}
</div>

{# --- German Müntzfüße overview ----------------------------------------
   A flat catalogue under data/shared/german_fuesse.yml — populated from
   the chat-generated v6 reference. Renders only when the YAML provides
   entries; gracefully degrades to a no-op when the file is absent or
   empty. Body content is German-primary with i18n.t fallback (see
   docs note at top of german_fuesse.yml). #}
{% if german_fuesse %}
<section class="gf-section">
  <h2 class="gf-heading">{{ ui_get('landing.gf.heading') }}</h2>
  <p class="gf-subheading">{{ ui_get('landing.gf.subheading') }}</p>
  {% set _note = ui_get('landing.gf.lang_note') %}
  {% if _note %}
  <p class="gf-langnote">{{ _note }}</p>
  {% endif %}

  {% for gf in german_fuesse %}
  <article class="gf-card" id="gf-{{ gf.id }}">
    <p class="gf-years">{{ gf.years_label|t(lang) }}</p>
    <div class="gf-head">
      <div class="gf-head-text">
        <h3 class="gf-title">{{ gf.title|t(lang) }}</h3>
        <p class="gf-subtitle">{{ gf.subtitle|t(lang) }}</p>
      </div>
      <span class="gf-bx gf-bx-{{ gf.metal }}">{{ ui_get('landing.gf.metal.' ~ gf.metal) }}</span>
    </div>
    <div class="gf-body">
      {# Pair (rows, immediately-following prose) into a side-by-side
         .gf-row2 layout: rows on the left, prose on the right. Standalone
         rows or standalone prose render full-width. Phase-headers and
         phase-summaries always render full-width as separators. #}
      {% for block in gf.body %}
        {%- set _next = gf.body[loop.index] if loop.index < gf.body|length else none -%}
        {%- set _prev = gf.body[loop.index0 - 1] if loop.index0 > 0 else none -%}
        {% if block.kind == 'rows' %}
          {% if _next and _next.kind == 'prose' %}
          <div class="gf-row2">
            <div class="gf-tb">
              {% for row in block['items'] %}
              <div class="gf-tr">
                <div class="gf-tk">{{ row.key|t(lang) }}</div>
                <div class="gf-tv">{{ row.value|t(lang)|safe }}</div>
              </div>
              {% endfor %}
            </div>
            <div class="gf-fr">
              <span class="gf-fr-lb">{{ _next.label|t(lang) }}</span>
              {{ _next.content|t(lang)|safe }}
            </div>
          </div>
          {% else %}
          <div class="gf-tb">
            {% for row in block['items'] %}
            <div class="gf-tr">
              <div class="gf-tk">{{ row.key|t(lang) }}</div>
              <div class="gf-tv">{{ row.value|t(lang)|safe }}</div>
            </div>
            {% endfor %}
          </div>
          {% endif %}
        {% elif block.kind == 'prose' %}
          {# Skip if already rendered as the right-hand pair of a preceding rows block #}
          {% if not (_prev and _prev.kind == 'rows') %}
          <div class="gf-fr">
            <span class="gf-fr-lb">{{ block.label|t(lang) }}</span>
            {{ block.content|t(lang)|safe }}
          </div>
          {% endif %}
        {% elif block.kind == 'phase_header' %}
          <div class="gf-ph">{{ block.title|t(lang) }}</div>
        {% elif block.kind == 'phase_summary' %}
          <div class="gf-ps">{{ block.content|t(lang)|safe }}</div>
        {% endif %}
      {% endfor %}
    </div>
    {% if gf.territories %}
    <div class="gf-terr">
      <span class="gf-terr-lb">{{ gf.territories.label|t(lang) }}</span>
      {{ gf.territories.content|t(lang)|safe }}
    </div>
    {% endif %}
  </article>
  {% endfor %}
</section>
{% endif %}

<footer>
  <span class="ftr-l">{{ ui_get('meta.generated') }}: {{ fmt_date(generated_date) }}{% if repo_url %} · <a href="{{ repo_url }}">{{ ui_get('meta.source_data') }}</a>{% endif %}{% if contact_email %} · <a href="mailto:{{ contact_email }}">{{ ui_get('meta.contact') }}</a>{% endif %}</span>
  <span class="ftr-r">Müntzfüße · CC-BY-SA</span>
</footer>

</body>
</html>
