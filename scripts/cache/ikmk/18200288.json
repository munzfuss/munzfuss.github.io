ord_gnd_uri":"http:\/\/d-nb.info\/gnd\/4027833-5","keyword_concept_uri":"http:\/\/vocab.getty.edu\/tgn\/1000080"},{"ikmk_keyword_id":"64","keyword_de":"Medaillen","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4038206-0","keyword_concept_uri":"http:\/\/www.nomisma.org\/id\/medal"},{"ikmk_keyword_id":"65","keyword_de":"Medailleure","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4306105-9","keyword_concept_uri":"http:\/\/www.nomisma.org\/id\/medalist"},{"ikmk_keyword_id":"3","keyword_de":"Neuzeit","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4171678-4","keyword_concept_uri":""},{"ikmk_keyword_id":"43","keyword_de":"Portr\u00e4ts","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4006627-7","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300015637"},{"ikmk_keyword_id":"40","keyword_de":"Private als M\u00fcnzstand","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4134791-2","keyword_concept_uri":""}],"timeline_themes":[{"ikmk_timeline_id":"61","timeline_item":"Medaillen der Renaissance","description":"Die Kreation des Mediums Medaille ist eng mit dem diesseitsorientierten Wirken selbstbewusster Pers\u00f6nlichkeiten in der Renaissance verbunden. Sie entstand im 15. Jh. in Italien. Der als Frescomaler bekannte Antonio Pisano war ihr erster Meister. Er schuf seine zweiseitigen Medaillenreliefs seit den 1430er Jahren. Andere - zumeist Bildhauer oder Maler wie Pisano - folgten fast zeitgleich. Weiche Konturen und malerisch wirkende \u00dcberg\u00e4nge zwischen Relief und Grund sind der vorzugsweise gegossenen Medaille eigen. Ein halbes Jahrhundert nach ihrer ersten Bl\u00fcte in Oberitalien setzte sich diese Kunstform auch n\u00f6rdlich der Alpen durch. Sie ist das Werk von Holzschnitzern, Steinschneidern, Goldschmieden und Bildhauern, die sich besonders in S\u00fcddeutschland um Augsburg (Hans Schwarz) und N\u00fcrnberg (Matthes Gebel) auf die Medaille spezialisierten. Im Unterschied zu den italienischen Vorbildern f\u00e4llt hier eine technisch subtile Detailtreue mit isoliert auf den Grund gesetzten Bildnissilhouetten auf.","year_from":"1435","year_until":"1550","autor":"Steguweit, Wolfgang"}],"secondary_treatment":[{"ikmk_secondary_treatment_id":"1","item_de":"gelocht","item_en":"pierced","description_de":"Absichtlich angebrachtes Loch (oder mehrere) zur Befestigung an einem Geh\u00e4nge oder einer Unterlage. Im Falle von Papiergeld h\u00e4ufig Lochung zum Zeichen der Entwertung.","description_en":"Intentional hole(s) pierced through a coin so that it can be worn on a neclace, sewn onto textiles, etc. In case of paper money such a perforation often indicates devaluation.","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/secondary_treatment\/1","concept":["http:\/\/nomisma.org\/id\/pierced"]}],"text_right":{"short":"CC BY-SA 4.0","icon":"https:\/\/licensebuttons.net\/l\/by-sa\/4.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de","en":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en"},"label":{"de":"Creative Commons Namensnennung - Weitergabe unter gleichen Bedingungen 4.0 International","en":"Creative Commons Attribution-ShareAlike 4.0 International"},"string":{"de":"Texte und Beschreibungen in diesem Online-Katalog stehen unter einer\u00a0<a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de\" target=\"_blank\">CC BY-SA 4.0<\/a> Lizenz.","en":"Texts and descriptions of this catalogue are licensed <a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en\" target=\"_blank\">CC BY-SA 4.0<\/a>."}},"lod_right":{"short":"PDM 1.0","icon":"https:\/\/licensebuttons.net\/p\/zero\/1.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de","en":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en"},"label":{"de":"Public Domain Mark 1.0","en":"Public Domain Mark 1.0"},"string":{"de":"Verwendete LOD-Identifikatoren sind <a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de\" target=\"_blank\">Public Domain Mark 1.0<