52-4","https:\/\/viaf.org\/viaf\/147226967":"https:\/\/viaf.org\/viaf\/147226967","https:\/\/ikmk.smb.museum\/ndp\/corporation\/6886":"https:\/\/ikmk.smb.museum\/ndp\/corporation\/6886"}}}}},"keywords":[{"ikmk_keyword_id":"79","keyword_de":"18. Jh.","keyword_gnd_uri":"","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300404512"},{"ikmk_keyword_id":"18","keyword_de":"Deutschland","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4011882-4","keyword_concept_uri":"http:\/\/vocab.getty.edu\/tgn\/7000084"},{"ikmk_keyword_id":"42","keyword_de":"Ereignisse","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4160028-9","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300069084"},{"ikmk_keyword_id":"76","keyword_de":"Gegenst\u00e4nde","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4121320-8","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300311889"},{"ikmk_keyword_id":"70","keyword_de":"Gold","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4157819-3","keyword_concept_uri":"http:\/\/www.nomisma.org\/id\/av"},{"ikmk_keyword_id":"44","keyword_de":"Herrscherrepr\u00e4sentation","keyword_gnd_uri":"","keyword_concept_uri":""},{"ikmk_keyword_id":"33","keyword_de":"K\u00f6nige (MA&NZ)","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4031516-2","keyword_concept_uri":""},{"ikmk_keyword_id":"3","keyword_de":"Neuzeit","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4171678-4","keyword_concept_uri":""},{"ikmk_keyword_id":"34","keyword_de":"Weltliche F\u00fcrsten","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4166473-5","keyword_concept_uri":""}],"timeline_themes":[{"ikmk_timeline_id":"74","timeline_item":"Deutschland. Goldm\u00fcnzen 17. und 18. Jh.","description":"Parallel zum Silberkurantgeld nahm ab dem 18. Jh. der Umlauf von Goldm\u00fcnzen zu. Besonders die von Portugal aus Brasilien nach Europa verbrachten Goldmengen sorgten hier f\u00fcr ein stabiles Angebot des Edelmetalls. Gold diente der Abwicklung gr\u00f6\u00dferer Handelsgesch\u00e4fte, wie z. B. dem Pferdehandel, dem Erwerb von Luxusartikeln an den H\u00f6fen und dem Bau neuer Residenzen. Ebenso vergaben die F\u00fcrsten Geschenke und \u201ePr\u00e4mien\u201c gern als gepr\u00e4gtes Gold. Das hatte den Vorteil, dass neben einer gew\u00fcnschten Propagandafunktion der materielle Wert des St\u00fcckes erkennbar war. International verbreiteten sich besonders der franz\u00f6sische Louisdor, die spanische Pistole und der holl\u00e4ndische Dukat. Diese M\u00fcnzen wurden dank ihrer allseitigen Anerkennung und Beliebtheit von vielen deutschen Staaten nachgeahmt. Die Goldm\u00fcnzen geh\u00f6rten wie bestimmte Nominale des Silbergeldes zu den Welthandelsm\u00fcnzen.","year_from":"1601","year_until":"1800","autor":"Bannike, Elke"}],"text_right":{"short":"CC BY-SA 4.0","icon":"https:\/\/licensebuttons.net\/l\/by-sa\/4.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de","en":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en"},"label":{"de":"Creative Commons Namensnennung - Weitergabe unter gleichen Bedingungen 4.0 International","en":"Creative Commons Attribution-ShareAlike 4.0 International"},"string":{"de":"Texte und Beschreibungen in diesem Online-Katalog stehen unter einer\u00a0<a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de\" target=\"_blank\">CC BY-SA 4.0<\/a> Lizenz.","en":"Texts and descriptions of this catalogue are licensed <a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en\" target=\"_blank\">CC BY-SA 4.0<\/a>."}},"lod_right":{"short":"PDM 1.0","icon":"https:\/\/licensebuttons.net\/p\/zero\/1.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de","en":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en"},"label":{"de":"Public Domain Mark 1.0","en":"Public Domain Mark 1.0"},"string":{"de":"Verwendete LOD-Identifikatoren sind <a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de\" target=\"_blank\">Public Domain Mark 1.0<\/a>\u00a0lizenzie