0dfen hatte das Geb\u00e4ude zur Verf\u00fcgung gestellt. Der Lehrbetrieb wurde 1810 aufgenommen. Von 1828 bis 1946 trug die Universit\u00e4t den Namen Friedrich-Wilhelm-Universit\u00e4t, im Jahre 1949 erhielt sie ihren jetzigen Namen.","period":{"ikmk_period_id":"5","name_de":"Moderne seit 1900","name_en":"Modern period post 1900","description_de":"Die kunstgeschichtliche Epoche seit dem Jahr 1900.","description_en":"The modern period from 1900.","concept_id":"http:\/\/vocab.getty.edu\/aat\/300404514","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/period\/5"},"year_start":"1985","year_end":"1985","date_verbal":"1985","year_islam":"0","manufacturing":[{"ikmk_manufacturing_id":"21","manufacturing_name_de":"gepr\u00e4gt","manufacturing_name_en":"struck","nomisma_id":"http:\/\/nomisma.org\/id\/struck","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/manufacture\/21"}],"linked_persons_corporations":{"32":{"ikmk_type_id":"32","type_name_de":"Entwurf","type_name_en":"Design","type_nomisma_id":"","type_concept_id":"http:\/\/d-nb.info\/gnd\/4121208-3","ndp_id":"https:\/\/ikmk.smb.museum\/ndp\/type_for_person_and_corporation\/32","items":{"3806":{"ikmk_person_id":"3806","title_de":null,"first_name_de":"Joachim","last_name_de":"Rie\u00df","vitalDates":"23.06.1937 Chemnitz -","title_en":null,"first_name_en":"Joachim","last_name_en":"Rie\u00df","corporation":"0","lod":{"https:\/\/d-nb.info\/gnd\/1285770811":"https:\/\/d-nb.info\/gnd\/1285770811","https:\/\/viaf.org\/viaf\/5014168172581248620005":"https:\/\/viaf.org\/viaf\/5014168172581248620005","https:\/\/www.wikidata.org\/wiki\/Q1690405":"https:\/\/www.wikidata.org\/wiki\/Q1690405","https:\/\/ikmk.smb.museum\/ndp\/person\/3806":"https:\/\/ikmk.smb.museum\/ndp\/person\/3806"}},"3296":{"ikmk_person_id":"3296","title_de":null,"first_name_de":"Heinz","last_name_de":"Rodewald","vitalDates":"26.12.1932 - 15.02.1993","title_en":null,"first_name_en":"Heinz","last_name_en":"Rodewald","corporation":"0","lod":{"https:\/\/d-nb.info\/gnd\/141780088