fundament deponiert. Sixtus IV. wurde 1414 geboren als Francesco della Rovere und im Jahre 1471 zum Papst gew\u00e4hlt.","period":{"ikmk_period_id":"7","name_de":"Renaissance","name_en":"Renaissance","description_de":"Die Renaissance (Wiedergeburt) bezeichnet eine europ\u00e4ische Kunstperiode zwischen Mittelalter und Neuzeit im 15. und 16. Jahrhundert. Diese setzt im fr\u00fchen 15. Jahrhundert ein und wird um 1550 vom Barock abgel\u00f6st.","description_en":"The term Renaissance (rebirth) describes a period at the turn from the Middele Ages to the Modern period during the 15th and 16th century. It begins during the early 15th century and developes into the Baroque around 1550.","concept_id":"http:\/\/vocab.getty.edu\/aat\/300021140","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/period\/7"},"year_start":"1473","year_end":"1473","date_verbal":"1473","year_islam":"0","references":[{"ikmk_referenz_id":21,"souce":"B\u00f6rner, Italienische Medaillen","number":"0304","similar":"0"},{"ikmk_referenz_id":208,"souce":"Hill, Italian Medals","number":"0806b","similar":"0"}],"manufacturing":[{"ikmk_manufacturing_id":"22","manufacturing_name_de":"gegossen","manufacturing_name_en":"cast","nomisma_id":"http:\/\/nomisma.org\/id\/cast","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/manufacture\/22"}],"linked_persons_corporations":{"49":{"ikmk_type_id":"49","type_name_de":"Medailleur\/in","type_name_en":"Medalist","type_nomisma_id":"http:\/\/nomisma.org\/id\/medalist","type_concept_id":"http:\/\/d-nb.info\/gnd\/4306105-9","ndp_id":"https:\/\/ikmk.smb.museum\/ndp\/type_for_person_and_corporation\/49","items":{"3729":{"ikmk_person_id":"3729","title_de":null,"first_name_de":null,"last_name_de":"Lysipp der J\u00fcngere (Hermes Flavius de' Bonis)","vitalDates":"um 1450\/1455-nach 1526","title_en":null,"first_name_en":null,"last_name_en":"Lysipp the Younger (Hermes Flavius de' Bonis)","corporation":"0","lod":{"https:\/\/d-nb.info\/gnd\/122023153":"https:\/\/d-nb.info\/gnd\/122023153","https:\/\/