0e4ter erhielten auch Silberm\u00fcnzen (eigentlich Scudo d'argento\/Ducatone) in Italien diesen Namen (piastra).\r\nHier zu verwenden (nur) f\u00fcr diese Silbergepr\u00e4ge in Italien. Eine saubere Trennung zwischen den italienischen als Piastre bzw. Scudi bzw. Ducatones bezeichneten M\u00fcnzen ist ohne gesonderte Nominalangabe auf der M\u00fcnze nicht m\u00f6glich und wird in der Forschung sehr subjektiv gehandhabt.\r\n\r\nF\u00fcr osmanisch-t\u00fcrkische sowie \u00e4gyptische und andere Piaster siehe dort unter Piaster (Kuru\u015f) mit den jeweiligen W\u00e4hrungsk\u00fcrzel (OL) und (TL) im Falle des Osmanischen Reiches bzw. der Republik T\u00fcrkei.\r\n\r\nF\u00fcr den franz\u00f6sischen Piastre de Commerce siehe dort.\r\n\r\nLit.: F. Schr\u00f6tter, W\u00f6rterbuch der M\u00fcnzkunde (1930) 514.","info_en":"","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/denomination\/1028"},"patronage":"Anonymus","date_last":"2026-03-18 05:47:52","coin_status":[{"ikmk_coin_status_id":"45","coin_status_name_de":"Papsttum","coin_status_name_en":"Papacy","coin_status_nomisma_id":"http:\/\/nomisma.org\/id\/pope","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/class_status\/45"}],"mint":[{"ikmk_country_id":"25","country_ndp_url":"https:\/\/ikmk.smb.museum\/ndp\/country\/25","country_name_de":"Italien","country_name_en":"Italy","country_nomisma_id":"http:\/\/nomisma.org\/id\/italian_republic","country_geoname_id":"http:\/\/www.geonames.org\/3175395","ikmk_region_id":"266","region_ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/region\/266","region_name_de":"Latium","region_name_en":"Latium","region_nomisma_id":"http:\/\/nomisma.org\/id\/latium","region_geoname_id":"","ikmk_mint_id":"678","mint_ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/location\/678","mint_name":"Rom","mint_name_de":"Rom","mint_name_en":"Rome","mint_nomisma_id":"http:\/\/nomisma.org\/id\/rome","mint_geoname_id":"http:\/\/www.geonames.org\/3169070"}],"material":{"ikmk_material_id":"1","material_name_de":"Silber","material_name_