ri":"http:\/\/d-nb.info\/gnd\/4047194-9","keyword_concept_uri":""},{"ikmk_keyword_id":"18","keyword_de":"Deutschland","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4011882-4","keyword_concept_uri":"http:\/\/vocab.getty.edu\/tgn\/7000084"},{"ikmk_keyword_id":"33","keyword_de":"K\u00f6nige (MA&NZ)","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4031516-2","keyword_concept_uri":""},{"ikmk_keyword_id":"65","keyword_de":"Medailleure","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4306105-9","keyword_concept_uri":"http:\/\/www.nomisma.org\/id\/medalist"},{"ikmk_keyword_id":"62","keyword_de":"Modelle","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4039798-1","keyword_concept_uri":"http:\/\/nomisma.org\/id\/model"},{"ikmk_keyword_id":"3","keyword_de":"Neuzeit","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4171678-4","keyword_concept_uri":""},{"ikmk_keyword_id":"43","keyword_de":"Portr\u00e4ts","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4006627-7","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300015637"}],"timeline_themes":[{"ikmk_timeline_id":"65","timeline_item":"Medaillenmodelle des 19. Jhs. aus Wachs","description":"Leonhard Posch (1750-1831) war als Bildnismodelleur ein K\u00fcnstler von europ\u00e4ischem Rang. Ausgebildet in Salzburg und Wien, fand er fr\u00fch den f\u00fcr ihn typischen, k\u00fchl distanzierten und dennoch durch Lebensn\u00e4he bestimmten klassizistischen Silhouettenstil. An den Wirkungsst\u00e4tten Wien, Paris und Berlin schuf er eine Portr\u00e4tgalerie von mehr als 800 Zeitgenossen aus Adel und B\u00fcrgertum. Nach Modellierung in Wachs oder Gips und Zwischenmodellen in Blei wurden die G\u00fcsse in Eisen vervielf\u00e4ltigt.\r\nJohann Karl Fischer (1802-1865), Lehrer an der Akademie in Berlin, war als Pr\u00e4gemedailleur, Elfenbein- und Steinschneider t\u00e4tig. Seine in Wachs auf Schiefer modellierten Bildnisse und R\u00fcckseitendarstellungen zeugen von souver\u00e4nem K\u00f6nnen und Kenntnis klassizistischen Themen- und Formengutes. Sie sind die vergr\u00f6\u00dferten Vorstufen f\u00fcr den bereits mittels der Reduziertechnik nach Metallabg\u00fcssen vorgenommenen Stempelschnitt.","year_from":"1780","year_until":"1900","autor":"Steguweit, Wolfgang"}],"text_right":{"short":"CC BY-SA 4.0","icon":"https:\/\/licensebuttons.net\/l\/by-sa\/4.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de","en":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en"},"label":{"de":"Creative Commons Namensnennung - Weitergabe unter gleichen Bedingungen 4.0 International","en":"Creative Commons Attribution-ShareAlike 4.0 International"},"string":{"de":"Texte und Beschreibungen in diesem Online-Katalog stehen unter einer\u00a0<a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de\" target=\"_blank\">CC BY-SA 4.0<\/a> Lizenz.","en":"Texts and descriptions of this catalogue are licensed <a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en\" target=\"_blank\">CC BY-SA 4.0<\/a>."}},"lod_right":{"short":"PDM 1.0","icon":"https:\/\/licensebuttons.net\/p\/zero\/1.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de","en":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en"},"label":{"de":"Public Domain Mark 1.0","en":"Public Domain Mark 1.0"},"string":{"de":"Verwendete LOD-Identifikatoren sind <a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de\" target=\"_blank\">Public Domain Mark 1.0<\/a>\u00a0lizenziert.","en":"LOD ids used are licensed <a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en\" target=\"_blank\">Public Domain Mark 1.0<\/a>."}},"image_restriction_id":0,"image_restriction":"free","image_right":{"short":"PDM 1.0","icon":"https:\/\/licensebuttons.net\/p\/zero\/1.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de","en":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en"},"label":{"de":"Public Domain Ma