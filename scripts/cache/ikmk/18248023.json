hsischen Kurf\u00fcrsten sehr gesch\u00e4tzt.","period":{"ikmk_period_id":"9","name_de":"Klassizismus","name_en":"Classicism","description_de":"Die kunstgeschichtliche Epoche zwischen ungef\u00e4hr 1770 und 1840.","description_en":"The art period between c. 1770 and 1840.","concept_id":"http:\/\/vocab.getty.edu\/aat\/300056513","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/period\/9"},"year_start":"1801","year_end":"1801","date_verbal":"1801","year_islam":"0","manufacturing":[{"ikmk_manufacturing_id":"21","manufacturing_name_de":"gepr\u00e4gt","manufacturing_name_en":"struck","nomisma_id":"http:\/\/nomisma.org\/id\/struck","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/manufacture\/21"}],"linked_persons_corporations":{"49":{"ikmk_type_id":"49","type_name_de":"Medailleur\/in","type_name_en":"Medalist","type_nomisma_id":"http:\/\/nomisma.org\/id\/medalist","type_concept_id":"http:\/\/d-nb.info\/gnd\/4306105-9","ndp_id":"https:\/\/ikmk.smb.museum\/ndp\/type_for_person_and_corporation\/49","items":{"4003":{"ikmk_person_id":"4003","title_de":null,"first_name_de":"Karl Reinhard","last_name_de":"Kr\u00fcger","vitalDates":"20.03.1794 - 20.02.1879","title_en":null,"first_name_en":"Karl Reinhard","last_name_en":"Kr\u00fcger","corporation":"0","lod":{"https:\/\/d-nb.info\/gnd\/116563346":"https:\/\/d-nb.info\/gnd\/116563346","https:\/\/viaf.org\/viaf\/10600649":"https:\/\/viaf.org\/viaf\/10600649","https:\/\/ikmk.smb.museum\/ndp\/person\/4003":"https:\/\/ikmk.smb.museum\/ndp\/person\/4003"}}}},"50":{"ikmk_type_id":"50","type_name_de":"Vorbesitzer","type_name_en":"previous Owner","type_nomisma_id":"","type_concept_id":"http:\/\/d-nb.info\/gnd\/4447273-0","ndp_id":"https:\/\/ikmk.smb.museum\/ndp\/type_for_person_and_corporation\/50","items":{"2163":{"ikmk_person_id":"2163","title_de":"Prof. Dr.","first_name_de":"Karl Asmund","last_name_de":"Rudolphi","vitalDates":"14.06.1771 - 29.11.1832","title_en":null,"first_name_en":"Karl Asmund","last_name_en":"Rudolphi","corporation":"0","lod":{"