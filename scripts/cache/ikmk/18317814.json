00e4gt 1252-1533) orientierten Goldm\u00fcnze. Anders als diese nicht mehr mit den Motiven Lilie\/Johannes der T\u00e4ufer und mit schrittweise geringerem Gewicht von schlie\u00dflich nur noch 3,2 Gramm und einem auf 18 Karat (750\/000) gesunkenen Feingehalt. F\u00fcr fr\u00fche, dem Florentiner Vorbild eng verpflichtete Goldgulden mi \u00dcbernahme des Motivs Lilie\/Johannes der T\u00e4ufer siehe auch Floren (Goldgulden).","info_en":"","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/denomination\/856"},"date_last":"2025-04-04 07:27:47","coin_status":[{"ikmk_coin_status_id":"41","coin_status_name_de":"Kurf\u00fcrstentum","coin_status_name_en":"Electorate","coin_status_nomisma_id":""}],"mint":[{"ikmk_country_id":"19","country_ndp_url":"https:\/\/ikmk.smb.museum\/ndp\/country\/19","country_name_de":"Deutschland","country_name_en":"Germany","country_nomisma_id":"http:\/\/nomisma.org\/id\/bundesrepublik_deutschland","country_geoname_id":"http:\/\/www.geonames.org\/2921044","ikmk_region_id":"93","region_ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/region\/93","region_name":"Sachsen","region_nomisma_id":"","region_geoname_id":"http:\/\/www.geonames.org\/2842566","ikmk_mint_id":"207","mint_ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/location\/207","mint_name":"Leipzig","mint_name_de":"Leipzig","mint_name_en":null,"mint_nomisma_id":"http:\/\/nomisma.org\/id\/leipzig","mint_geoname_id":"http:\/\/www.geonames.org\/6548737"}],"material":{"ikmk_material_id":"3","material_name_de":"Gold","material_name_en":"Gold","material_nomisma_id":"http:\/\/nomisma.org\/id\/av","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/material\/3"},"diameter":"23 mm","die_axis":"9 h","weight":"3.29 g","accession":"1844\/258-1 (MA Inv.)","access_year":"1844","access_type":{"ikmk_access_type_id":"1","access_type_name":"Kauf","access_type_nomisma_id":"","access_type_concept_id":"http:\/\/d-nb.info\/gnd\/4128692-3","ndp_uir":"https:\/\/ikmk.smb.museum\/ndp\/accession\/1"},"provenienz_extern":"","acquisition_date":"07.05