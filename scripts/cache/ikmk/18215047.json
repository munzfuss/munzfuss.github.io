_de":"Autorit\u00e4t","type_name_en":"Authority","type_nomisma_id":"http:\/\/nomisma.org\/id\/authority","type_concept_id":"http:\/\/d-nb.info\/gnd\/1051614252","ndp_id":"https:\/\/ikmk.smb.museum\/ndp\/type_for_person_and_corporation\/57","items":{"693":{"ikmk_person_id":"693","title_de":null,"first_name_de":null,"last_name_de":"Friedrich Wilhelm II. (1786-1797), K\u00f6nig von Preu\u00dfen","vitalDates":"25.09.1744 - 16.11.1797","title_en":null,"first_name_en":null,"last_name_en":"Friedrich Wilhelm II (1786-1797), king of Prussia","corporation":"0","lod":{"http:\/\/nomisma.org\/id\/frederick_william_ii_of_prussia":"http:\/\/nomisma.org\/id\/frederick_william_ii_of_prussia","https:\/\/d-nb.info\/gnd\/11869362X":"https:\/\/d-nb.info\/gnd\/11869362X","https:\/\/en.wikipedia.org\/wiki\/Frederick_William_II_of_Prussia":"https:\/\/en.wikipedia.org\/wiki\/Frederick_William_II_of_Prussia","https:\/\/viaf.org\/viaf\/59878495":"https:\/\/viaf.org\/viaf\/59878495","https:\/\/www.britishmuseum.org\/collection\/term\/BIOG69889":"https:\/\/www.britishmuseum.org\/collection\/term\/BIOG69889","https:\/\/www.wikidata.org\/wiki\/Q152229":"https:\/\/www.wikidata.org\/wiki\/Q152229","https:\/\/ikmk.smb.museum\/ndp\/person\/693":"https:\/\/ikmk.smb.museum\/ndp\/person\/693"}}}}},"keywords":[{"ikmk_keyword_id":"79","keyword_de":"18. Jh.","keyword_gnd_uri":"","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300404512"},{"ikmk_keyword_id":"16","keyword_de":"Berlin","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4005728-8","keyword_concept_uri":"http:\/\/www.nomisma.org\/id\/berlin"},{"ikmk_keyword_id":"17","keyword_de":"Brandenburg-Preussen (-1918)","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4047194-9","keyword_concept_uri":""},{"ikmk_keyword_id":"18","keyword_de":"Deutschland","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4011882-4","keyword_concept_uri":"http:\/\/vocab.getty.edu\/tgn\/7000084"},{"ikmk_keyword_id":"70","keyword_de":"Gold","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4157819-3","keyword_concept_uri":"http:\/\/www.nomisma.org\/id\/av"},{"ikmk_keyword_id":"80","keyword_de":"Heraldik und Wappen","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4072428-1","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300077808"},{"ikmk_keyword_id":"33","keyword_de":"K\u00f6nige (MA&NZ)","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4031516-2","keyword_concept_uri":""},{"ikmk_keyword_id":"3","keyword_de":"Neuzeit","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4171678-4","keyword_concept_uri":""}],"timeline_themes":[{"ikmk_timeline_id":"140","timeline_item":"Goldm\u00fcnzen in Brandenburg-Preu\u00dfen","description":"Goldgulden und Dukaten waren beide urspr\u00fcnglich M\u00fcnzen aus Feingold im Gewicht von 3,5 Gramm. Seit dem 15. Jh. galt dieser Standard nur noch f\u00fcr den Dukaten, w\u00e4hrend der Goldgulden etwas leichter war und geringeren Goldgehalt besa\u00df. Die ersten Goldgulden sind in Kurbrandenburg um 1510, die ersten Dukaten 1560\/66 gem\u00fcnzt worden. Auf Grund ihres hohen Wertes sind beide Sorten gerne zur f\u00fcrstlichen Repr\u00e4sentation genutzt worden. Eine Besonderheit stellen die aus dem Gold der brandenburgischen Kolonie Neu-Guinea 1682-1696 gem\u00fcnzten Guinea-Dukaten dar. Regelm\u00e4\u00dfig, d.h. j\u00e4hrlich, sind Dukaten nur unter K\u00f6nig Friedrich Wilhelm I. (1713-1740) ausgegeben worden. Dem Soldatenk\u00f6nig wird auch mit dem 1738 eingef\u00fchrten Wilhelmsdor (10 Taler) die werth\u00f6chste deutsche Goldm\u00fcnze verdankt. Mit der M\u00fcnzreform Friedrichs des Gro\u00dfen 1750 wurde als neue Standardgoldm\u00fcnze der Friedrichsd\u2019or eingef\u00fchrt.","year_from":"1510","year_until":"1870","autor":"Kluge, Bernd"},{"ikmk_timeline_id":"74","timeline_item":"Deutschland. Goldm\u00fcnzen 17. und 18. Jh.","description":"Parallel zum Silberkurantgeld nahm ab dem 18. Jh. der Umlauf von Goldm\u00fcnzen zu. Besonders die von Portugal aus Brasilien nach Europa verbrachten Goldmengen sorgten hier f\u00fcr ein stabiles Angebot des Edelmetalls. Gold diente der Abwicklung gr\u00f6\u00dferer Handelsgesch\u00e4fte, wie z. B. dem Pferdehandel, dem Erwerb von Luxusartikeln an den H\u00f6fen und dem Bau neuer Residenzen. Ebenso vergaben die F\u00fcrsten Geschenke und \u201ePr\u00e4mien\u201c gern als gepr\u00e4gtes Gold. Das hatte den Vorteil, dass neben einer gew\u00fcnschten Propagandafunktion der materielle Wert des St\u00fcckes erkennbar war. International verbreiteten sich besonders der franz\u00f6sische Louisdor, die spanische Pistole und der holl\u00e4ndische Dukat. Diese M\u00fcnzen wurden dank ihrer allseitigen Anerkennung und Beliebtheit von vielen deutschen Staaten nachgeahmt. Die Goldm\u00fcnzen geh\u00f6rten wie bestimmte Nominale des Silbergeldes zu den Welthandelsm\u00fcnzen.","year_from":"1601","year_until":"1800","autor":"Bannike, Elke"}],"text_right":{"short":"CC BY-SA 4.0","icon":"https:\/\/licensebuttons.net\/l\/by-sa\/4.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de","en":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en"},"label":{"de":"Creative Commons Namensnennung - Weitergabe unter gleichen Bedingungen 4.0 International","en":"Creative Commons Attribution-ShareAlike 4.0 International"},"string":{"de":"Texte und Beschreibungen in diesem Online-Katalog stehen unter einer\u00a0<a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de\" target=\"_blank\">CC BY-SA 4.0<\/a> Lizenz.","en":"Texts and descriptions of this catalogue are licensed <a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en\" target=\"_blank\">CC BY-SA 4.0<\/a>."}},"lod_right":{"short":"PDM 1.0","icon":"https:\/\/licensebuttons.net\/p\/zero\/1.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de","en":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en"},"label":{"de":"Public Domain Mark 1.0","en":"Public Domain Mark 1.0"},"string":{"de":"Verwendete LOD-Identifi