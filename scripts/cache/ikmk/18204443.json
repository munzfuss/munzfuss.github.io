issance (rebirth) describes a period at the turn from the Middele Ages to the Modern period during the 15th and 16th century. It begins during the early 15th century and developes into the Baroque around 1550.","concept_id":"http:\/\/vocab.getty.edu\/aat\/300021140","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/period\/7"},"year_start":"1506","year_end":"1506","date_verbal":"1506","year_islam":"0","manufacturing":[{"ikmk_manufacturing_id":"21","manufacturing_name_de":"gepr\u00e4gt","manufacturing_name_en":"struck","nomisma_id":"http:\/\/nomisma.org\/id\/struck","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/manufacture\/21"}],"linked_persons_corporations":{"54":{"ikmk_type_id":"54","type_name_de":"Dargestellte\/r","type_name_en":"Sitter","type_nomisma_id":"http:\/\/nomisma.org\/id\/portrait","type_concept_id":"http:\/\/vocab.getty.edu\/aat\/300189844","ndp_id":"https:\/\/ikmk.smb.museum\/ndp\/type_for_person_and_corporation\/54","items":{"1176":{"ikmk_person_id":"1176","title_de":null,"first_name_de":null,"last_name_de":"Maximilian I. (1477-1519), seit 1493 deutscher K\u00f6nig, 1508 Kaiser","vitalDates":"22.03.1459 - 12.01.1519","title_en":null,"first_name_en":null,"last_name_en":"Maximilian I (1477-1519), from 1493 king of the Germans, 1508 emperor","corporation":"0","lod":{"https:\/\/d-nb.info\/gnd\/118579371":"https:\/\/d-nb.info\/gnd\/118579371","https:\/\/de.wikipedia.org\/wiki\/Maximilian_I._(HRR)":"https:\/\/de.wikipedia.org\/wiki\/Maximilian_I._(HRR)","https:\/\/en.wikipedia.org\/wiki\/Maximilian_I,_Holy_Roman_Emperor":"https:\/\/en.wikipedia.org\/wiki\/Maximilian_I,_Holy_Roman_Emperor","https:\/\/nomisma.org\/id\/maximilian_i_hre":"https:\/\/nomisma.org\/id\/maximilian_i_hre","https:\/\/viaf.org\/viaf\/293727145":"https:\/\/viaf.org\/viaf\/293727145","https:\/\/www.britishmuseum.org\/collection\/term\/BIOG37808":"https:\/\/www.britishmuseum.org\/collection\/term\/BIOG37808","https:\/\/www.wikidata.org\/wiki\/Q150726":"https:\/\/www.wikidata.org\/wiki\/Q150726","h