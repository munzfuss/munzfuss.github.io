\/vocab.getty.edu\/aat\/300021147","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/period\/13"},"year_start":"1727","year_end":"1727","date_verbal":"1727","year_islam":"0","manufacturing":[{"ikmk_manufacturing_id":"21","manufacturing_name_de":"gepr\u00e4gt","manufacturing_name_en":"struck","nomisma_id":"http:\/\/nomisma.org\/id\/struck","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/manufacture\/21"}],"linked_persons_corporations":{"49":{"ikmk_type_id":"49","type_name_de":"Medailleur\/in","type_name_en":"Medalist","type_nomisma_id":"http:\/\/nomisma.org\/id\/medalist","type_concept_id":"http:\/\/d-nb.info\/gnd\/4306105-9","ndp_id":"https:\/\/ikmk.smb.museum\/ndp\/type_for_person_and_corporation\/49","items":{"3014":{"ikmk_person_id":"3014","title_de":null,"first_name_de":"Christian","last_name_de":"Wermuth","vitalDates":"16.12.1661 - 03.12.1739","title_en":null,"first_name_en":"Christian","last_name_en":"Wermuth","corporation":"0","lod":{"https:\/\/d-nb.info\/gnd\/119098245":"https:\/\/d-nb.info\/gnd\/119098245","https:\/\/de.wikipedia.org\/wiki\/Christian_Wermuth":"https:\/\/de.wikipedia.org\/wiki\/Christian_Wermuth","https:\/\/mmlo.de\/10300":"https:\/\/mmlo.de\/10300","https:\/\/viaf.org\/viaf\/72196797":"https:\/\/viaf.org\/viaf\/72196797","https:\/\/www.britishmuseum.org\/collection\/term\/BIOG117377":"https:\/\/www.britishmuseum.org\/collection\/term\/BIOG117377","https:\/\/www.wikidata.org\/wiki\/Q98886":"https:\/\/www.wikidata.org\/wiki\/Q98886","https:\/\/ikmk.smb.museum\/ndp\/person\/3014":"https:\/\/ikmk.smb.museum\/ndp\/person\/3014"}}}},"54":{"ikmk_type_id":"54","type_name_de":"Dargestellte\/r","type_name_en":"Sitter","type_nomisma_id":"http:\/\/nomisma.org\/id\/portrait","type_concept_id":"http:\/\/vocab.getty.edu\/aat\/300189844","ndp_id":"https:\/\/ikmk.smb.museum\/ndp\/type_for_person_and_corporation\/54","items":{"2047":{"ikmk_person_id":"2047","title_de":null,"first_name_de":"August Hermann","last_name_de":"Francke","vitalDates":"22.03.1663 - 08.06.1727","