046","https:\/\/www.britishmuseum.org\/collection\/term\/BIOG114390":"https:\/\/www.britishmuseum.org\/collection\/term\/BIOG114390","https:\/\/ikmk.smb.museum\/ndp\/corporation\/5560":"https:\/\/ikmk.smb.museum\/ndp\/corporation\/5560"}}}}},"keywords":[{"ikmk_keyword_id":"79","keyword_de":"18. Jh.","keyword_gnd_uri":"","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300404512"},{"ikmk_keyword_id":"72","keyword_de":"Andere Metalle und Legierungen","keyword_gnd_uri":"","keyword_concept_uri":""},{"ikmk_keyword_id":"18","keyword_de":"Deutschland","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4011882-4","keyword_concept_uri":"http:\/\/vocab.getty.edu\/tgn\/7000084"},{"ikmk_keyword_id":"42","keyword_de":"Ereignisse","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4160028-9","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300069084"},{"ikmk_keyword_id":"64","keyword_de":"Medaillen","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4038206-0","keyword_concept_uri":"http:\/\/www.nomisma.org\/id\/medal"},{"ikmk_keyword_id":"65","keyword_de":"Medailleure","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4306105-9","keyword_concept_uri":"http:\/\/www.nomisma.org\/id\/medalist"},{"ikmk_keyword_id":"3","keyword_de":"Neuzeit","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4171678-4","keyword_concept_uri":""},{"ikmk_keyword_id":"52","keyword_de":"Pflanzen","keyword_gnd_uri":"","keyword_concept_uri":""},{"ikmk_keyword_id":"43","keyword_de":"Portr\u00e4ts","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4006627-7","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300015637"},{"ikmk_keyword_id":"34","keyword_de":"Weltliche F\u00fcrsten","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4166473-5","keyword_concept_uri":""}],"timeline_themes":[{"ikmk_timeline_id":"62","timeline_item":"Medaillen Barock","description":"Die Barockmedaille diente der f\u00fcrstlichen Repr\u00e4sentation. In mythologischen Szenen, mit Personifikationen und Allegorien wurden dynastische Themen von der Geburt bis zum Tod \u00fcber Thronbesteigung, Huldigung, Verm\u00e4hlung, Bauleistungen, Kriege und Friedensschl\u00fcsse zu einer \u201eHistoire m\u00e9tallique\u201c geformt. Frankreich war tonangebend. Durch die Zentralgewalt gef\u00f6rdert, konzentrierte sich das Medaillenschaffen in Paris um den k\u00f6niglichen Hof. In den kaiserlichen Residenzen Wien und Prag gedieh es besonders unter Rudolf II. (1576-1612). Tr\u00e4ger der deutschen Barockmedaille waren die Landesf\u00fcrsten, die dem franz\u00f6sischen Vorbild mit glanzvoller Hofhaltung nachzueifern suchten. Wirtschaftlich prosperierende St\u00e4dte nutzten das Medium ebenfalls. Eine bereits in der Sp\u00e4trenaissance einsetzende Sonderform bilden kostbar gefasste Medaillenkleinode, die weltliche und geistliche Herrscher als besonderen Gunst- und Gnadenbeweis vergaben.","year_from":"1600","year_until":"1750","autor":"Steguweit, Wolfgang"}],"text_right":{"short":"CC BY-SA 4.0","icon":"https:\/\/licensebuttons.net\/l\/by-sa\/4.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de","en":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en"},"label":{"de":"Creative Commons Namensnennung - Weitergabe unter gleichen Bedingungen 4.0 International","en":"Creative Commons Attribution-ShareAlike 4.0 International"},"string":{"de":"Texte und Beschreibungen in diesem Online-Katalog stehen unter einer\u00a0<a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de\" target=\"_blank\">CC BY-SA 4.0<\/a> Lizenz.","en":"Texts and descriptions of this catalogue are licensed <a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en\" target=\"_blank\">CC BY-SA 4.0<\/a>."}},"lod_right":{"short":"PDM 1.0","icon":"https:\/\/licensebuttons.net\/p\/zero\/1.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de","en":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en"},"label":{"de":"Public Domain Mark 1.0","en":"Public Domain Mark 1.