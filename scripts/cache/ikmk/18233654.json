pedia.org\/wiki\/Otto_I._(HRR)":"https:\/\/de.wikipedia.org\/wiki\/Otto_I._(HRR)","https:\/\/en.wikipedia.org\/wiki\/Otto_I,_Holy_Roman_Emperor":"https:\/\/en.wikipedia.org\/wiki\/Otto_I,_Holy_Roman_Emperor","https:\/\/viaf.org\/viaf\/267323947":"https:\/\/viaf.org\/viaf\/267323947","https:\/\/www.britishmuseum.org\/collection\/term\/BIOG75955":"https:\/\/www.britishmuseum.org\/collection\/term\/BIOG75955","https:\/\/www.wikidata.org\/wiki\/Q43915":"https:\/\/www.wikidata.org\/wiki\/Q43915","https:\/\/ikmk.smb.museum\/ndp\/person\/1246":"https:\/\/ikmk.smb.museum\/ndp\/person\/1246"}}}},"57":{"ikmk_type_id":"57","type_name_de":"Autorit\u00e4t","type_name_en":"Authority","type_nomisma_id":"http:\/\/nomisma.org\/id\/authority","type_concept_id":"http:\/\/d-nb.info\/gnd\/1051614252","ndp_id":"https:\/\/ikmk.smb.museum\/ndp\/type_for_person_and_corporation\/57","items":{"1473":{"ikmk_person_id":"1473","title_de":null,"first_name_de":null,"last_name_de":"Uto III. (950-965), Bischof von Stra\u00dfburg","vitalDates":"-965","title_en":null,"first_name_en":null,"last_name_en":"Uto III (950-965), bishop of Strasbourg","corporation":"0","lod":{"https:\/\/d-nb.info\/gnd\/115795634":"https:\/\/d-nb.info\/gnd\/115795634","https:\/\/viaf.org\/viaf\/15506431":"https:\/\/viaf.org\/viaf\/15506431","https:\/\/ikmk.smb.museum\/ndp\/person\/1473":"https:\/\/ikmk.smb.museum\/ndp\/person\/1473"}}}}},"keywords":[{"ikmk_keyword_id":"53","keyword_de":"Architektur","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4002851-3","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300263552"},{"ikmk_keyword_id":"37","keyword_de":"Geistliche F\u00fcrsten","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4156371-2","keyword_concept_uri":"https:\/\/nomisma.org\/id\/clergy"},{"ikmk_keyword_id":"9","keyword_de":"Hochmittelalter, 10.-12. Jh.","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/7503822-5","keyword_concept_uri":""},{"ikmk_keyword_id":"33","keyword_de":"K\u00f6nige (MA&NZ)","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4031516-2","keyword_concept_uri":""},{"ikmk_keyword_id":"2","keyword_de":"Mittelalter","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4129108-6","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300020756"},{"ikmk_keyword_id":"43","keyword_de":"Portr\u00e4ts","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4006627-7","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300015637"},{"ikmk_keyword_id":"69","keyword_de":"Silber","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4133759-1","keyword_concept_uri":"http:\/\/www.nomisma.org\/id\/ar"},{"ikmk_keyword_id":"19","keyword_de":"Westeuropa (ohne D)","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4079215-8","keyword_concept_uri":"http:\/\/vocab.getty.edu\/tgn\/4003761"}],"timeline_themes":[{"ikmk_timeline_id":"94","timeline_item":"Deutschland im Hochmittelalter","description":"Das ostfr\u00e4nkisch-deutsche Reich war um 900 rechtsrheinisch eine Region ohne eigene M\u00fcnzpr\u00e4gung. Mit dem politischen Aufschwung unter den Ottonen (919-1024) und Saliern (1024-1125) verschob sich nicht nur die Grenze der M\u00fcnzgeldwirtschaft innerhalb weniger Jahrzehnte vom Rhein an die Elbe, sondern wurde das Reich der Ottonen und Salier zum Hauptm\u00fcnzproduzent in Europa. An der M\u00fcnzpr\u00e4gung wurde vom K\u00f6nigtum durch gezielte Privilegien die Reichskirche beteiligt. Neben den Emissionen, die sich durch Namensnennung K\u00f6nig, Geistlichkeit oder weltlichem Adel zuweisen lassen, spielen anonyme Emissionen eine gro\u00dfe Rolle, vor allem im Osten. Die aus Silber gepr\u00e4gten Denare (Pfennige) sahen \u00fcberall anders aus, so dass sich mehr als 3000 verschiedene M\u00fcnztypen feststellen lassen. An der Pr\u00e4gung waren ca. 160-180 M\u00fcnzst\u00e4tten beteiligt, davon etwa 25-30 kontinuierlich und mit gr\u00f6\u00dferem Produktionsvolumen.","year_from":"911","year_until":"1200","autor":"Kluge, Bernd"},{"ikmk_timeline_id":"122","timeline_item":"Deutsche K\u00f6nige und Kaiser des Mittelalters","description":"Nach dem Aussterben der ostfr\u00e4nkischen Karolinger ging die K\u00f6nigsw\u00fcrde durch die Wahl der F\u00fcrsten zun\u00e4chst an Konrad I. (911-918), Herzog von Franken, nach dessen Tod an den s\u00e4chsischen Herzog Heinrich I. (919-936) \u00fcber. Mit Heinrich I. beginnt \u00fcblicherweise die Z\u00e4hlung der deutschen K\u00f6nige. Heinrichs Sohn Otto I. (936-973) wurde 962 durch den Papst in Rom zum Kaiser gekr\u00f6nt. Seither haben fast alle deutschen K\u00f6nige des Mittelalters auch die Kaiserkrone getragen. Dazu war die Kr\u00f6nung durch den Papst in Rom erforderlich. Alle K\u00f6nige wurden durch Wahl der F\u00fcrsten bestimmt, auch wenn meist der Sohn auf den Vater folgte (Gebl\u00fctsrecht). Erst bei Aussterben einer Dynastie wurde das Wahlrecht der F\u00fcrsten voll wirksam. Seit 1356 (Goldene Bulle) ist die K\u00f6nigswahl Sache der  sieben Kurf\u00fcrsten des Reiches. Die bedeutendsten K\u00f6nigsdynastien waren die Ottonen (Liudolfinger, 919-1024), die Salier (1024-1125), die Staufer (1138-1250), die Luxemburger (1308-1313, 1346-1437) und die Habsburger (1273-1291 und von 1438 bis zur Aufl\u00f6sung des Reiches 1806).","year_from":"911","year_until":"1500","autor":"Kluge"},{"ikmk_timeline_id":"22","timeline_item":"Der Fernhandelsdenar","description":"Zu keiner Zeit sind so zahlreiche deutsche M\u00fcnzen nach Skandinavien, Polen, das Baltikum und Russland gelangt wie vom Ende des 10. bis zur ersten H\u00e4lfte des 12. Jhs. Zahlreiche Schatzfunde legen davon Zeugnis ab. Demgegen\u00fcber werden die deutschen Denare dieser Zeit im Inland nur vergleichsweise selten gefunden, so da\u00df man von einem M\u00fcnzexport in den Norden und Osten sprechen kann, der vor allem dem Fernhandel diente. Alle hier aufgef\u00fchrten M\u00fcnztypen sind in Funden Skandinaviens, Polens, des Baltikums oder Russlands aufgetreten.","year_from":"950","year_until":"1150","autor":"Kluge, Bernd"},{"ikmk_timeline_id":"81","timeline_item":"Erzbisch\u00f6fe, Bisch\u00f6fe, \u00c4bte","description":"Um die wirtschaftlichen und politischen Potenzen der Kirche f\u00fcr das Reich und das eigene Seelenheil zu nutzen, ist die Kirche durch die K\u00f6nige im 10. und 11. Jh. im Deutschen Reich  mit Schenkungen bedacht worden. Zu diesen Schenkungen geh\u00f6rte auch die Verleihung des M\u00fcnzrechts. Auf diese Weise sind nahezu alle Erzbist\u00fcmer, Bist\u00fcmer und Reichsabteien in den Besitz des M\u00fcnzrechts gelangt, das die meisten auch ausge\u00fcbt haben. Die bis in die Neuzeit reichenden geistlichen M\u00fcnzpr\u00e4gungen in Deutschland haben ihre Wurzeln im 10. Jh.","year_from":"950","year_until":"1500","autor":"Kluge, Bernd"}],"text_right":{"short":"CC BY-SA 4.0","icon":"https:\/\/licensebuttons.net\/l\/by-sa\/4.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de","en":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en"},"label":{"de":"Creative Commons Namensnennung - Weitergabe unter gleichen Bedingungen 4.0 International","en":"Creative Commons Attribution-ShareAlike 4.0 International"},"string":{"de":"Texte und Beschreibungen in diesem Online-Katalog stehen unter einer\u00a0<a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de\" target=\"_blank\">CC BY-SA 4.0<\/a> Lizenz.","en":"Texts and descriptions of this catalogue are licensed <a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en\" target=\"_blank\">CC BY-SA 4.0<\/a>."}},"lod_right":{"short":"PDM 1.0","icon":"https:\/\/licensebuttons.net\/p\/zero\/1.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de","en":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en"},"label":{"de":"Public Domain Mark 1.0","en":"Public Domain Mark 1.0"},"string":{"de":"Verwendete LOD-Identifikatoren sind <a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de\" target=\"_blank\">Public Domain Mark 1.0<\/a>\u00a0lizenziert.","en":"LOD ids used are licensed <a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en\" target=\"_blank\">Public Domain Mark 1.0<\/a>."}},"image_restriction_id":0,"image_restriction":"free","image_right":{"short":"PDM 1.0","icon":"https:\/\/licensebuttons.net\/p\/zero\/1.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de","en":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en"},"label":{"de":"Public Domain Mark 1.0","en":"Public Domain Mark 1.0"}}}