/d-nb.info\/gnd\/118848399","https:\/\/en.wikipedia.org\/wiki\/Albert_II,_Duke_of_Austria":"https:\/\/en.wikipedia.org\/wiki\/Albert_II,_Duke_of_Austria","https:\/\/viaf.org\/viaf\/67262940":"https:\/\/viaf.org\/viaf\/67262940","https:\/\/www.wikidata.org\/wiki\/Q158434":"https:\/\/www.wikidata.org\/wiki\/Q158434","https:\/\/ikmk.smb.museum\/ndp\/person\/257":"https:\/\/ikmk.smb.museum\/ndp\/person\/257"}}}}},"keywords":[{"ikmk_keyword_id":"50","keyword_de":"Christliche Ikonographie","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/7502667-3","keyword_concept_uri":""},{"ikmk_keyword_id":"70","keyword_de":"Gold","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4157819-3","keyword_concept_uri":"http:\/\/www.nomisma.org\/id\/av"},{"ikmk_keyword_id":"47","keyword_de":"Heilige","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4024055-1","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300150555"},{"ikmk_keyword_id":"2","keyword_de":"Mittelalter","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4129108-6","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300020756"},{"ikmk_keyword_id":"52","keyword_de":"Pflanzen","keyword_gnd_uri":"","keyword_concept_uri":""},{"ikmk_keyword_id":"10","keyword_de":"Sp\u00e4tmittelalter, 13.-15. Jh.","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/7503823-7","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300111307"},{"ikmk_keyword_id":"34","keyword_de":"Weltliche F\u00fcrsten","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4166473-5","keyword_concept_uri":""},{"ikmk_keyword_id":"19","keyword_de":"Westeuropa (ohne D)","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4079215-8","keyword_concept_uri":"http:\/\/vocab.getty.edu\/tgn\/4003761"}],"timeline_themes":[{"ikmk_timeline_id":"82","timeline_item":"Herz\u00f6ge, Grafen, F\u00fcrsten","description":"Das urspr\u00fcnglich nur dem K\u00f6nig bzw. Kaiser zustehende M\u00fcnzrecht ist seit dem 10. Jh. in Deutschland und Frankreich auch auf den weltlichen Adel \u00fcbergegangen, teils durch k\u00f6nigliche Delegation, teils infolge der Schw\u00e4che des K\u00f6nigtums durch  Usurpation und Gewohnheitsrecht. W\u00e4hrend in Frankreich die M\u00fcnzpr\u00e4gung des Adels durch das K\u00f6nigtum im Laufe der Zeit zur\u00fcckgedr\u00e4ngt und am Ende des Mittelalters ganz aufh\u00f6rte, ist sie im Gebiet des Deutschen Reiches zu einem festen Bestandteil des M\u00fcnzwesens geworden und im 13. Jh. durch das K\u00f6nigtum auch formal sanktioniert worden.","year_from":"900","year_until":"1500","autor":"Kluge, Bernd"},{"ikmk_timeline_id":"132","timeline_item":"\u00d6sterreich im Mittelalter","description":"\u00d6sterreich war im Mittelalter Teil des Deutschen Reiches. Die einheimische M\u00fcnzpr\u00e4gung beginnt in Salzburg durch die Herz\u00f6ge von Bayern bereits im 10. Jh. Die seit dem 12. Jh. durch die Salzburger Erzbisch\u00f6fe gem\u00fcnzten Pfennige aus den Silbervorkommen um Friesach in K\u00e4rnten (Friesacher Pfennige) bildeten zusammen mit dem etwas sp\u00e4ter entstandenen Wiener Pfennig die wichtigsten Geldsorten bis zur Mitte des 15. Jh. Goldm\u00fcnzen sind zuerst in der zweiten H\u00e4lfte des 14. Jh., gr\u00f6\u00dfere Silberm\u00fcnzen als Pfennige erst in der zweiten H\u00e4lfte des 15. Jh. gem\u00fcnzt worden. Die m\u00fcnzgeschichtlich wichtigste Region ist das im Mittelalter von \u00d6sterreich noch unabh\u00e4ngige Tirol, das erst 1477 habsburgisch wurde. Mit den ab 1274\/75 gem\u00fcnzten Kreuzern und den 1486 in der M\u00fcnzst\u00e4tte Hall entstandenen ersten Talern (Guldiner (Guldengroschen) hat Tirol eine bedeutende Rolle in der europ\u00e4ischen M\u00fcnzgeschichte des Mittelalters gespielt.","year_from":"1000","year_until":"1500","autor":"Kluge, Bernd"},{"ikmk_timeline_id":"83","timeline_item":"Florene - die Euros des 14. Jahrhunderts","description":"Die seit 1252 immer im gleichen Bild mit der Lilie auf der einen und Johannes dem T\u00e4ufer auf der anderen Seite ausgegebenen Goldgulden der Stadt Florenz werden nach dem M\u00fcnzbild des Florentiner Wappens, der Lilie (lat. flos), Florene genannt. Sie sind im 14. Jh. in vielen Gegenden Europas v\u00f6llig bildgleich nachgeahmt worden (Deutschland, \u00d6sterreich, B\u00f6hmen, Schlesien, Ungarn, Niederlande, Frankreich, Spanien). Nur die Umschrift der Lilienseite und Beizeichen auf der T\u00e4ufer-Seite geben Hinweise auf den tats\u00e4chlichen Entstehungsort. Mit den Florenen hat das Ph\u00e4nomen europaweit gleicher M\u00fcnzen seinen prominentesten Vorl\u00e4ufer.","year_from":"1325","year_until":"1400","autor":"Kluge, Bernd"}],"text_right":{"short":"CC BY-SA 4.0","icon":"https:\/\/licensebuttons.net\/l\/by-sa\/4.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de","en":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en"},"label":{"de":"Creative Commons Namensnennung - Weitergabe unter gleichen Bedingungen 4.0 International","en":"Creative Commons Attribution-ShareAlike 4.0 International"},"string":{"de":"Texte und Beschreibungen in diesem Online-Katalog stehen unter einer\u00a0<a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de\" target=\"_blank\">CC BY-SA 4.0<\/a> Lizenz.","en":"Texts and descriptions of this catalogue are licensed <a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en\" target=\"_blank\">CC BY-SA 4.0<\/a>."}},"lod_right":{"short":"PDM 1.0","icon":"https:\/\/licensebuttons.net\/p\/zero\/1.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de","en":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en"},"label":{"de":"Public Domain Mark 1.0","en":"Public Domain Mark 1.0"},"string":{"de":"Verwendete LOD-Identifikatoren sind <a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de\" target=\"_blank\">Public Domain Mark 1.0<\/a>\u00a0lizenziert.","en":"LOD ids used are licensed <a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en\" target=\"_blank\">Public Domain Mark 1.0<\/