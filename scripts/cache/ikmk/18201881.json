th":"https:\/\/ikmk.smb.museum\/image\/18201881\/vs_org.jpg","path_org":"https:\/\/ikmk.smb.museum\/image\/18201881\/vs_org.jpg","image_timestamp":1643740523,"copyright":{"short":"PDM 1.0","url":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/","de":"Bilddateien sind lizenziert als&nbsp;<a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de\" target=\"_blank\">Public Domain Mark 1.0<\/a>. Berlin, M\u00fcnzkabinett der Staatlichen Museen, 18201881. Aufnahme durch Lutz-J\u00fcrgen L\u00fcbke (L\u00fcbke und Wiedemann). Medailleur\/in: Tobias Wolff.","en":"Image files are licensed&nbsp;<a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en\" target=\"_blank\">Public Domain Mark 1.0<\/a>. Berlin, M\u00fcnzkabinett der Staatlichen Museen, 18201881. Photographs by Lutz-J\u00fcrgen L\u00fcbke (L\u00fcbke und Wiedemann). Medalist: Tobias Wolff."}},"revers":{"leg_trans":"Drei Schriftb\u00e4nder und Tafeltext, teilweise ligierte Buchstaben","leg_text":"DIE ALMACHT - DIE VERNVNFT - IOSVA I CONFIDE NON DERELINQVAM TE \/\/ SCHLOS HAR\/TENFELS -\/ APVD DEVM NON EST IMPOS \/ SIBILE VLLVM VERBVM LVC I \/ CONSERVA APVD NOS \/ VERBVM TVVM DOMINE \/ 1574","image_description":"Kurf\u00fcrst August steht auf einem Fels, r. das Schwert geschultert, l. eine ein Waage, in deren abgesenkter Schale das Jesuskind mit Schriftband, in oberer Schale vier Geistliche mit Schriftband, \u00fcber allen Gottvater mit Schriftband. Unten Schrifttafel.","foto_date":"2005-10-12","photographer":{"ikmk_photographer_id":"4","photographer_name":"Lutz-J\u00fcrgen L\u00fcbke (L\u00fcbke und Wiedemann)","photographer_gnd":"","photographer_viaf":""},"path_thumbnail":"https:\/\/ikmk.smb.museum\/image\/18201881\/rs_opt.jpg","path_opt":"https:\/\/ikmk.smb.museum\/image\/18201881\/rs_opt.jpg","path_opt_rel":"\/data\/www\/001-ikmk\/mk-edit\/images\/n1\/1927\/rs_opt.jpg","path":"https:\/\/ikmk.smb.museum\/image\/18201881\/rs_org.jpg","path_org":"https:\/\/ikmk.smb.museum\/image\/18201881\/rs_org.jpg","image_timestamp":1643740523,"copyright":{"short":"PDM 1.0","url":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/","de":"Bilddateien sind lizenziert als&nbsp;<a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de\" target=\"_blank\">Public Domain Mark 1.0<\/a>. Berlin, M\u00fcnzkabinett der Staatlichen Museen, 18201881. Aufnahme durch Lutz-J\u00fcrgen L\u00fcbke (L\u00fcbke und Wiedemann). Medailleur\/in: Tobias Wolff.","en":"Image files are licensed&nbsp;<a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en\" target=\"_blank\">Public Domain Mark 1.0<\/a>. Berlin, M\u00fcnzkabinett der Staatlichen Museen, 18201881. Photographs by Lutz-J\u00fcrgen L\u00fcbke (L\u00fcbke und Wiedemann). Medalist: Tobias Wolff."}},"division":{"ikmk_division_id":"4","division_name_de":"Medaillen","division_name_en":"Medals"},"sub_division":{"ikmk_subdivision_id":"7","subdivision_name_de":"Brandenburg-Preu\u00dfen","subdivision_name_en":"Brandenburg-Prussia"},"literatur":"J. Menadier, Schaum\u00fcnzen des Hauses Hohenzollern (1901) Nr. 41; G. Habich, Die deutschen Schaum\u00fcnzen des XVI. Jahrhunderts II (1931) 296 Nr. 2050; G. Brockmann, Die Medaillen Joachim I. - Friedrich Wilhelm I. 1499-1740 (1994) Nr. 49 (dieses St\u00fcck); W. Steguweit - B. Kluge, Suum Cuique. Medaillenkunst und M\u00fcnzpr\u00e4gung in Brandenburg-Preu\u00dfen (2008) Nr. 9 (dieses St\u00fcck).","comment":"Im August 1574 wurde in Torgau eine Synode abgehalten. Sie hatte zum Ziel, die radikalen Elemente innerhalb des protestantischen Glaubens auszuschalten. In diesem Zusammenhang wurden vier Geistliche festgesetzt, sie wurden in der oberen Waagschale dargestellt. Eine weitere Versammlung 1576 endete mit dem Entwurf der sog. Concordienformel, nachdem zuvor schwerwiegende Lehrstreitigkeiten beigelegt werden konnten. Die Concordienformel wurde von mehr als 800 Geistlichen angenommen, und bildete als \u201eTorgauer Artikel\u201c die Grundlage der Augsburgischen Konfession.","period":{"ikmk_period_id":"13","name_de":"Barock","name_en":"Baroque","description_de":"Kunst bzw- Stilperiode, welche mit regional unterschiedlichen Entwicklungen die Zeit vom Ende des 16. Jahrhunderts bis ca. 1730 umfasst. Teilweise wird der Rokoko (bis ca. 1770) ihr auch zugerechnet.","description_en":"Art period with a regionally varying developement in chronological terms roughly from the end of the 16th century to c. 1730. Sometimes the following period Rococo (to c. 1770) is considered a late form of Baroque.","concept_id":"http:\/\/vocab.getty.edu\/aat\/300021147","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/period\/13"},"year_start":"1577","year_end":"1577","date_verbal":"1577","year_islam":"0","references":[{"ikmk_referenz_id":221,"souce":"Habich, Schaum\u00fcnzen XVI. Jh.","number":"2050","similar":"0"}],"manufacturing":[{"ikmk_manufacturing_id":"22","manufacturing_name_de":"gegossen","manufacturing_name_en":"cast","nomisma_id":"http:\/\/nomisma.org\/id\/cast","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/manufacture\/22"}],"linked_persons_corporations":{"49":{"ikmk_type_id":"49","type_name_de":"Medailleur\/in","type_name_en":"Medalist","type_nomisma_id":"http:\/\/nomisma.org\/id\/medalist","type_concept_id":"http:\/\/d-nb.info\/gnd\/4306105-9","ndp_id":"https:\/\/ikmk.smb.museum\/ndp\/type_for_person_and_corporation\/49","items":{"3145":{"ikmk_person_id":"3145","title_de":null,"first_name_de":"Tobias","last_name_de":"Wolff","vitalDates":"-um 1600","title_en":null,"first_name_en":"Tobias","last_name_en":"Wolff","corporation":"0","lod":{"https:\/\/d-nb.info\/gnd\/138463395":"https:\/\/d-nb.info\/gnd\/138463395","https:\/\/viaf.org\/viaf\/90001100":"https:\/\/viaf.org\/viaf\/90001100","https:\/\/ikmk.smb.museum\/ndp\/person\/3145":"https:\/\/ikmk.smb.museum\/ndp\/person\/3145"}}}},"50":{"ikmk_type_id":"50","type_name_de":"Vorbesitzer","type_name_en":"previous Owner","type_nomisma_id":"","type_concept_id":"http:\/\/d-nb.info\/gn