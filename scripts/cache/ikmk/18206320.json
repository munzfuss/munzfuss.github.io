{"ikmk_mds_id":"18206320","ikmk_id":"6502","eLearning_completed":"0","primary_source_id":"0","title":"Anhalt-K\u00f6then: F\u00fcrstentum","inventory_number":"","activated":"yes","item":{"ikmk_item_id":"1","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/item\/1","item_de":"M\u00fcnze","item_en":"Coin","item_nomisma":"http:\/\/nomisma.org\/id\/coin"},"permalink":"https:\/\/ikmk.smb.museum\/object?id=18206320","permalink_source":null,"publisher":{"ikmk_publisher_id":13,"ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/owner\/13","publisher_name":"M\u00fcnzkabinett, Staatliche Museen zu Berlin - Stiftung Preu\u00dfischer Kulturbesitz","publisher_isil":"http:\/\/ld.zdb-services.de\/resource\/organisations\/DE-MUS-814819","publisher_isil_short":"DE-MUS-814819","UID":"http:\/\/ld.zdb-services.de\/resource\/organisations\/DE-MUS-814819\/18206320","legalBodyWeblink":"https:\/\/www.smb.museum\/museen-und-einrichtungen\/muenzkabinett\/home.html","nomisma_address":"http:\/\/nomisma.org\/id\/mk_berlin","author":"Bannicke, Elke"},"owner":{"ikmk_owner_id":"13","owner_name":"Berlin, M\u00fcnzkabinett der Staatlichen Museen","owner_isil":"http:\/\/ld.zdb-services.de\/resource\/organisations\/DE-MUS-814819","owner_isil_short":"DE-MUS-814819","owner_www_address":"https:\/\/ikmk.smb.museum\/","nomisma_address":"http:\/\/nomisma.org\/id\/mk_berlin","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/owner\/13","owner_type":{"de":"Eigentum","en":"Property","ikmk_type_id":"2","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/status_of_property\/2"}},"ikmk_status_id":"7","status":{"de":"vorhanden","en":"present","ikmk_status_id":"7","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/object_status\/7"},"nominal":{"ikmk_nominal_id":"1153","nominal_de":"Taler (Speziestaler)","nominal_en":"Taler (Speciestaler)","nominal_nomisma_id":"http:\/\/nomisma.org\/id\/taler_(speciestaler)","nominal_gnd_id":"","info_de":"Bezeichnung von Talerm\u00fcnzen, die nach dem alten 9 Talerfuss (= 32 Groschen) gepr\u00e4gt waren und damit ein h\u00f6heres Gewicht als die zeitgen\u00f6ssischen Reichstaler zu 24 Groschen aufwiesen.\r\nAuch die Kurzform Species war \u00fcblich. Urspr\u00fcnglich wurde damit die physische M\u00fcnze von der Rechnungseinheit unterschieden.\r\nAuch der 1753 eingef\u00fchrte Konventionstaler wurde bisweilen als Speciestaler bezeichnet.\r\n\r\nLit.: F. von Schr\u00f6tter, W\u00f6rterbuch der M\u00fcnzkunde (1930) s.v. Species 645 f.","info_en":"A term to describe Taler coins, of which nine pieces were struck from the Mark (9 Taler standard), equaling 32 Groschen, in contrast to the contemporary Reichstaler, which was valued as 24 Groschen.\r\n\r\nOften the brief variant Species was used. The term originally differentiated the physical coin from the unit of account.\r\nWhen the Conventionstaler was introduced in 1753 it frequently was called a Speciestaler.\r\n\r\nLit.: F. von Schr\u00f6tter, W\u00f6rterbuch der M\u00fcnzkunde (1930) s.v. Species pp. 645-655.","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/denomination\/1153"},"patronage":"Anonymus","date_last":"2023-03-14 01:49:51","coin_status":[{"ikmk_coin_status_id":"20","coin_status_name_de":"F\u00fcrstentum","coin_status_name_en":"Principality","coin_status_nomisma_id":"http:\/\/nomisma.org\/id\/prince","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/class_status\/20"}],"mint":[{"ikmk_country_id":"19","country_ndp_url":"https:\/\/ikmk.smb.museum\/ndp\/country\/19","country_name_de":"Deutschland","country_name_en":"Germany","country_nomisma_id":"http:\/\/nomisma.org\/id\/bundesrepublik_deutschland","country_geoname_id":"http:\/\/www.geonames.org\/2921044","ikmk_region_id":"52","region_ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/region\/52","region_name":"Anhalt","region_nomisma_id":"","region_geoname_id":"","ikmk_mint_id":"267","mint_ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/location\/267","mint_name":"Stolberg","mint_name_de":"Stolberg","mint_name_en":null,"mint_nomisma_id":"http:\/\/nomisma.org\/id\/stolberg_harz","mint_geoname_id":"http: