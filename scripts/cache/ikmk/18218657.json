15","photographer":{"ikmk_photographer_id":"5","photographer_name":"Reinhard Saczewski","photographer_gnd":"","photographer_viaf":""},"path_thumbnail":"https:\/\/ikmk.smb.museum\/image\/18218657\/vs_opt.jpg","path_opt":"https:\/\/ikmk.smb.museum\/image\/18218657\/vs_opt.jpg","path_opt_rel":"\/data\/www\/001-ikmk\/mk-edit\/images\/n19\/19513\/vs_opt.jpg","path":"https:\/\/ikmk.smb.museum\/image\/18218657\/vs_org.jpg","path_org":"https:\/\/ikmk.smb.museum\/image\/18218657\/vs_org.jpg","image_timestamp":1643738129,"copyright":{"short":"PDM 1.0","url":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/","de":"Bilddateien sind lizenziert als&nbsp;<a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de\" target=\"_blank\">Public Domain Mark 1.0<\/a>. Berlin, M\u00fcnzkabinett der Staatlichen Museen, 18218657. Aufnahme durch Reinhard Saczewski.","en":"Image files are licensed&nbsp;<a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en\" target=\"_blank\">Public Domain Mark 1.0<\/a>. Berlin, M\u00fcnzkabinett der Staatlichen Museen, 18218657. Photographs by Reinhard Saczewski."}},"revers":{"leg_trans":"","leg_text":"PROV-INCIA DA-CIA \/\/ AN II","image_description":"Dacia in der Vorderansicht, Kopf mit phrygischer M\u00fctze nach l. Sie h\u00e4lt in der r. Hand ein Krummschwert und in der l. Hand ein Feldzeichen (vexillum), darauf XIII. Ein Feldzeichen (vexillum) steht l., darauf V. Adler mit Kranz im Schnabel l. und ein L\u00f6we r.","foto_date":"2010-01-18","photographer":{"ikmk_photographer_id":"5","photographer_name":"Reinhard Saczewski","photographer_gnd":"","photographer_viaf":""},"path_thumbnail":"https:\/\/ikmk.smb.museum\/image\/18218657\/rs_opt.jpg","path_opt":"https:\/\/ikmk.smb.museum\/image\/18218657\/rs_opt.jpg","path_opt_rel":"\/data\/www\/001-ikmk\/mk-edit\/images\/n19\/19513\/rs_opt.jpg","path":"https:\/\/ikmk.smb.museum\/image\/18218657\/rs_org.jpg","path_org":"https:\/\/ikmk.smb.museum\/image\/18218657\/rs_org.jpg","image_timestamp":1643738129,"copyright":{"short":"PDM 1.0","url":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/","de":"Bilddateien sind lizenziert als&nbsp;<a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de\" target=\"_blank\">Public Domain Mark 1.0<\/a>. Berlin, M\u00fcnzkabinett der Staatlichen Museen, 18218657. Aufnahme durch Reinhard Saczewski.","en":"Image files are licensed&nbsp;<a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en\" target=\"_blank\">Public Domain Mark 1.0<\/a>. Berlin, M\u00fcnzkabinett der Staatlichen Museen, 18218657. Photographs by Reinhard Saczewski."}},"division":{"ikmk_division_id":"1","division_name_de":"Antike","division_name_en":"Antiquity"},"sub_division":{"ikmk_subdivision_id":"6","subdivision_name_de":"Griechen, R\u00f6mische Kaiserzeit","subdivision_name_en":"Greek, Roman Imperial period"},"literatur":"AMNG I-1 10 Nr. 8,4 (diese M\u00fcnze, 247\/248 n. Chr.); SNG Ungarn. Budapest II Nr. 32.","comment":"Im Sommer des Jahres 246 n. Chr. vergab Philippus I. das M\u00fcnzrecht an die Provinz Dakien. Die Pr\u00e4gehoheit ist mittels der R\u00fcckseitenlegende PROVINCIA DACIA veranschaulicht. Zugleich verweist sie auf die stehende weibliche Figur, die durch ihre Attribute, die phrygische M\u00fctze und den Krumms\u00e4bel, als Personifikation der Daker gekennzeichnet ist. Zu dieser vertrauten Bildsprache z\u00e4hlen auch die beiden Tiere zu ihren F\u00fc\u00dfen. Der Adler als Symboltier der Legio XIII Gemina, die bereits mit den Eroberungsz\u00fcgen durch Kaiser Traianus in dieses Gebiet kam, sowie der L\u00f6we als Wappen der Legio V Macedonica, die w\u00e4hrend der Markomannenkriege in Dakien eingesetzt war (Cassius Dio 55,23). Beide Legionsnummern erscheinen hier auch auf den Feldzeichen der Rs. Im Abschnitt befindet sich die \u00c4renangabe AN II. Mit der Verleihung des Pr\u00e4gerechtes 246 n. Chr. wurde diese Jahresz\u00e4hlung eingef\u00fchrt, die dann bis zur Eroberung Dakiens durch die Goten bis Ende der f\u00fcnfziger Jahre auf den M\u00fcnzen fortgesetzt wurde.","period":{"ikmk_period_id":"4","name_de":"R\u00f6mische Kaiserzeit","name_en":"Roman Imperiod period","description_de":"Die Zeit zwischen dem Ende des Hellenismus mit der Eroberung \u00c4gyptens durch Rom im Jahre 30 v. und dem Regierungsantritt des Diocletianus 284 n. Chr.","description_en":"The period between the end of Hellenism in 30 BC (conquest of Alexandria) and the accession of Diocletianus in AD 284.","concept_id":"http:\/\/vocab.getty.edu\/aat\/300020541","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/period\/4"},"year_start":"247","year_end":"248","date_verbal":"247-248 n. Chr.","year_islam":"0","manufacturing":[{"ikmk_manufacturing_id":"21","manufacturing_name_de":"gepr\u00e4gt","manufacturing_name_en":"struck","nomisma_id":"http:\/\/nomisma.org\/id\/struck","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/manufacture\/21"}],"linked_persons_corporations":{"50":{"ikmk_type_id":"50","type_name_de":"Vorbesitzer","type_name_en":"previous Owner","type_nomisma_id":"","type_concept_id":"http:\/\/d-nb.info\/gnd\/4447273-0","ndp_id":"https:\/\/ikmk.smb.museum\/ndp\/type_for_person_and_corporation\/50","items":{"5897":{"ikmk_person_id":"5897","title_de":null,"first_name_de":"Friedrich","last_name_de":"Imhoof-Blumer","vitalDates":"11.05.1838 - 26.04.1920","title_en":null,"first_name_en":"Friedrich","last_name_en":"Imhoof-Blumer","corporation":"0","lod":{"https:\/\/d-nb.info\/gnd\/117137332":"https:\/\/d-nb.info\/gnd\/117137332","https:\/\/de.wikipedia.org\/wiki\/Friedrich_Imhoof-Blumer":"https:\/\/de.wikipedia.org\/wiki\/Friedrich_Imhoof-Blumer","https:\/\/hls-dhs-dss.ch\/de\/articles\/031431\/":"https:\/\/hls-dhs-dss.ch\/de\/articles\/031431\/","https:\/\/numismates.huma-num.fr\/wiki\/Imhoof-Blumer_Friedrich":"https:\/\/numismates.huma-num.fr\/wiki\/Imhoof-Blumer_Friedrich","https:\/\/term.museum-digital.de\/md-de\/persinst\/142578":"https:\/\/term.museum-digital.de\/md-de\/pe