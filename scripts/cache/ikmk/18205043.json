word_de":"Deutschland","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4011882-4","keyword_concept_uri":"http:\/\/vocab.getty.edu\/tgn\/7000084"},{"ikmk_keyword_id":"75","keyword_de":"Fabelwesen","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4016114-6","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300379738"},{"ikmk_keyword_id":"37","keyword_de":"Geistliche F\u00fcrsten","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4156371-2","keyword_concept_uri":"https:\/\/nomisma.org\/id\/clergy"},{"ikmk_keyword_id":"9","keyword_de":"Hochmittelalter, 10.-12. Jh.","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/7503822-5","keyword_concept_uri":""},{"ikmk_keyword_id":"2","keyword_de":"Mittelalter","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4129108-6","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300020756"},{"ikmk_keyword_id":"69","keyword_de":"Silber","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4133759-1","keyword_concept_uri":"http:\/\/www.nomisma.org\/id\/ar"},{"ikmk_keyword_id":"34","keyword_de":"Weltliche F\u00fcrsten","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4166473-5","keyword_concept_uri":""}],"timeline_themes":[{"ikmk_timeline_id":"82","timeline_item":"Herz\u00f6ge, Grafen, F\u00fcrsten","description":"Das urspr\u00fcnglich nur dem K\u00f6nig bzw. Kaiser zustehende M\u00fcnzrecht ist seit dem 10. Jh. in Deutschland und Frankreich auch auf den weltlichen Adel \u00fcbergegangen, teils durch k\u00f6nigliche Delegation, teils infolge der Schw\u00e4che des K\u00f6nigtums durch  Usurpation und Gewohnheitsrecht. W\u00e4hrend in Frankreich die M\u00fcnzpr\u00e4gung des Adels durch das K\u00f6nigtum im Laufe der Zeit zur\u00fcckgedr\u00e4ngt und am Ende des Mittelalters ganz aufh\u00f6rte, ist sie im Gebiet des Deutschen Reiches zu einem festen Bestandteil des M\u00fcnzwesens geworden und im 13. Jh. durch das K\u00f6nigtum auch formal sanktioniert worden.","year_from":"900","year_until":"1500","autor":"Kluge, Bernd"},{"ikmk_timeline_id":"81","timeline_item":"Erzbisch\u00f6fe, Bisch\u00f6fe, \u00c4bte","description":"Um die wirtschaftlichen und politischen Potenzen der Kirche f\u00fcr das Reich und das eigene Seelenheil zu nutzen, ist die Kirche durch die K\u00f6nige im 10. und 11. Jh. im Deutschen Reich  mit Schenkungen bedacht worden. Zu diesen Schenkungen geh\u00f6rte auch die Verleihung des M\u00fcnzrechts. Auf diese Weise sind nahezu alle Erzbist\u00fcmer, Bist\u00fcmer und Reichsabteien in den Besitz des M\u00fcnzrechts gelangt, das die meisten auch ausge\u00fcbt haben. Die bis in die Neuzeit reichenden geistlichen M\u00fcnzpr\u00e4gungen in Deutschland haben ihre Wurzeln im 10. Jh.","year_from":"950","year_until":"1500","autor":"Kluge, Bernd"},{"ikmk_timeline_id":"39","timeline_item":"Renovatio monetae - regionale Pfennigw\u00e4hrungen","description":"Verrufungen (renovatio monetae) und W\u00e4hrungszwang (Wechselmonopol) kennzeichnen das System der hochmittelalterlichen Pfennigw\u00e4hrungen im Deutschen Reich. Zu bestimmten Stichtagen, meist j\u00e4hrlich, wurde das umlaufende Geld eingezogen (\u201everrufen\u201c). Wer Gesch\u00e4fte auf dem Markt machen wollte, war gezwungen, sein Geld dort umzuwechseln, wobei man meist f\u00fcr 12 alte nur 9 neue Pfennige erhielt, so da\u00df der M\u00fcnz- und Marktherr praktisch eine j\u00e4hrliche \u201eVerm\u00f6genssteuer\u201c von 25 Prozent erhob.","year_from":"1100","year_until":"1300","autor":"Kluge, Bernd"}],"text_right":{"short":"CC BY-SA 4.0","icon":"https:\/\/licensebuttons.net\/l\/by-sa\/4.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de","en":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en"},"label":{"de":"Creative Commons Namensnennung - Weitergabe unter gleichen Bedingungen 4.0 International","en":"Creative Commons Attribution-ShareAlike 4.0 International"},"string":{"de":"Texte und Beschreibungen in diesem Online-Katalog stehen unter einer\u00a0<a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de\" target=\"_blank\">CC BY-SA 4.0<\/a> Lizenz.","en":"Texts and descriptions of this catalogue are licensed <a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en\" target=\"_blank\">CC BY-SA 4.0<\/a>."}},"lod_right":{"short":"PDM 1.0","icon":"https:\/\/licensebuttons.net\/p\/zero\/1.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de","en":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en"},"label":{"de":"Public Domain Mark 1.0","en":"Public Domain Mark 1.0"},"string":{"de":"Verwendete LOD-Identifikatoren sind <a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de\" target=\"_blank\">Public Domain Mark 1.0<\/a>\u00a0lizenziert.","en":"LOD ids used are licensed <a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en\" target=\"_blank\">Public Domain Mark 1.0<\/a>."}},"image_restriction_id":0,"image_restriction":"free","image_right":{"short":"PDM 1.0","icon":"https:\/\/licensebuttons.net\/p\/zero\/1.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de","en":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en"},"label":{"de":"Public Domain Mark 1.0","en":"Public Domain Mark 1.0"}}}