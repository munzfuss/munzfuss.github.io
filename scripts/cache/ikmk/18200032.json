 Ages to the Modern period during the 15th and 16th century. It begins during the early 15th century and developes into the Baroque around 1550.","concept_id":"http:\/\/vocab.getty.edu\/aat\/300021140","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/period\/7"},"year_start":"1519","year_end":"1519","date_verbal":"1519","year_islam":"0","references":[{"ikmk_referenz_id":221,"souce":"Habich, Schaum\u00fcnzen XVI. Jh.","number":"0143","similar":"0"}],"manufacturing":[{"ikmk_manufacturing_id":"22","manufacturing_name_de":"gegossen","manufacturing_name_en":"cast","nomisma_id":"http:\/\/nomisma.org\/id\/cast","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/manufacture\/22"}],"linked_persons_corporations":{"49":{"ikmk_type_id":"49","type_name_de":"Medailleur\/in","type_name_en":"Medalist","type_nomisma_id":"http:\/\/nomisma.org\/id\/medalist","type_concept_id":"http:\/\/d-nb.info\/gnd\/4306105-9","ndp_id":"https:\/\/ikmk.smb.museum\/ndp\/type_for_person_and_corporation\/49","items":{"3095":{"ikmk_person_id":"3095","title_de":null,"first_name_de":"Hans","last_name_de":"Schwarz","vitalDates":"1492-um 1550","title_en":null,"first_name_en":"Hans","last_name_en":"Schwarz","corporation":"0","lod":{"https:\/\/d-nb.info\/gnd\/12270911X":"https:\/\/d-nb.info\/gnd\/12270911X","https:\/\/de.wikipedia.org\/wiki\/Hans_Schwarz_(Medailleur)":"https:\/\/de.wikipedia.org\/wiki\/Hans_Schwarz_(Medailleur)","https:\/\/en.wikipedia.org\/wiki\/Hans_Schwarz_(sculptor)":"https:\/\/en.wikipedia.org\/wiki\/Hans_Schwarz_(sculptor)","https:\/\/viaf.org\/viaf\/95712623":"https:\/\/viaf.org\/viaf\/95712623","https:\/\/www.wikidata.org\/wiki\/Q1582440":"https:\/\/www.wikidata.org\/wiki\/Q1582440","https:\/\/ikmk.smb.museum\/ndp\/person\/3095":"https:\/\/ikmk.smb.museum\/ndp\/person\/3095"}}}},"54":{"ikmk_type_id":"54","type_name_de":"Dargestellte\/r","type_name_en":"Sitter","type_nomisma_id":"http:\/\/nomisma.org\/id\/portrait","type_concept_id":"http:\/\/vocab.getty.edu\/aat\/300189844","ndp_id":"https:\/\/ikmk.