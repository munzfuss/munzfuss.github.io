erglichen werden. In Frankreich dominierte seit Ludwig XIV. der Ecu. Im Osten Europas setzte der seit 1704 unter Peter I. emittierte Rubel durch das Dezimalsystem (Rubel zu 100 Kopeken) gegen\u00fcber dem \u00fcblichen Duodezimalsystem (Taler zu 24 Groschen \u00e0 12 Pfennige) f\u00fcr die Zukunft Ma\u00dfst\u00e4be.","year_from":"1601","year_until":"1800","autor":"Steguweit, Wolfgang"}],"secondary_treatment":[{"ikmk_secondary_treatment_id":"25","item_de":"beschriftet (per Hand)","item_en":"inscribed upon (by hand)","description_de":"Ein Objekt ist von Hand mit Tinte, Tusche etc. beschriftet worden.","description_en":"An object has been inscribed by hand with ink etc.","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/secondary_treatment\/25"}],"text_right":{"short":"CC BY-SA 4.0","icon":"https:\/\/licensebuttons.net\/l\/by-sa\/4.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de","en":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en"},"label":{"de":"Creative Commons Namensnennung - Weitergabe unter gleichen Bedingungen 4.0 International","en":"Creative Commons Attribution-ShareAlike 4.0 International"},"string":{"de":"Texte und Beschreibungen in diesem Online-Katalog stehen unter einer\u00a0<a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de\" target=\"_blank\">CC BY-SA 4.0<\/a> Lizenz.","en":"Texts and descriptions of this catalogue are licensed <a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en\" target=\"_blank\">CC BY-SA 4.0<\/a>."}},"lod_right":{"short":"PDM 1.0","icon":"https:\/\/licensebuttons.net\/p\/zero\/1.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de","en":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en"},"label":{"de":"Public Domain Mark 1.0","en":"Public Domain Mark 1.0"},"string":{"de":"Verwendete LOD-Identifikatoren sind <a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de\" target=\"_bla