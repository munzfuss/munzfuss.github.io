ry_id":"19","country_ndp_url":"https:\/\/ikmk.smb.museum\/ndp\/country\/19","country_name_de":"Deutschland","country_name_en":"Germany","country_nomisma_id":"http:\/\/nomisma.org\/id\/bundesrepublik_deutschland","country_geoname_id":"http:\/\/www.geonames.org\/2921044","ikmk_region_id":"50","region_ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/region\/50","region_name_de":"","region_name_en":null,"region_nomisma_id":"","region_geoname_id":"","ikmk_mint_id":"78","mint_ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/location\/78","mint_name":"","mint_name_de":"","mint_name_en":null,"mint_nomisma_id":"","mint_geoname_id":""}],"material":{"ikmk_material_id":"23","material_name_de":"Wei\u00dfmetall","material_name_en":"Whitemetal","material_nomisma_id":"","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/material\/23"},"diameter":"114x112 mm","weight":"400.00 g","accession":"1991\/47","access_year":"1991","access_type":{"ikmk_access_type_id":"1","access_type_name":"Kauf","access_type_nomisma_id":"","access_type_concept_id":"http:\/\/d-nb.info\/gnd\/4128692-3","ndp_uir":"https:\/\/ikmk.smb.museum\/ndp\/accession\/1"},"provenienz_extern":"","acquisition_date":"","avers":{"leg_trans":"","leg_text":"WIR WOLLEN SEIN EIN EIN(Z)IG \/ VOLK VON BR\u00dcDERN..","image_description":"Umriss von West- und Ostdeutschland, \u00fcberspannt von einem blauen Band mit zehn goldenen Sternen, darauf das Datum 3.10.90. Aus den Grenzen der DDR fliehen Schlangen in alle Richtungen. Links der Geistk\u00e4mpfer von Ernst Barlach. Signatur G 91\/92.","foto_date":"2009-01-22","photographer":{"ikmk_photographer_id":"5","photographer_name":"Reinhard Saczewski","photographer_gnd":"","photographer_viaf":""},"path_thumbnail":"https:\/\/ikmk.smb.museum\/layout\/sperre300.jpg","path_opt":"https:\/\/ikmk.smb.museum\/layout\/sperre300.jpg","path_opt_rel":"\/data\/www\/001-ikmk\/mk-edit\/images\/n17\/17011\/vs_opt.jpg","path":"https:\/\/ikmk.smb.museum\/layout\/sperre300.jpg","path_org":"https:\/\/ikmk.smb.museum\/layout\/sperre300.jpg","image_timestamp":1643744606,"copyright":{"short":"none","de":"Die Anzeige der Bildansichten wurde durch den Urheber&nbsp;erlaubt, aber nicht das Herunterladen der Bilddateien. Berlin, M\u00fcnzkabinett der Staatlichen Museen, 18217007. Aufnahme durch Reinhard Saczewski. Medailleur\/in: Peter-G\u00f6tz G\u00fcttler.","en":"Permission to show images of this object was granted by the Copyright holder. Downloading of or saving&nbsp;these images is prohibited. Berlin, M\u00fcnzkabinett der Staatlichen Museen, 18217007. Photographs by Reinhard Saczewski. Medalist: Peter-G\u00f6tz G\u00fcttler."}},"division":{"ikmk_division_id":"4","division_name_de":"Medaillen","division_name_en":"Medals"},"sub_division":{"ikmk_subdivision_id":"30","subdivision_name_de":"20. Jh. bis heute","subdivision_name_en":"20th century to present"},"literatur":"Vgl. W. Steguweit u.a., Die Kunstmedaille der Gegenwart in Deutschland 1988-1991. Die Kunstmedaille in Deutschland 1 (1992) 40 Nr. 54 mit Abb. (Signatur dort G. 90\/91); W. Steguweit (Hrsg.), Peter-G\u00f6tz G\u00fcttler. Gegossene Sichten und Welten - Medaillen 1917 bis 2011. Die Kunstmedaille in Deutschland 27 (2012) 167 Nr. 1991.2a.","comment":"Guss, einseitig. Patiniert und bemalt. - Thematisiert wird der Tag der deutschen Einheit am 3. Oktober 1990. Wie ein Siegelabdruck verschwei\u00dft das Datum die beiden Teile Deutschlands miteinander. Das blaue Band mit den Sternen verdeutlicht, dass die Wiedervereinigung Deutschlands Teil eines gr\u00f6\u00dferen europ\u00e4ischen Vereinigungsprozesses ist. - \u00dcber dem Bild steht das Zitat aus Schillers 'Wilhelm Tell'. Auf der linken Seite ist die bronzene Gro\u00dfplastik des 'Geistk\u00e4mpfers' von Ernst Barlach abgebildet, die den Sieg des Geistes \u00fcber die b\u00f6se Macht symbolisiert. Die b\u00f6se Macht und ihre Vertreter erscheinen in Form der Schlangen, die aus dem sich aufb\u00e4umenden Ostdeutschland nach allen Richtungen fliehen. Barlachs Plastik aus dem Jahre 1928 steht vor der Universit\u00e4tskirche St. Nikolai in Kiel. Seit 1994 steht ein Abguss der Skulptur vor der Berliner Gethsemane-Kirche zur Erinnerung an die Urspr\u00fcnge der dortigen Demokratiebewegung.","period":{"ikmk_period_id":"5","name_de":"Moderne seit 1900","name_en":"Modern period post 1900","description_de":"Die kunstgeschichtliche Epoche seit dem Jahr 1900.","description_en":"The modern period from 1900.","concept_id":"http:\/\/vocab.getty.edu\/aat\/300404514","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/period\/5"},"year_start":"1991","year_end":"1992","date_verbal":"1991-1992","year_islam":"0","manufacturing":[{"ikmk_manufacturing_id":"22","manufacturing_name_de":"gegossen","manufacturing_name_en":"cast","nomisma_id":"http:\/\/nomisma.org\/id\/cast","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/manufacture\/22"}],"linked_persons_corporations":{"49":{"ikmk_type_id":"49","type_name_de":"Medailleur\/in","type_name_en":"Medalist","type_nomisma_id":"http:\/\/nomisma.org\/id\/medalist","type_concept_id":"http:\/\/d-nb.info\/gnd\/4306105-9","ndp_id":"https:\/\/ikmk.smb.museum\/ndp\/type_for_person_and_corporation\/49","items":{"19":{"ikmk_person_id":"19","title_de":null,"first_name_de":"Peter-G\u00f6tz","last_name_de":"G\u00fcttler","vitalDates":"08.06.1939 Greifswald - 31.10.2024 Dresden","title_en":null,"first_name_en":"Peter-G\u00f6tz","last_name_en":"G\u00fcttler","corporation":"0","lod":{"https:\/\/d-nb.info\/gnd\/121418294":"https:\/\/d-nb.info\/gnd\/121418294","https:\/\/term.museum-digital.de\/md-de\/persinst\/143":"https:\/\/term.museum-digital.de\/md-de\/persinst\/143","https:\/\/viaf.org\/viaf\/27926897":"https:\/\/viaf.org\/viaf\/27926897","https:\/\/www.wikidata.org\/wiki\/Q2075356":"https:\/\/www.wikidata.org\/wiki\/Q2075356","https:\/\/ikmk.smb.museum\/ndp\/person\/19":"https:\/\/ikmk.smb.museum\/ndp\/person\/19"}}}},"125":{"ikmk_type_id":"125","type_name_de":"Ver\u00e4u\u00dferer (an Museum)","type_name_en":"Vendor (to Museum)","type_nomisma_id":""