{"ikmk_mds_id":"18214612","ikmk_id":"14696","eLearning_completed":"0","primary_source_id":"0","title":"Preu\u00dfen: Friedrich Wilhelm I.","inventory_number":"","activated":"yes","item":{"ikmk_item_id":"1","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/item\/1","item_de":"M\u00fcnze","item_en":"Coin","item_nomisma":"http:\/\/nomisma.org\/id\/coin"},"permalink":"https:\/\/ikmk.smb.museum\/object?id=18214612","permalink_source":null,"publisher":{"ikmk_publisher_id":13,"ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/owner\/13","publisher_name":"M\u00fcnzkabinett, Staatliche Museen zu Berlin - Stiftung Preu\u00dfischer Kulturbesitz","publisher_isil":"http:\/\/ld.zdb-services.de\/resource\/organisations\/DE-MUS-814819","publisher_isil_short":"DE-MUS-814819","UID":"http:\/\/ld.zdb-services.de\/resource\/organisations\/DE-MUS-814819\/18214612","legalBodyWeblink":"https:\/\/www.smb.museum\/museen-und-einrichtungen\/muenzkabinett\/home.html","nomisma_address":"http:\/\/nomisma.org\/id\/mk_berlin","author":"Kluge, Bernd"},"owner":{"ikmk_owner_id":"13","owner_name":"Berlin, M\u00fcnzkabinett der Staatlichen Museen","owner_isil":"http:\/\/ld.zdb-services.de\/resource\/organisations\/DE-MUS-814819","owner_isil_short":"DE-MUS-814819","owner_www_address":"https:\/\/ikmk.smb.museum\/","nomisma_address":"http:\/\/nomisma.org\/id\/mk_berlin","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/owner\/13","owner_type":{"de":"Eigentum","en":"Property","ikmk_type_id":"2","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/status_of_property\/2"}},"ikmk_status_id":"7","status":{"de":"vorhanden","en":"present","ikmk_status_id":"7","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/object_status\/7"},"nominal":{"ikmk_nominal_id":"801","nominal_de":"Dukat","nominal_en":"Ducat","nominal_nomisma_id":"http:\/\/nomisma.org\/id\/ducat","nominal_gnd_id":"http:\/\/d-nb.info\/gnd\/7577068-4","info_de":"Aus der 1284 erstmals in Venedig gepr\u00e4gten Goldm\u00fcnze zu rund 3,5 Gramm und in einer Feinheit von 986\/000 entwickelte Bezei