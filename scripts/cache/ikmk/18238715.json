,"https:\/\/viaf.org\/viaf\/87172361":"https:\/\/viaf.org\/viaf\/87172361","https:\/\/www.britishmuseum.org\/collection\/term\/BIOG57623":"https:\/\/www.britishmuseum.org\/collection\/term\/BIOG57623","https:\/\/www.wikidata.org\/wiki\/Q1411":"https:\/\/www.wikidata.org\/wiki\/Q1411","https:\/\/ikmk.smb.museum\/ndp\/person\/464":"https:\/\/ikmk.smb.museum\/ndp\/person\/464"}}}},"148":{"ikmk_type_id":"148","type_name_de":"Anthypatos","type_name_en":"Anthypatos","type_nomisma_id":"","type_concept_id":"https:\/\/www.wikidata.org\/wiki\/Q574545","ndp_id":"https:\/\/ikmk.smb.museum\/ndp\/type_for_person_and_corporation\/148","items":{"4584":{"ikmk_person_id":"4584","title_de":null,"first_name_de":null,"last_name_de":"Titus Cominius Proculus","vitalDates":null,"title_en":null,"first_name_en":null,"last_name_en":"Titus Cominius Proculus","corporation":"0","lod":{"https:\/\/pir.bbaw.de\/id\/4738":"https:\/\/pir.bbaw.de\/id\/4738","https:\/\/rpc.ashmus.ox.ac.uk\/magistrate\/2424":"https:\/\/rpc.ashmus.ox.ac.uk\/magistrate\/2424","https:\/\/ikmk.smb.museum\/ndp\/person\/4584":"https:\/\/ikmk.smb.museum\/ndp\/person\/4584"}}}}},"keywords":[{"ikmk_keyword_id":"1","keyword_de":"Antike","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4068754-5","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300055818"},{"ikmk_keyword_id":"71","keyword_de":"Bronze \/ Kupfer","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4146667-6","keyword_concept_uri":"http:\/\/www.nomisma.org\/id\/ae"},{"ikmk_keyword_id":"67","keyword_de":"M\u00fcnzmeister\/-beamte","keyword_gnd_uri":"","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300205361"},{"ikmk_keyword_id":"43","keyword_de":"Portr\u00e4ts","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4006627-7","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300015637"},{"ikmk_keyword_id":"7","keyword_de":"R\u00f6mische Kaiserzeit, 1. Jh. v. Chr.-3. Jh.","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/7512142-6","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300020541"},{"ikmk_keyword_id":"39","keyword_de":"St\u00e4dteb\u00fcnde","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4182777-6","keyword_concept_uri":"http:\/\/nomisma.org\/id\/league"}],"timeline_themes":[{"ikmk_timeline_id":"5","timeline_item":"Griechische M\u00fcnzen in der R\u00f6mischen Kaiserzeit","description":"Als der Adoptivsohn Caesars, genannt Octavianus, im Jahre 27 v. Chr. zum Augustus erhoben wurde, merkten die griechischen Bewohner des R\u00f6mischen Reiches, dass die B\u00fcrgerkriege der sp\u00e4ten Republik vorbei waren. Das neue System des Prinzipates versprach Frieden und eindeutige Ansprechpartner in Rom, die die st\u00e4dtischen Honoratioren in das Herrschaftssystem einbanden. Die St\u00e4dte begannen wieder zu prosperieren. Die nun hergestellten st\u00e4dtischen M\u00fcnzen bestanden \u00fcberwiegend aus Bronze. Sie sind Zeugnisse des Selbstverst\u00e4ndnisses der St\u00e4dte und deren Verh\u00e4ltnis zum r\u00f6mischen Kaiserhaus. Die Vorderseiten trugen nun anstatt von G\u00f6tterbildern \u00fcberwiegend die Portr\u00e4ts von Angeh\u00f6rigen des Kaiserhauses. Auch die R\u00fcckseiten konnten in Bezug auf Rom gestaltet sein. Einen gr\u00f6\u00dferen Umfang nahmen hier jedoch Bilder in unmittelbarem Bezug auf die Stadt selbst ein. Am h\u00e4ufigsten waren Darstellungen der st\u00e4dtischen Gottheiten, ihrer Begleiter und Attribute. Die M\u00fcnzen sangen ein St\u00e4dtelob mit Strophen auf das ehrw\u00fcrdige Alter und die Zugeh\u00f6rigkeit zur griechischen Koin\u00e9. Sie zeigen die lokalen Heroen und Mythen. Der Schmuck der Stadt mit Architektur und ber\u00fchmten Skulpturen ist auf den M\u00fcnzen zu sehen. Homer, Herodot und andere Vorfahren (\u201aviri illustres\u2019) trugen zum Ruhm der Stadt bei. Mit Stolz pr\u00e4sentiert man die Festspiele und die Ehrentitel der Stadt, um die man mit anderen St\u00e4dten konkurrierte. Ab Mitte des 3. Jahrhunderts verschlechterte sich die wirtschaftliche Lage, so dass es zunehmend unattraktiv wurde, eigenes Geld zu produzieren. In der Regierungszeit des Tacitus (275\/276 n. Chr.) gaben auch die letzten Pr\u00e4georte die Herstellung st\u00e4dtischen Geldes auf. In Alexandria dagegen endet die regul\u00e4re M\u00fcnzpr\u00e4gung 295\/296 bzw. mit dem Usurpator Domitius Domitianus 297\/298 n. Chr.","year_from":"-27","year_until":"298","autor":"Weisser, Bernhard"}],"text_right":{"short":"CC BY-SA 4.0","icon":"https:\/\/licensebuttons.net\/l\/by-sa\/4.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de","en":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en"},"label":{"de":"Creative Commons Namensnennung - Weitergabe unter gleichen Bedingungen 4.0 International","en":"Creative Commons Attribution-ShareAlike 4.0 International"},"string":{"de":"Texte und Beschreibungen in diesem Online-Katalog stehen unter einer\u00a0<a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de\" target=\"_blank\">CC BY-SA 4.0<\/a> Lizenz.","en":"Texts and descriptions of this catalogue are licensed <a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en\" target=\"_blank\">CC BY-SA 4.0<\/a>."}},"lod_right":{"short":"PDM 1.0","icon":"https:\/\/licensebuttons.net\/p\/zero\/1.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de","en":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en"},"label":{"de":"Public Domain Mark 1.0","en":"Public Domain Mark 1.0"},"string":{"de":"Verwendete LOD-Identifikatoren sind <a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de\" target=\"_blank\">Public Domain Mark 1.0<\/a>\u00a0lizenziert.","en":"LOD ids used are licensed <a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en\" target=\"_blank\">Public Domain Mark 1.0<\/a>."}},"image_restriction_id":0,"image_restriction":"free","image_right":{"short":"PDM 1.0","icon":"https:\/\/licensebuttons.net\/p\/zero\/1.0\/80x15.png","url":{"de":"http