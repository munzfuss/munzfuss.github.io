d in einer Feinheit von 986\/000 entwickelte Bezeichnung. Der Name geht auf die Umschrift der venezianischen Zecchinen zur\u00fcck (Sit tibi Christe datus quem tu regis iste ducatus = Dir, Christus, sei dieses Herzogtum, welches du regierst, gegeben). Der Name Dukat bezeichnet in der Folge jene Goldm\u00fcnzen, die weiterhin diesem Standard folgen, w\u00e4hrend solche mit bald vermindertem Gewicht und geringerer Feinheit als Goldgulden benannt werden.","info_en":"","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/denomination\/801"},"date_last":"2024-12-30 14:21:27","coin_status":[{"ikmk_coin_status_id":"43","coin_status_name_de":"Markgrafschaft","coin_status_name_en":"Margraviate","coin_status_nomisma_id":""}],"mint":[{"ikmk_country_id":"19","country_ndp_url":"https:\/\/ikmk.smb.museum\/ndp\/country\/19","country_name_de":"Deutschland","country_name_en":"Germany","country_nomisma_id":"http:\/\/nomisma.org\/id\/bundesrepublik_deutschland","country_geoname_id":"http:\/\/www.geonames.org\/2921044","ikmk_region_id":"64","region_ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/region\/64","region_name":"Franken","region_nomisma_id":"","region_geoname_id":"http:\/\/www.geonames.org\/2803465","ikmk_mint_id":"102","mint_ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/location\/102","mint_name":"Bayreuth","mint_name_de":"Bayreuth","mint_name_en":null,"mint_nomisma_id":"http:\/\/nomisma.org\/id\/bayreuth","mint_geoname_id":"http:\/\/www.geonames.org\/3220845"}],"material":{"ikmk_material_id":"3","material_name_de":"Gold","material_name_en":"Gold","material_nomisma_id":"http:\/\/nomisma.org\/id\/av","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/material\/3"},"diameter":"22 mm","weight":"3.53 g","accession":"Alter Bestand (vor 1839)","access_year":"","access_type":{"ikmk_access_type_id":"6","access_type_name":"Zugang ungekl\u00e4rt","access_type_nomisma_id":"","access_type_concept_id":"","ndp_uir":"https:\/\/ikmk.smb.museum\/ndp\/accession\/6"},"provenienz_extern":"Mindestens seit um 1818 im Bestan