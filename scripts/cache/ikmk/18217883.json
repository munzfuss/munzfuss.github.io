883\/vs_opt.jpg","path_opt":"https:\/\/ikmk.smb.museum\/image\/18217883\/vs_opt.jpg","path_opt_rel":"\/data\/www\/001-ikmk\/mk-edit\/images\/n18\/18739\/vs_opt.jpg","path":"https:\/\/ikmk.smb.museum\/image\/18217883\/vs_org.jpg","path_org":"https:\/\/ikmk.smb.museum\/image\/18217883\/vs_org.jpg","image_timestamp":1643739357,"copyright":{"short":"PDM 1.0","url":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/","de":"Bilddateien sind lizenziert als&nbsp;<a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de\" target=\"_blank\">Public Domain Mark 1.0<\/a>. Berlin, M\u00fcnzkabinett der Staatlichen Museen, 18217883. Aufnahme durch Reinhard Saczewski.","en":"Image files are licensed&nbsp;<a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en\" target=\"_blank\">Public Domain Mark 1.0<\/a>. Berlin, M\u00fcnzkabinett der Staatlichen Museen, 18217883. Photographs by Reinhard Saczewski."}},"revers":{"leg_trans":"","leg_text":"PRIMI \/ REGNI PRUSS \/ HEREDIS \/ CONIUGIUM \/ FELIX \/ 28 NOV \/ 1706","image_description":"Aufschrift in sieben Zeilen. Ganz unten die Signatur des M\u00fcnzmeisters HFH (Heinrich Friedrich Halter).","foto_date":"2009-08-25","photographer":{"ikmk_photographer_id":"5","photographer_name":"Reinhard Saczewski","photographer_gnd":"","photographer_viaf":""},"path_thumbnail":"https:\/\/ikmk.smb.museum\/image\/18217883\/rs_opt.jpg","path_opt":"https:\/\/ikmk.smb.museum\/image\/18217883\/rs_opt.jpg","path_opt_rel":"\/data\/www\/001-ikmk\/mk-edit\/images\/n18\/18739\/rs_opt.jpg","path":"https:\/\/ikmk.smb.museum\/image\/18217883\/rs_org.jpg","path_org":"https:\/\/ikmk.smb.museum\/image\/18217883\/rs_org.jpg","image_timestamp":1643739357,"copyright":{"short":"PDM 1.0","url":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/","de":"Bilddateien sind lizenziert als&nbsp;<a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de\" target=\"_blank\">Public Domain Mark 1.0<\/a>. Berlin, M\u00fcnzka