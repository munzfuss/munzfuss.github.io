d-nb.info\/gnd\/137944918":"https:\/\/d-nb.info\/gnd\/137944918","https:\/\/de.wikipedia.org\/wiki\/Heinrich_III._(Hessen)":"https:\/\/de.wikipedia.org\/wiki\/Heinrich_III._(Hessen)","https:\/\/en.wikipedia.org\/wiki\/Henry_III,_Landgrave_of_Upper_Hesse":"https:\/\/en.wikipedia.org\/wiki\/Henry_III,_Landgrave_of_Upper_Hesse","https:\/\/viaf.org\/viaf\/86107292":"https:\/\/viaf.org\/viaf\/86107292","https:\/\/www.wikidata.org\/wiki\/Q87986":"https:\/\/www.wikidata.org\/wiki\/Q87986","https:\/\/ikmk.smb.museum\/ndp\/person\/785":"https:\/\/ikmk.smb.museum\/ndp\/person\/785"}}}}},"keywords":[{"ikmk_keyword_id":"18","keyword_de":"Deutschland","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4011882-4","keyword_concept_uri":"http:\/\/vocab.getty.edu\/tgn\/7000084"},{"ikmk_keyword_id":"47","keyword_de":"Heilige","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4024055-1","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300150555"},{"ikmk_keyword_id":"80","keyword_de":"Heraldik und Wappen","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4072428-1","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300077808"},{"ikmk_keyword_id":"2","keyword_de":"Mittelalter","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4129108-6","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300020756"},{"ikmk_keyword_id":"69","keyword_de":"Silber","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4133759-1","keyword_concept_uri":"http:\/\/www.nomisma.org\/id\/ar"},{"ikmk_keyword_id":"10","keyword_de":"Sp\u00e4tmittelalter, 13.-15. Jh.","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/7503823-7","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300111307"},{"ikmk_keyword_id":"34","keyword_de":"Weltliche F\u00fcrsten","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4166473-5","keyword_concept_uri":""}],"timeline_themes":[{"ikmk_timeline_id":"82","timeline_item":"Herz\u00f6ge, Grafen, F\u00fcrsten","description":"Das urspr\u00fcnglich nur dem K\u00f6nig bzw. Kaiser zustehende M\u00fcnzrecht ist seit dem 10. Jh. in Deutschland und Frankreich auch auf den weltlichen Adel \u00fcbergegangen, teils durch k\u00f6nigliche Delegation, teils infolge der Schw\u00e4che des K\u00f6nigtums durch  Usurpation und Gewohnheitsrecht. W\u00e4hrend in Frankreich die M\u00fcnzpr\u00e4gung des Adels durch das K\u00f6nigtum im Laufe der Zeit zur\u00fcckgedr\u00e4ngt und am Ende des Mittelalters ganz aufh\u00f6rte, ist sie im Gebiet des Deutschen Reiches zu einem festen Bestandteil des M\u00fcnzwesens geworden und im 13. Jh. durch das K\u00f6nigtum auch formal sanktioniert worden.","year_from":"900","year_until":"1500","autor":"Kluge, Bernd"},{"ikmk_timeline_id":"131","timeline_item":"Deutschland im Sp\u00e4tmittelalter. Silberm\u00fcnzen","description":"Die Entwicklung im Bereich der Silberm\u00fcnzen ist in Deutschland regional sehr unterschiedlich verlaufen. Bis um 1300 herrschte noch Pfennigw\u00e4hrung, bevor von Westen her h\u00f6herwertige Silberm\u00fcnzen (Groschen) Fu\u00df fassten. Eine Groschenm\u00fcnze verk\u00f6rperte - je nach Region und Wertstufe - den Wert von vier bis zw\u00f6lf Pfennigen. Anf\u00e4nglich lehnte man sich an das Vorbild des franz\u00f6sischen Gros tournois an, bevor in den Rheinlanden mit dem Albus (Wei\u00dfpfennig) ein eigener Groschenstandard geschaffen wurde.\r\nMittel- und Ostdeutschland standen unter dem Einfluss des Prager Groschens und des daran angelehnten seit ca. 1338 in Freiberg (Erzgebirge) gem\u00fcnzten Mei\u00dfner Groschens. Der Norden entwickelte mit Witten und Schillingen ein anderes System kleinerer Groschenm\u00fcnzen.\r\nS\u00fcdlich des Mains (Bayern, Schwaben) spielten neben den Importen b\u00f6hmischer Groschen das Pfennig- und Hellergeld sowie der fr\u00e4nkische Schilling die Hauptrolle. In S\u00fcdwestdeutschland (Baden-W\u00fcrttemberg), im Elsass und der Schweiz sind gegen Ende des 15. Jh. mit den Dicken gr\u00f6\u00dfere Silberm\u00fcnzen entstanden, die mit ihren sorgf\u00e4ltig geschnittenen Stempeln wieder f\u00fcr einen k\u00fcnstlerischen Anspruch in der M\u00fcnzherstellung sorgten.\r\nDie Rolle der St\u00e4dte als neuer politischer Macht zeigt sich in autonomen M\u00fcnzpr\u00e4gungen und in M\u00fcnzb\u00fcnden wie dem Wendischen M\u00fcnzverein der f\u00fchrenden Hansest\u00e4dte.","year_from":"1251","year_until":"1500","autor":"Kluge, Bernd"}],"text_right":{"short":"CC BY-SA 4.0","icon":"https:\/\/licensebuttons.net\/l\/by-sa\/4.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de","en":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en"},"label":{"de":"Creative Commons Namensnennung - Weitergabe unter gleichen Bedingungen 4.0 International","en":"Creative Commons Attribution-ShareAlike 4.0 International"},"string":{"de":"Texte und Beschreibungen in diesem Online-Katalog stehen unter einer\u00a0<a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de\" target=\"_blank\">CC BY-SA 4.0<\/a> Lizenz.","en":"Texts and descriptions of this catalogue are licensed <a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en\" target=\"_blank\">CC BY-SA 4.0<\/a>."}},"lod_right":{"short":"PDM 1.0","icon":"https:\/\/licensebuttons.net\/p\/zero\/1.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de","en":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en"},"label":{"de":"Public Domain Mark 1.0","en":"Public Domain Mark 1.0"},"string":{"de":"Verwendete LOD-Identifikatoren sind <a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de\" target=\"_blank\">Public Domain Mark 1.0<\/a>\u00a0lizenziert.","en":"LOD ids used are licensed <a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en\" target=\"_blank\">Public Domain Mark 1.0<\/a>."}},"image_restriction_id":0,"image_restriction":"free","image_right":{"short":"PDM 1.0","icon":"https:\/\/licensebuttons.net\/p\/zero\/1.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\