\/\/ikmk.smb.museum\/ndp\/person\/5213":"https:\/\/ikmk.smb.museum\/ndp\/person\/5213"}}}}},"keywords":[{"ikmk_keyword_id":"90","keyword_de":"16. Jh.","keyword_gnd_uri":"","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300404510"},{"ikmk_keyword_id":"78","keyword_de":"Ber\u00fchmte Pers\u00f6nlichkeiten","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4044257-3","keyword_concept_uri":""},{"ikmk_keyword_id":"18","keyword_de":"Deutschland","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4011882-4","keyword_concept_uri":"http:\/\/vocab.getty.edu\/tgn\/7000084"},{"ikmk_keyword_id":"37","keyword_de":"Geistliche F\u00fcrsten","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4156371-2","keyword_concept_uri":"https:\/\/nomisma.org\/id\/clergy"},{"ikmk_keyword_id":"70","keyword_de":"Gold","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4157819-3","keyword_concept_uri":"http:\/\/www.nomisma.org\/id\/av"},{"ikmk_keyword_id":"47","keyword_de":"Heilige","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4024055-1","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300150555"},{"ikmk_keyword_id":"80","keyword_de":"Heraldik und Wappen","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4072428-1","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300077808"},{"ikmk_keyword_id":"3","keyword_de":"Neuzeit","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4171678-4","keyword_concept_uri":""}],"timeline_themes":[{"ikmk_timeline_id":"90","timeline_item":"Am Ende des Mittelalters","description":"Neben die einfachen M\u00fcnzen des Geldverkehrs traten im Laufe des 15. Jh. in Europa die Kategorien besonders werthoher M\u00fcnzen und von M\u00fcnzen mit Repr\u00e4sentationsauftrag. K\u00fcnstlerisch ansprechende Bilder, Sorgfalt des Stempelschnitts und der technischen Herstellung zeichnen sie aus. Eine besondere Rolle spielte dabei der pers\u00f6nlich an der M\u00fcnzpr\u00e4gung interessierte Erzherzog Sigismund der M\u00fcnzreiche von Tirol (1439-1496) und die von ihm 1477 in Hall\/Tirol gegr\u00fcndete M\u00fcnzst\u00e4tte. Dort ist 1486 der Taler \u201eerfunden\u201c worden, und bis ins 17. Jh. war Hall der technisch f\u00fchrende M\u00fcnzbetrieb Europas.","year_from":"1450","year_until":"1520","autor":"Kluge, Bernd"},{"ikmk_timeline_id":"133","timeline_item":"Goldm\u00fcnzen im Deutschen Reich","description":"Im ersten Viertel des 16. Jh. ist allerorten ein W\u00e4hrungsumbruch sp\u00fcrbar \u2013 weg von den einfachen Groschen und Pfennigm\u00fcnzen des Mittelalters hin zu den st\u00e4rker gestaffelten M\u00fcnzsystemen der Neuzeit. Nicht immer sind es in erster Linie geldgeschichtliche Erfordernisse, die hinter der Ausgabe der neuen M\u00fcnzen stehen. Insbesondere bei den zahlreichen kleinen M\u00fcnzherren des Reiches bricht sich in der Ausgabe von Goldgulden und Dukaten eher das neue Repr\u00e4sentationsbed\u00fcrfnis der Renaissance Bahn. Man war sich der Kostbarkeit des Materials bewusst und stellte unter Beweis, dass man zu einer Elite geh\u00f6rte, der vom Kaiser das Recht einger\u00e4umt worden war, Goldm\u00fcnzen zu pr\u00e4gen.","year_from":"1500","year_until":"1525","autor":"Kluge"}],"text_right":{"short":"CC BY-SA 4.0","icon":"https:\/\/licensebuttons.net\/l\/by-sa\/4.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de","en":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en"},"label":{"de":"Creative Commons Namensnennung - Weitergabe unter gleichen Bedingungen 4.0 International","en":"Creative Commons Attribution-ShareAlike 4.0 International"},"string":{"de":"Texte und Beschreibungen in diesem Online-Katalog stehen unter einer\u00a0<a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de\" target=\"_blank\">CC BY-SA 4.0<\/a> Lizenz.","en":"Texts and descriptions of this catalogue are licensed <a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en\" target=\"_blank\">CC BY-SA 4.0<\/a>."}},"lod_right":{"short":"PDM 1.0","icon":"https:\/\/licensebuttons.net\/p\/zero\/1.0\/80x15.p