ction\/term\/BIOG27861":"https:\/\/www.britishmuseum.org\/collection\/term\/BIOG27861","https:\/\/www.wikidata.org\/wiki\/Q33550":"https:\/\/www.wikidata.org\/wiki\/Q33550","https:\/\/ikmk.smb.museum\/ndp\/person\/668":"https:\/\/ikmk.smb.museum\/ndp\/person\/668"}}}},"125":{"ikmk_type_id":"125","type_name_de":"Ver\u00e4u\u00dferer (an Museum)","type_name_en":"Vendor (to Museum)","type_nomisma_id":"","type_concept_id":"http:\/\/d-nb.info\/gnd\/4126928-7","ndp_id":"https:\/\/ikmk.smb.museum\/ndp\/type_for_person_and_corporation\/125","items":{"4739":{"ikmk_person_id":"4739","title_de":null,"first_name_de":"Rudolf","last_name_de":"Kube","vitalDates":null,"title_en":null,"first_name_en":"Rudolf","last_name_en":"Kube","corporation":"0","lod":{"https:\/\/ikmk.smb.museum\/ndp\/person\/4739":"https:\/\/ikmk.smb.museum\/ndp\/person\/4739"}}}}},"keywords":[{"ikmk_keyword_id":"79","keyword_de":"18. Jh.","keyword_gnd_uri":"","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300404512"},{"ikmk_keyword_id":"72","keyword_de":"Andere Metalle und Legierungen","keyword_gnd_uri":"","keyword_concept_uri":""},{"ikmk_keyword_id":"16","keyword_de":"Berlin","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4005728-8","keyword_concept_uri":"http:\/\/www.nomisma.org\/id\/berlin"},{"ikmk_keyword_id":"17","keyword_de":"Brandenburg-Preussen (-1918)","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4047194-9","keyword_concept_uri":""},{"ikmk_keyword_id":"18","keyword_de":"Deutschland","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4011882-4","keyword_concept_uri":"http:\/\/vocab.getty.edu\/tgn\/7000084"},{"ikmk_keyword_id":"60","keyword_de":"Gegenstempel, Erasionen u.a.","keyword_gnd_uri":"","keyword_concept_uri":""},{"ikmk_keyword_id":"80","keyword_de":"Heraldik und Wappen","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4072428-1","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300077808"},{"ikmk_keyword_id":"33","keyword_de":"K\u00f6nige (MA&NZ)","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4031516-2","keyword_concept_uri":""},{"ikmk_keyword_id":"3","keyword_de":"Neuzeit","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4171678-4","keyword_concept_uri":""},{"ikmk_keyword_id":"43","keyword_de":"Portr\u00e4ts","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4006627-7","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300015637"}],"timeline_themes":[{"ikmk_timeline_id":"142","timeline_item":"Provinzialm\u00fcnzen in Brandenburg-Preu\u00dfen","description":"Brandenburg-Preu\u00dfen umfa\u00dfte neben dem Kernland Brandenburg (mit Altmark und Neumark) seit dem 17. Jahrhundert auch weit im Osten (Preu\u00dfen) und Westen (Cleve, Mark, Ravensberg) liegende Gebiete, die nach ganz verschiedenen M\u00fcnzsystemen rechneten. Dem trugen die 'Landm\u00fcnzen' (Provinzialm\u00fcnzen) Rechnung, die im Gegensatz zu dem einheitlichen Silberkurant auf die \u00f6rtlichen Verh\u00e4ltnisse abgestimmt waren und meist aus geringwertiger Silberlegierung (Billon), sp\u00e4ter auch aus Kupferbestanden. In Brandenburg basierten die Landesm\u00fcnzen auf Pfennig und Groschen, in Schlesien auf Kreuzer und Gr\u00f6schel, in Ostpreu\u00dfen auf dem Schilling, im Westen auf St\u00fcber und Groschen. Groschen war auch nicht gleich Groschen. Der Groschen Brandenburgs war der Gute Groschen (1\/24 Taler), der Groschen im Westen war der Mariengroschen (1\/36 Taler). In ganz Preu\u00dfen einheitliche Landesm\u00fcnzen wurden erst mit dem M\u00fcnzgesetz von 1821\/22 eingef\u00fchrt.","year_from":"1620","year_until":"1822","autor":"Kluge, Bernd"},{"ikmk_timeline_id":"145","timeline_item":"K\u00f6nig Friedrich II. der Gro\u00dfe von Preu\u00dfen","description":"Nicht nur wegen der territorialen Erweiterung Preu\u00dfens und der langen Regierungszeit hat Friedrich II. (1740-1786) das gr\u00f6\u00dfte numismatische Erbe Preu\u00dfens hinterlassen. Er ist auch m\u00fcnzgeschichtlich der bedeutendste der preu\u00dfischen K\u00f6nige. Im Jahre 1750 wurde durch den von ihm berufenen Generalm\u00fcnzdirektor Johann Philipp Grauman (Graumann) eine durchgreifende Neuordnung des M\u00fcnzwesens vorgenommen. Die Basis bildete nunmehr ein 14-Talerfu\u00df, d. h. aus der Mark Silber zu 233,86 g sollten 14 Taler gepr\u00e4gt werden. In der Hoffnung, dass der neue Taler sich auch au\u00dferhalb Preu\u00dfens durchsetzen w\u00fcrde, ist vollmundig die Bezeichnung 'Reichstaler' gew\u00e4hlt worden. Mit der Einf\u00fchrung des neuen M\u00fcnzfu\u00dfes war zugleich eine Reorganisation der preu\u00dfischen M\u00fcnzst\u00e4tten verbunden, die fortan mit einem Buchstaben anstelle der M\u00fcnzmeisterinitialen auf den M\u00fcnzen signierten. In der Reihenfolge ihrer Reorganisation erhielten die preu\u00dfischen M\u00fcnzst\u00e4tten die Buchstaben: A Berlin, B Breslau, C Cleve, D Aurich, E K\u00f6nigsberg, F Magdeburg, G Stettin. 1764 ist der sog. 'Graumansche M\u00fcnzfu\u00df' verbessert worden und galt nun f\u00fcr alle Silberm\u00fcnzen vom Taler bis zum Doppelgroschen. In allen M\u00fcnzst\u00e4tten wurden die M\u00fcnzen nach einem einheitlichem Bildtyp gepr\u00e4gt. Die Scheidem\u00fcnzen blieben den Erfordernissen der einzelnen Provinzen angepasst. Zu Exportzwecken und f\u00fcr den Fernhandel sind sog. Handelsm\u00fcnzen hergestellt worden, die sich durch ungew\u00f6hnliche M\u00fcnzbilder auszeichnen und wegen ihrer geringen Pr\u00e4gezahl zu den besonderen Seltenheiten z\u00e4hlen.","year_from":"1740","year_until":"1786","autor":"Kluge, Bernd"}],"secondary_treatment":[{"ikmk_secondary_treatment_id":"25","item_de":"beschriftet (per Hand)","item_en":"inscribed upon (by hand)","description_de":"Ein Objekt ist von Hand mit Tinte, Tusche etc. beschriftet worden.","description_en":"An object has been inscribed by hand with ink etc.","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/secondary_treatment\/25"}],"text_right":{"short":"CC BY-SA 4.0","icon":"https:\/\/licensebuttons.net\/l\/by-sa\/4.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de","en":"h