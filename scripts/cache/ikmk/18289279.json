mk\/mk-edit\/images\/n93\/93708\/vs_opt.jpg","path":"https:\/\/ikmk.smb.museum\/image\/18289279\/vs_org.jpg","path_org":"https:\/\/ikmk.smb.museum\/image\/18289279\/vs_org.jpg","image_timestamp":1646825395,"copyright":{"short":"PDM 1.0","url":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/","de":"Bilddateien sind lizenziert als&nbsp;<a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de\" target=\"_blank\">Public Domain Mark 1.0<\/a>. Berlin, M\u00fcnzkabinett der Staatlichen Museen, 18289279. Aufnahme durch Karsten Dahmen.","en":"Image files are licensed&nbsp;<a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en\" target=\"_blank\">Public Domain Mark 1.0<\/a>. Berlin, M\u00fcnzkabinett der Staatlichen Museen, 18289279. Photographs by Karsten Dahmen."}},"revers":{"leg_trans":"","leg_text":"SOLIS FAS CERNERE SOLEM \/\/ AVOCATS AUX \/ CONSEILS DU ROY \/ 1725","image_description":"Drei Adler fliegen \u00fcber ein Welle nach links der Sonne entgegen.","foto_date":"2022-02-23","photographer":{"ikmk_photographer_id":"16","photographer_name":"Karsten Dahmen","photographer_gnd":"http:\/\/d-nb.info\/gnd\/1018908900","photographer_viaf":"https:\/\/viaf.org\/viaf\/5240736"},"path_thumbnail":"https:\/\/ikmk.smb.museum\/image\/18289279\/rs_opt.jpg","path_opt":"https:\/\/ikmk.smb.museum\/image\/18289279\/rs_opt.jpg","path_opt_rel":"\/data\/www\/001-ikmk\/mk-edit\/images\/n93\/93708\/rs_opt.jpg","path":"https:\/\/ikmk.smb.museum\/image\/18289279\/rs_org.jpg","path_org":"https:\/\/ikmk.smb.museum\/image\/18289279\/rs_org.jpg","image_timestamp":1646825548,"copyright":{"short":"PDM 1.0","url":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/","de":"Bilddateien sind lizenziert als&nbsp;<a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de\" target=\"_blank\">Public Domain Mark 1.0<\/a>. Berlin, M\u00fcnzkabinett der Staatlichen Museen, 18289279. Aufnahme durch Karsten Dahmen.","en":"Image files are licensed&nbsp;<a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en\" target=\"_blank\">Public Domain Mark 1.0<\/a>. Berlin, M\u00fcnzkabinett der Staatlichen Museen, 18289279. Photographs by Karsten Dahmen."}},"edge":"Riffelrand","division":{"ikmk_division_id":"3","division_name_de":"Neuzeit","division_name_en":"Modern Period"},"sub_division":{"ikmk_subdivision_id":"24","subdivision_name_de":"18. Jh.","subdivision_name_en":"18th century"},"literatur":"F. Feuardent, Collection Feuardent. Jetons et m\u00e9reaux I-III (1904-1915) Nr. 359.","comment":"Die Bildkomposition und die Devise der R\u00fcckseite dieses Jetons stammen aus der Zeit des \u201eSonnenk\u00f6nigs\u201c Ludwig XIV. In Kombination verwendet wurde beides auf einem Jeton von 1683, dessen Pr\u00e4gung vierzig Jahre nach dem Erlass eines Edikts erfolgte, durch das die Anw\u00e4lte bei den k\u00f6niglichen R\u00e4ten das Alleinvertretungsrecht erhielten. Die Sonne war in der Fr\u00fchzeit von Ludwigs Herrschaft das zentrale Symbol der monarchischen Selbstdarstellung. In der offiziellen Herrschaftsrepr\u00e4sentation wurde Ludwig mit der Sonne verglichen oder gar gleichgesetzt. Die Sonne ist auch ein Symbol f\u00fcr die Gerechtigkeit, etwa im Alten Testament im Buch des Propheten Maleachi. Dass allein die Anw\u00e4lte in der Lage seien, zu erkennen, was sich im Licht der Sonne als wahr und gerecht erweist, ist eine Behauptung, die von einem hohen Selbstbewusstsein des Anwaltsstandes getragen ist.","period":{"ikmk_period_id":"13","name_de":"Barock","name_en":"Baroque","description_de":"Kunst bzw- Stilperiode, welche mit regional unterschiedlichen Entwicklungen die Zeit vom Ende des 16. Jahrhunderts ist ca. 1730 umfasst. Teilweise wird der Rokoko (bis ca. 1770) ihr auch zugerechnet.","description_en":"Art period with a regionally varying developement in chronological terms roughly from the end of the 16th century to c. 1730. Sometimes the following period Rococo (to c. 1770) is considered a late form of Baroque.","concept_id":"http:\/\/vocab.getty.edu\/aat\/300021147","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/period\/13"},"year_start":"1725","year_end":"1725","date_verbal":"1725","year_islam":"0","manufacturing":[{"ikmk_manufacturing_id":"21","manufacturing_name_de":"gepr\u00e4gt","manufacturing_name_en":"struck","nomisma_id":"http:\/\/nomisma.org\/id\/struck","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/manufacture\/21"}],"linked_persons_corporations":{"50":{"ikmk_type_id":"50","type_name_de":"Vorbesitzer","type_name_en":"previous Owner","type_nomisma_id":"","type_concept_id":"http:\/\/d-nb.info\/gnd\/4447273-0","ndp_id":"https:\/\/ikmk.smb.museum\/ndp\/type_for_person_and_corporation\/50","items":{"10152":{"ikmk_person_id":"10152","title_de":"Prof. Dr.","first_name_de":"Thomas","last_name_de":"W\u00fcrtenberger","vitalDates":"27.01.1943-","title_en":null,"first_name_en":"Thomas","last_name_en":"W\u00fcrtenberger","corporation":"0","lod":{"https:\/\/d-nb.info\/gnd\/118635484":"https:\/\/d-nb.info\/gnd\/118635484","https:\/\/viaf.org\/viaf\/37043901":"https:\/\/viaf.org\/viaf\/37043901","https:\/\/www.wikidata.org\/wiki\/Q1307657":"https:\/\/www.wikidata.org\/wiki\/Q1307657","https:\/\/ikmk.smb.museum\/ndp\/person\/10152":"https:\/\/ikmk.smb.museum\/ndp\/person\/10152"},"year_from":"0","year_until":"2021"}}},"54":{"ikmk_type_id":"54","type_name_de":"Dargestellte\/r","type_name_en":"Sitter","type_nomisma_id":"http:\/\/nomisma.org\/id\/portrait","type_concept_id":"http:\/\/vocab.getty.edu\/aat\/300189844","ndp_id":"https:\/\/ikmk.smb.museum\/ndp\/type_for_person_and_corporation\/54","items":{"1129":{"ikmk_person_id":"1129","title_de":null,"first_name_de":null,"last_name_de":"Ludwig XV. (1715-1774), K\u00f6nig von Frankreich","vitalDates":"25.02.1710 - 10.05.1774","title_en":null,"first_name_en":null,"last_name_en":"Louis XV (1715-1774), king of France","corporation":"0","lod":{"https:\/\/d-nb.info\/gnd\/118729438":"https:\/\/d-nb.info\/gnd\/118729438","https:\/\/