ikidata.org\/wiki\/Q325784","https:\/\/ikmk.smb.museum\/ndp\/person\/719":"https:\/\/ikmk.smb.museum\/ndp\/person\/719"}}}}},"keywords":[{"ikmk_keyword_id":"12","keyword_de":"17. Jh.","keyword_gnd_uri":"","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300404511"},{"ikmk_keyword_id":"70","keyword_de":"Gold","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4157819-3","keyword_concept_uri":"http:\/\/www.nomisma.org\/id\/av"},{"ikmk_keyword_id":"80","keyword_de":"Heraldik und Wappen","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4072428-1","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300077808"},{"ikmk_keyword_id":"3","keyword_de":"Neuzeit","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4171678-4","keyword_concept_uri":""},{"ikmk_keyword_id":"20","keyword_de":"Osteuropa","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4075739-0","keyword_concept_uri":"http:\/\/vocab.getty.edu\/tgn\/4003756"},{"ikmk_keyword_id":"43","keyword_de":"Portr\u00e4ts","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4006627-7","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300015637"},{"ikmk_keyword_id":"34","keyword_de":"Weltliche F\u00fcrsten","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4166473-5","keyword_concept_uri":""}],"timeline_themes":[{"ikmk_timeline_id":"59","timeline_item":"Europa. Donative 16.-18. Jh.","description":"Donative sind Geschenk- oder Verehrm\u00fcnzen mit und ohne Gedenkcharakter. Zur Belohnung gepr\u00e4gte Mehrfachaurei und Medaillone kennt bereits die Antike (Thema 40\/41). Eine numismatische Spezialit\u00e4t in Renaissance und Barock waren Donative, die parallel zu den auch als Gnadenpfennige bezeichneten Medaillenkleinoden im Deutschen Reich, aber auch von F\u00fcrsten und reichen St\u00e4dten Europas ausgegeben wurden. Es sind zumeist Mehrfachst\u00fccke oder Abschl\u00e4ge von Goldnominalen. Dickst\u00fccke von Gro\u00dfsilberm\u00fcnzen waren schon durch ihre Form und extreme Seltenheit nicht f\u00fcr den Geldverkehr gedacht. Einen Sonderfall stellen die bis zum 16fachen eines Talers aus dem Silber des Harzes gepr\u00e4gten L\u00f6ser der Braunschweiger Herz\u00f6ge dar. Schon zum Zeitpunkt ihrer Ausgabe als materielle Kostbarkeiten und ideelle Rarit\u00e4ten begehrt, geh\u00f6ren Donative heute zum besonderen Schatz eines jeden M\u00fcnzkabinetts.","year_from":"1501","year_until":"1800","autor":"Steguweit, Wolfgang"}],"secondary_treatment":[{"ikmk_secondary_treatment_id":"34","item_de":"Stempelumschnitt","item_en":"Recut die","description_de":"Ein bereits zur Herstellung von M\u00fcnzen, Medaillen oder Marken verwendeter Stempel wurde in der Folge umgeschnitten, etwa um Sch\u00e4den im Stempel auszugleichen oder Motiv bzw. Aufschrift zu modifizieren.","description_en":"Secondary re-engraving of a die after it has already been used to strike coins, medals, or tokens, e.g. to repair defects in the die or modify its design.","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/secondary_treatment\/34","concept":["http:\/\/nomisma.org\/id\/recut_die"]}],"text_right":{"short":"CC BY-SA 4.0","icon":"https:\/\/licensebuttons.net\/l\/by-sa\/4.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de","en":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en"},"label":{"de":"Creative Commons Namensnennung - Weitergabe unter gleichen Bedingungen 4.0 International","en":"Creative Commons Attribution-ShareAlike 4.0 International"},"string":{"de":"Texte und Beschreibungen in diesem Online-Katalog stehen unter einer\u00a0<a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de\" target=\"_blank\">CC BY-SA 4.0<\/a> Lizenz.","en":"Texts and descriptions of this catalogue are licensed <a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en\" target=\"_blank\">CC BY-SA 4.0<\/a>."}},"lod_right":{"short":"PDM 1.0","icon":"https:\/\/licensebuttons.net\/p\/zero\/1.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de","en":"https:\/\/creativecomm