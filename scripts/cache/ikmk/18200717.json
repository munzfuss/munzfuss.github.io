ury and developes into the Baroque around 1550.","concept_id":"http:\/\/vocab.getty.edu\/aat\/300021140","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/period\/7"},"year_start":"1608","year_end":"1619","date_verbal":"1608-1619","year_islam":"0","manufacturing":[{"ikmk_manufacturing_id":"22","manufacturing_name_de":"gegossen","manufacturing_name_en":"cast","nomisma_id":"http:\/\/nomisma.org\/id\/cast","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/manufacture\/22"}],"linked_persons_corporations":{"49":{"ikmk_type_id":"49","type_name_de":"Medailleur\/in","type_name_en":"Medalist","type_nomisma_id":"http:\/\/nomisma.org\/id\/medalist","type_concept_id":"http:\/\/d-nb.info\/gnd\/4306105-9","ndp_id":"https:\/\/ikmk.smb.museum\/ndp\/type_for_person_and_corporation\/49","items":{"3965":{"ikmk_person_id":"3965","title_de":null,"first_name_de":"Matth\u00e4us","last_name_de":"Carl","vitalDates":"1554-1609","title_en":null,"first_name_en":"Matth\u00e4us","last_name_en":"Carl","corporation":"0","lod":{"https:\/\/d-nb.info\/gnd\/135707986":"https:\/\/d-nb.info\/gnd\/135707986","https:\/\/viaf.org\/viaf\/18447301":"https:\/\/viaf.org\/viaf\/18447301","https:\/\/www.wikidata.org\/wiki\/Q1910508":"https:\/\/www.wikidata.org\/wiki\/Q1910508","https:\/\/ikmk.smb.museum\/ndp\/person\/3965":"https:\/\/ikmk.smb.museum\/ndp\/person\/3965"}}}},"50":{"ikmk_type_id":"50","type_name_de":"Vorbesitzer","type_name_en":"previous Owner","type_nomisma_id":"","type_concept_id":"http:\/\/d-nb.info\/gnd\/4447273-0","ndp_id":"https:\/\/ikmk.smb.museum\/ndp\/type_for_person_and_corporation\/50","items":{"5595":{"ikmk_person_id":"5595","title_de":null,"first_name_de":"Immanuel Christian Leberecht von","last_name_de":"Ampach","vitalDates":"11.12.1772 - 05.06.1831","title_en":null,"first_name_en":"Immanuel Christian Leberecht von","last_name_en":"Ampach","corporation":"0","lod":{"https:\/\/d-nb.info\/gnd\/116302097":"https:\/\/d-nb.info\/gnd\/116302097","https:\/\/de.wikipedia.org\/wiki\/Immanuel_Christian_Lebere