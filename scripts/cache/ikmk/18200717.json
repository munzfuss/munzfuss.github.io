mk.smb.museum\/ndp\/type_for_person_and_corporation\/125","items":{"6374":{"ikmk_person_id":"6374","title_de":null,"first_name_de":"Johann Friedrich","last_name_de":"Weidhas","vitalDates":null,"title_en":null,"first_name_en":"Johann Friedrich","last_name_en":"Weidhas","corporation":"0","lod":{"https:\/\/d-nb.info\/gnd\/101444206":"https:\/\/d-nb.info\/gnd\/101444206","https:\/\/viaf.org\/viaf\/12671686":"https:\/\/viaf.org\/viaf\/12671686","https:\/\/ikmk.smb.museum\/ndp\/person\/6374":"https:\/\/ikmk.smb.museum\/ndp\/person\/6374"}}}}},"keywords":[{"ikmk_keyword_id":"12","keyword_de":"17. Jh.","keyword_gnd_uri":"","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300404511"},{"ikmk_keyword_id":"17","keyword_de":"Brandenburg-Preussen (-1918)","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4047194-9","keyword_concept_uri":""},{"ikmk_keyword_id":"18","keyword_de":"Deutschland","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4011882-4","keyword_concept_uri":"http:\/\/vocab.getty.edu\/tgn\/7000084"},{"ikmk_keyword_id":"70","keyword_de":"Gold","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4157819-3","keyword_concept_uri":"http:\/\/www.nomisma.org\/id\/av"},{"ikmk_keyword_id":"80","keyword_de":"Heraldik und Wappen","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4072428-1","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300077808"},{"ikmk_keyword_id":"64","keyword_de":"Medaillen","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4038206-0","keyword_concept_uri":"http:\/\/www.nomisma.org\/id\/medal"},{"ikmk_keyword_id":"61","keyword_de":"M\u00fcnzschmuck und Schmuckm\u00fcnzen","keyword_gnd_uri":"","keyword_concept_uri":""},{"ikmk_keyword_id":"3","keyword_de":"Neuzeit","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4171678-4","keyword_concept_uri":""},{"ikmk_keyword_id":"43","keyword_de":"Portr\u00e4ts","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4006627-7","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300015637"},{"ikmk_keyword_id":"34","keyword_de":"Weltliche F\u00fcrsten","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4166473-5","keyword_concept_uri":""}],"timeline_themes":[{"ikmk_timeline_id":"68","timeline_item":"Medaillen Brandenburg-Preu\u00dfen 16.-20. Jh.","description":"Bis zum ausgehenden 18. Jh. gedieh die Medaille in Brandenburg-Preu\u00dfen im Rahmen der h\u00f6fischen Repr\u00e4sentation und wurde je nach Bedarf im eigenen Lande gef\u00f6rdert oder importiert. Die dynastische Verbindung mit den fr\u00e4nkischen Linien der Hohenzollern hat in der Renaissance erstrangige k\u00fcnstlerische Leistungen s\u00fcddeutscher Meister hervorgebracht. Kostbar gefasste Kleinode sind eine Sonderform der Sp\u00e4trenaissance um 1600. Die Ereignismedaille, allegorisch \u00fcberh\u00f6ht, wurde im Barock popul\u00e4r. 1690 erhielt Raimund Faltz die Berufung als Medailleur nach Berlin. Trotz k\u00f6niglichen Desinteresses haben im 18. Jh. international renommierte Medailleure in Berlin gewirkt, wie der Schweizer Hedlinger und dessen Sch\u00fcler, der Schwede Georgi. Unter Friedrich Wilhelm III. begann Ende des 18. Jh. ein Aufschwung im Medaillenschaffen, der auch unter den nachfolgenden K\u00f6nigen anhielt. Abramson und die Medailleurfamilie Loos, der \u00d6sterreicher Posch und der Schweizer Brandt waren mit der K\u00f6niglichen M\u00fcnze in Berlin verbunden, ebenso wie einheimische Medailleure um Fischer und Pfeuffer. Bei aller Wertsch\u00e4tzung seitens der Regenten wurde der b\u00fcrgerliche Einfluss durch die enge Verbindung von Kunst, Handwerk und Gewerbe f\u00fcr die weitere k\u00fcnstlerische Entwicklung der Medaille bestimmend.","year_from":"1501","year_until":"1918","autor":"Steguweit, Wolfgang"}],"secondary_treatment":[{"ikmk_secondary_treatment_id":"28","item_de":"gefasst","item_en":"mounted","description_de":"Nachtr\u00e4glich mit einer Fassung versehen.","description_en":"Mounted in such a way that the coin or medal has become part of a new object.","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/secondary_treatment\/28","concept":[