lte Bezeichnung. Der Name geht auf die Umschrift der venezianischen Zecchinen zur\u00fcck (Sit tibi Christe datus quem tu regis iste ducatus = Dir, Christus, sei dieses Herzogtum, welches du regierst, gegeben). Der Name Dukat bezeichnet in der Folge jene Goldm\u00fcnzen, die weiterhin diesem Standard folgen, w\u00e4hrend solche mit bald vermindertem Gewicht und geringerer Feinheit als Goldgulden benannt werden.","info_en":"","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/denomination\/801"},"patronage":"N. N.","date_last":"2023-03-14 01:49:51","coin_status":[{"ikmk_coin_status_id":"41","coin_status_name_de":"Kurf\u00fcrstentum","coin_status_name_en":"Electorate","coin_status_nomisma_id":""}],"mint":[{"ikmk_country_id":"19","country_ndp_url":"https:\/\/ikmk.smb.museum\/ndp\/country\/19","country_name_de":"Deutschland","country_name_en":"Germany","country_nomisma_id":"http:\/\/nomisma.org\/id\/bundesrepublik_deutschland","country_geoname_id":"http:\/\/www.geonames.org\/2921044","ikmk_region_id":"52","region_ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/region\/52","region_name":"Anhalt","region_nomisma_id":"","region_geoname_id":"","ikmk_mint_id":"167","mint_ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/location\/167","mint_name":"Halberstadt","mint_name_de":"Halberstadt","mint_name_en":null,"mint_nomisma_id":"http:\/\/nomisma.org\/id\/halberstadt","mint_geoname_id":"http:\/\/www.geonames.org\/2911665"}],"material":{"ikmk_material_id":"3","material_name_de":"Gold","material_name_en":"Gold","material_nomisma_id":"http:\/\/nomisma.org\/id\/av","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/material\/3"},"diameter":"22 mm","die_axis":"12 h","weight":"3.45 g","accession":"1908\/45","access_year":"1908","access_type":{"ikmk_access_type_id":"1","access_type_name":"Kauf","access_type_nomisma_id":"","access_type_concept_id":"http:\/\/d-nb.info\/gnd\/4128692-3","ndp_uir":"https:\/\/ikmk.smb.museum\/ndp\/accession\/1"},"provenienz_extern":"","acquisition_date":"","avers":{"leg_trans":"","leg_t