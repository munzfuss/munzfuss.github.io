/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en\" target=\"_blank\">Public Domain Mark 1.0<\/a>. Berlin, M\u00fcnzkabinett der Staatlichen Museen, 18214785. Photographs by Reinhard Saczewski."}},"revers":{"leg_trans":"9 f\u00fcr -VS. Wenn Gott mit uns ist, wer ist dann gegen uns","leg_text":"SI DE9 PRO NOBIS QVIS CONTRA NOS","image_description":"Blumenkreuz, auf der Mitte der brandenburgische Schild, rechts in den Winkeln die Schilde von Schlesien und Pommern, links der Burggrafschaft N\u00fcrnberg und Zollern, oben M\u00fcnzmeisterzeichen (Dreiblatt).","foto_date":"2008-08-07","photographer":{"ikmk_photographer_id":"5","photographer_name":"Reinhard Saczewski","photographer_gnd":"","photographer_viaf":""},"path_thumbnail":"https:\/\/ikmk.smb.museum\/image\/18214785\/rs_opt.jpg","path_opt":"https:\/\/ikmk.smb.museum\/image\/18214785\/rs_opt.jpg","path_opt_rel":"\/data\/www\/001-ikmk\/mk-edit\/images\/n14\/14864\/rs_opt.jpg","path":"https:\/\/ikmk.smb.museum\/image\/18214785\/rs_org.jpg","path_org":"https:\/\/ikmk.smb.museum\/image\/18214785\/rs_org.jpg","image_timestamp":1643735119,"copyright":{"short":"PDM 1.0","url":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/","de":"Bilddateien sind lizenziert als&nbsp;<a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de\" target=\"_blank\">Public Domain Mark 1.0<\/a>. Berlin, M\u00fcnzkabinett der Staatlichen Museen, 18214785. Aufnahme durch Reinhard Saczewski.","en":"Image files are licensed&nbsp;<a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en\" target=\"_blank\">Public Domain Mark 1.0<\/a>. Berlin, M\u00fcnzkabinett der Staatlichen Museen, 18214785. Photographs by Reinhard Saczewski."}},"division":{"ikmk_division_id":"3","division_name_de":"Neuzeit","division_name_en":"Modern Period"},"sub_division":{"ikmk_subdivision_id":"25","subdivision_name_de":"16. Jh.","subdivision_name_en":"16th century"},"literatur":"F. Freiherr von Schr\u00f6tter, Brandenburg-Fr\u00e4nkisches M\u00fcnzwesen II (1929) Nr. 792 (dieses Exemplar); A. Brause-Mansfeld, Feld-, Noth- und Belagerungsm\u00fcnzen von Deutschland, \u00d6sterreich-Ungarn, Siebenb\u00fcrgen, Moldau, D\u00e4nemark, Schweden, Norwegen, Russland, Polen usw. (1897) 7 Taf. 3,9 (dieses Exemplar).","comment":"Dieses St\u00fcck, als Denkm\u00fcnze auf den Pfaffenkrieg bezeichnet, stammt aus der Markgr\u00e4flich-Ansbacher Sammlung. F\u00fcr die R\u00fcckseite der M\u00fcnze wurde der Stempel der Vierteltaler von 1549 verwandt. Die Stempel entstanden unter den M\u00fcnzmeistern Hans und Andreas Zehenntner, die Pr\u00e4gung von 1553 aber erst unter dem M\u00fcnzmeister Anton Coburger 1553 zu Erlangen. Der Pfaffen- oder Markgr\u00e4flerkrieg f\u00fchrte in seinem Ergebnis dazu, dass \u00fcber Albrecht Alcibiades die Reichsacht verh\u00e4ngt wurde und er aus seinen Landen fliehen musste. 1557 gingen seine Besitzungen an Georg Friedrich, den Markgrafen von Brandenburg-Ansbach \u00fcber. Die Plassenburg bei Kulmbach kam 1340 an die Burggrafen von N\u00fcrnberg und etwickelte sich in den folgenden Jahrhunderten zu einem Herrschaftszentrum der Hohenzollern. Die Notm\u00fcnzen sollen aus erbeutetem Silbergeschirr und Kirchenschmuck hergestellt worden sein. Das Berliner Exemplar ist wohl das einzig bekannte.","period":{"ikmk_period_id":"7","name_de":"Renaissance","name_en":"Renaissance","description_de":"Die Renaissance (Wiedergeburt) bezeichnet eine europ\u00e4ische Kunstperiode zwischen Mittelalter und Neuzeit im 15. und 16. Jahrhundert. Diese setzt im fr\u00fchen 15. Jahrhundert ein und wird um 1550 vom Barock abgel\u00f6st.","description_en":"The term Renaissance (rebirth) describes a period at the turn from the Middele Ages to the Modern period during the 15th and 16th century. It begins during the early 15th century and developes into the Baroque around 1550.","concept_id":"http:\/\/vocab.getty.edu\/aat\/300021140","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/period\/7"},"year_start":"1553