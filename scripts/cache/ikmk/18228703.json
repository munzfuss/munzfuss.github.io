d-nb.info\/gnd\/4005728-8","keyword_concept_uri":"http:\/\/www.nomisma.org\/id\/berlin"},{"ikmk_keyword_id":"17","keyword_de":"Brandenburg-Preussen (-1918)","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4047194-9","keyword_concept_uri":""},{"ikmk_keyword_id":"18","keyword_de":"Deutschland","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4011882-4","keyword_concept_uri":"http:\/\/vocab.getty.edu\/tgn\/7000084"},{"ikmk_keyword_id":"59","keyword_de":"Herstellung und M\u00fcnztechnik","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4727424-4","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300206581"},{"ikmk_keyword_id":"65","keyword_de":"Medailleure","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4306105-9","keyword_concept_uri":"http:\/\/www.nomisma.org\/id\/medalist"},{"ikmk_keyword_id":"62","keyword_de":"Modelle","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4039798-1","keyword_concept_uri":"http:\/\/nomisma.org\/id\/model"},{"ikmk_keyword_id":"3","keyword_de":"Neuzeit","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4171678-4","keyword_concept_uri":""},{"ikmk_keyword_id":"43","keyword_de":"Portr\u00e4ts","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4006627-7","keyword_concept_uri":"http:\/\/vocab.getty.edu\/aat\/300015637"},{"ikmk_keyword_id":"34","keyword_de":"Weltliche F\u00fcrsten","keyword_gnd_uri":"http:\/\/d-nb.info\/gnd\/4166473-5","keyword_concept_uri":""}],"timeline_themes":[{"ikmk_timeline_id":"68","timeline_item":"Medaillen Brandenburg-Preu\u00dfen 16.-20. Jh.","description":"Bis zum ausgehenden 18. Jh. gedieh die Medaille in Brandenburg-Preu\u00dfen im Rahmen der h\u00f6fischen Repr\u00e4sentation und wurde je nach Bedarf im eigenen Lande gef\u00f6rdert oder importiert. Die dynastische Verbindung mit den fr\u00e4nkischen Linien der Hohenzollern hat in der Renaissance erstrangige k\u00fcnstlerische Leistungen s\u00fcddeutscher Meister hervorgebracht. Kostbar gefasste Kleinode sind eine Sonderform der Sp\u00e4trenaissance um 1600. Die Ereignismedaille, allegorisch \u00fcberh\u00f6ht, wurde im Barock popul\u00e4r. 1690 erhielt Raimund Faltz die Berufung als Medailleur nach Berlin. Trotz k\u00f6niglichen Desinteresses haben im 18. Jh. international renommierte Medailleure in Berlin gewirkt, wie der Schweizer Hedlinger und dessen Sch\u00fcler, der Schwede Georgi. Unter Friedrich Wilhelm III. begann Ende des 18. Jh. ein Aufschwung im Medaillenschaffen, der auch unter den nachfolgenden K\u00f6nigen anhielt. Abramson und die Medailleurfamilie Loos, der \u00d6sterreicher Posch und der Schweizer Brandt waren mit der K\u00f6niglichen M\u00fcnze in Berlin verbunden, ebenso wie einheimische Medailleure um Fischer und Pfeuffer. Bei aller Wertsch\u00e4tzung seitens der Regenten wurde der b\u00fcrgerliche Einfluss durch die enge Verbindung von Kunst, Handwerk und Gewerbe f\u00fcr die weitere k\u00fcnstlerische Entwicklung der Medaille bestimmend.","year_from":"1501","year_until":"1918","autor":"Steguweit, Wolfgang"},{"ikmk_timeline_id":"64","timeline_item":"Medaillenmodelle des 17. Jh. aus Wachs","description":"Im Unterschied zur Renaissance ist Wachs das bevorzugte Modellmaterial im Barock. Ein Virtuose darin war Raimund Faltz (1658-1703). Er modellierte mit gebleichtem oder leicht rosa gef\u00e4rbtem Bienenwachs auf Schieferplatten oder geschw\u00e4rzten Glasscheiben und erzielte durch unterschiedlich starken Wachsauftrag eine fein abgestufte Plastizit\u00e4t mit transparenten Effekten. Die Wachse lieferten die originalgetreue Vorlage f\u00fcr eine positive Umsetzung des Reliefs in den Eisenstempel. Dies war eine neuartige, der Glyptik verwandte skulpturale Auffassung im Unterschied zur \u00fcblichen M\u00fcnzgravur. Der Einsatz des Balanciers erm\u00f6glichte eine differenzierte Absenkung der Patrize in den Stempel. Als Pr\u00e4gemedailleur erfuhr Faltz die k\u00fcnstlerische Vollendung in Berlin. Mit Testament setzte er kurz vor seinem Tode K\u00f6nig Friedrich I. als Erben der Modelle und Medaillenpr\u00e4gungen ein und sicherte damit den Erhalt seines Werkes.","year_from":"1685","year_until":"1703","autor":"Steguweit, Wolfgang"}],"secondary_treatment":[{"ikmk_secondary_treatment_id":"26","item_de":"Aufkleber","item_en":"adhesive label","description_de":"Ein Aufkleber oder Klebetikett ist angebracht worden.","description_en":"An adhesive label has been glued on the object.","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/secondary_treatment\/26"},{"ikmk_secondary_treatment_id":"28","item_de":"gefasst","item_en":"mounted","description_de":"Nachtr\u00e4glich mit einer Fassung versehen.","description_en":"Mounted in such a way that the coin or medal has become part of a new object.","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/secondary_treatment\/28","concept":["http:\/\/nomisma.org\/id\/mounted"]}],"text_right":{"short":"CC BY-SA 4.0","icon":"https:\/\/licensebuttons.net\/l\/by-sa\/4.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de","en":"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en"},"label":{"de":"Creative Commons Namensnennung - Weitergabe unter gleichen Bedingungen 4.0 International","en":"Creative Commons Attribution-ShareAlike 4.0 International"},"string":{"de":"Texte und Beschreibungen in diesem Online-Katalog stehen unter einer\u00a0<a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.de\" target=\"_blank\">CC BY-SA 4.0<\/a> Lizenz.","en":"Texts and descriptions of this catalogue are licensed <a href=\"https:\/\/creativecommons.org\/licenses\/by-sa\/4.0\/deed.en\" target=\"_blank\">CC BY-SA 4.0<\/a>."}},"lod_right":{"short":"PDM 1.0","icon":"https:\/\/licensebuttons.net\/p\/zero\/1.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de","en":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en"},"label":{"de":"Public Domain Mark 1.0","en":"Public Domain Mark 1.0"},"string":{"de":"Verwendete LOD-Identifikatoren sind <a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de\" target=\"_blank\">Public Domain Mark 1.0<\/a>\u00a0lizenziert.","en":"LOD ids used are licensed <a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en\" target=\"_blank\">Public Domain Mark 1.0<\/a>."}},"image_restriction_id":0,"image_restriction":"free","image_right":{"short":"PDM 1.0","icon":"https:\/\/licensebuttons.net\/p\/zero\/1.0\/80x15.png","url":{"de":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de","en":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en"},"label":{"de":"Public Domain Mark 1.0","en":"Public Domain Mark 1.0"}}}