{"ikmk_mds_id":"18214137","ikmk_id":"14247","eLearning_completed":"0","primary_source_id":"0","title":"Hadrianus","inventory_number":"","activated":"yes","item":{"ikmk_item_id":"1","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/item\/1","item_de":"M\u00fcnze","item_en":"Coin","item_nomisma":"http:\/\/nomisma.org\/id\/coin"},"permalink":"https:\/\/ikmk.smb.museum\/object?id=18214137","permalink_source":null,"publisher":{"ikmk_publisher_id":13,"ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/owner\/13","publisher_name":"M\u00fcnzkabinett, Staatliche Museen zu Berlin - Stiftung Preu\u00dfischer Kulturbesitz","publisher_isil":"http:\/\/ld.zdb-services.de\/resource\/organisations\/DE-MUS-814819","publisher_isil_short":"DE-MUS-814819","UID":"http:\/\/ld.zdb-services.de\/resource\/organisations\/DE-MUS-814819\/18214137","legalBodyWeblink":"https:\/\/www.smb.museum\/museen-und-einrichtungen\/muenzkabinett\/home.html","nomisma_address":"http:\/\/nomisma.org\/id\/mk_berlin","author":"Deissmann, Marieluise; Gorys, Andrea"},"owner":{"ikmk_owner_id":"13","owner_name":"Berlin, M\u00fcnzkabinett der Staatlichen Museen","owner_isil":"http:\/\/ld.zdb-services.de\/resource\/organisations\/DE-MUS-814819","owner_isil_short":"DE-MUS-814819","owner_www_address":"https:\/\/ikmk.smb.museum\/","nomisma_address":"http:\/\/nomisma.org\/id\/mk_berlin","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/owner\/13","owner_type":{"de":"Eigentum","en":"Property","ikmk_type_id":"2","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/status_of_property\/2"}},"ikmk_status_id":"7","status":{"de":"vorhanden","en":"present","ikmk_status_id":"7","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/object_status\/7"},"nominal":{"ikmk_nominal_id":"715","nominal_de":"Cistophor","nominal_en":"Cistophor","nominal_nomisma_id":"http:\/\/nomisma.org\/id\/cistophorus","nominal_gnd_id":"http:\/\/d-nb.info\/gnd\/4163972-8","info_de":"Als Cistophoren bezeichnet man eine Gruppe von Silberm\u00fcnzen im (Vergleich zur Tetradrachme reduzierten) Gewicht von 3 attischen Drachmen oder r\u00f6mischen Denaren zu etwa 12 g. Ihren Namen tragen sie nach dem Korb auf der Vorderseite, aus dem eine Schlange hervorkriecht (cista mystica). Sie wurden in Pergamon unter Eumenes II. f\u00fcr das pergamenische Reich als \u00fcberst\u00e4dtische W\u00e4hrung eingef\u00fchrt. 16 St\u00e4dte erhielten damals das Pr\u00e4gerecht f\u00fcr dieses Silbergeld. Kistophoren wurden \u00fcber das Ende des pergamenischen Reiches hinaus auch in der Provinz Asia durch die r\u00f6mischen Prokuratoren gepr\u00e4gt. Sp\u00e4ter sind auch M. Antonius, Augustus und andere r\u00f6mische Kaiser auf Cistophoren vertreten.","info_en":"","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/denomination\/715"},"patronage":"Anonymus","date_last":"2023-03-14 01:49:51","coin_status":[{"ikmk_coin_status_id":"29","coin_status_name_de":"Antike Herrscherpr\u00e4gung","coin_status_name_en":"Ancient Ruler's issue","coin_status_nomisma_id":"http:\/\/nomisma.org\/id\/ruler","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/class_status\/29"}],"mint":[{"ikmk_country_id":"75","country_ndp_url":"https:\/\/ikmk.smb.museum\/ndp\/country\/75","country_name_de":"T\u00fcrkei","country_name_en":"Turkey","country_nomisma_id":"","country_geoname_id":"http:\/\/www.geonames.org\/298795","ikmk_region_id":"379","region_ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/region\/379","region_name":"","region_nomisma_id":"","region_geoname_id":"","ikmk_mint_id":"872","mint_ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/location\/872","mint_name":"","mint_name_de":"","mint_name_en":null,"mint_nomisma_id":"","mint_geoname_id":""}],"material":{"ikmk_material_id":"1","material_name_de":"Silber","material_name_en":"Silver","material_nomisma_id":"http:\/\/nomisma.org\/id\/ar","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/material\/1"},"diameter":"27 mm","die_axis":"6 h","weight":"10.09 g","accession":"1907\/224","access_year":"1907","access_type":{"ikmk_access_type_id":"4","access_type_name":"\u00dcberweisung","access_type_nom