/ikmk.smb.museum\/image\/18216483\/vs_opt.jpg","path_opt":"https:\/\/ikmk.smb.museum\/image\/18216483\/vs_opt.jpg","path_opt_rel":"\/data\/www\/001-ikmk\/mk-edit\/images\/n16\/16504\/vs_opt.jpg","path":"https:\/\/ikmk.smb.museum\/image\/18216483\/vs_org.jpg","path_org":"https:\/\/ikmk.smb.museum\/image\/18216483\/vs_org.jpg","image_timestamp":1643732454,"copyright":{"short":"PDM 1.0","url":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/","de":"Bilddateien sind lizenziert als&nbsp;<a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de\" target=\"_blank\">Public Domain Mark 1.0<\/a>. Berlin, M\u00fcnzkabinett der Staatlichen Museen, 18216483. Aufnahme durch Dirk Sonnenwald.","en":"Image files are licensed&nbsp;<a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en\" target=\"_blank\">Public Domain Mark 1.0<\/a>. Berlin, M\u00fcnzkabinett der Staatlichen Museen, 18216483. Photographs by Dirk Sonnenwald."}},"revers":{"leg_trans":"","leg_text":"TENE-\u0394\u0399-\u039f\u039d","image_description":"Aufrecht stehende Doppelaxt, im l. F. eine Weintraube, im r. F. eine Leier (lyra). Das Ganze in leicht vertieftem quadratum incusum.","foto_date":"2010-11-03","photographer":{"ikmk_photographer_id":"3","photographer_name":"Dirk Sonnenwald","photographer_gnd":"","photographer_viaf":""},"path_thumbnail":"https:\/\/ikmk.smb.museum\/image\/18216483\/rs_opt.jpg","path_opt":"https:\/\/ikmk.smb.museum\/image\/18216483\/rs_opt.jpg","path_opt_rel":"\/data\/www\/001-ikmk\/mk-edit\/images\/n16\/16504\/rs_opt.jpg","path":"https:\/\/ikmk.smb.museum\/image\/18216483\/rs_org.jpg","path_org":"https:\/\/ikmk.smb.museum\/image\/18216483\/rs_org.jpg","image_timestamp":1643732454,"copyright":{"short":"PDM 1.0","url":"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/","de":"Bilddateien sind lizenziert als&nbsp;<a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.de\" target=\"_blank\">Public Domain Mark 1.0<\/a>. Berlin, M\u00fcnzkabinett der Staatlichen Museen, 18216483. Aufnahme durch Dirk Sonnenwald.","en":"Image files are licensed&nbsp;<a href=\"https:\/\/creativecommons.org\/publicdomain\/mark\/1.0\/deed.en\" target=\"_blank\">Public Domain Mark 1.0<\/a>. Berlin, M\u00fcnzkabinett der Staatlichen Museen, 18216483. Photographs by Dirk Sonnenwald."}},"division":{"ikmk_division_id":"1","division_name_de":"Antike","division_name_en":"Antiquity"},"sub_division":{"ikmk_subdivision_id":"4","subdivision_name_de":"Griechen, Archaik und Klassik","subdivision_name_en":"Greek, Archaic and Classical periods"},"literatur":"E. Specht, Die M\u00fcnzpr\u00e4gung von Tenedos (Dissertation Wien 1968) 18 Nr. 44,1 (dieses St\u00fcck). Vgl. SNG Kopenhagen Nr. 513 (Vs. K\u00f6pfe vertauscht); K. Regling, Die antike M\u00fcnze als Kunstwerk (1924) Nr. 429 Taf. 19 (Rs. Beizeichen Zikade); C. M. Kraay - M. Hirmer, Greek Coins (1966) 368 Nr. 697 Taf. 197 (Rs. Beizeichen Zikade, um 375 v. Chr.). Vgl. zum Motiv M. Rocchi, Monete di Tenedos: la doppia ascia di Tennes e dei granchi dell'isola, in: B. Laum, Origine della moneta e teoria del sacrificio. Atti del incontro di studio 1995. Istituto Italiano di Numismatica (1997) 93-110; E. Specht, Tenedos und Tennes. Zur fr\u00fchen Geschichte der Insel, Hyperboreus 7, 2001, 33-36.","comment":"Tenedos leitet seinen Namen von Tenes her, der in der Stadt g\u00f6ttliche Verehrung geno\u00df (Cicero, De natura deorum 3, 15, 39). Der Doppelkopf auf der Vorderseite k\u00f6nnte Tenes und seine Schwester Hemithea darstellen. Es k\u00f6nnte sich aber auch um Zeus und seine Gattin Hera handeln, da der m\u00e4nnliche Kopf b\u00e4rtig und lorbeerbekr\u00e4nzt ist, und der weibliche eine Stephane im Haar tr\u00e4gt. F\u00fcr das Bild der Doppelaxt auf der R\u00fcckseite gab es schon in der Antike mehrere Erkl\u00e4rungen. Pausanias 10, 14, 2 berichtet, da\u00df Tenes sich mit seinem Vater zerstritten hatte. Als dieser mit seinem Schiff bei Tenedos vor Anker lag, um sich mit dem Sohn zu vers\u00f6hnen, hat Tenes die Taue mit einer Doppelaxt durchschlagen, um die Vers\u00f6hnung zu verhindern. Aristoteles (etwa nach dem Kommentar von Stephanos von Byzanz, s.v. Tenedos) bringt die Axt mit dem Gesetz eines K\u00f6nigs von Tenedos in Verbindung, welches Ehebruch mit dem Tod bestrafte und einen Sohn des K\u00f6nigs traf. In sp\u00e4teren antiken Kommentaren wie von Stephanos von Byzanz wird diese sekund\u00e4r \u00fcberlieferte Textstelle direkt mit diesem M\u00fcnztyp in Verbindung gebracht. Wahrscheinlicher ist allerdings, da\u00df die Doppelaxt ein Symbol des Dionysos Pelekys ist und auf vorgriechische Zeit zur\u00fcckgeht.","period":{"ikmk_period_id":"2","name_de":"Klassik","name_en":"Classical","description_de":"Der (europ\u00e4ische) Zeit- und Kunstabschnitt ungef\u00e4hr zwischen 480 und 323 v. Chr.","description_en":"Term to describe the period from c. 480 to 323 BC in Greek art.","concept_id":"http:\/\/vocab.getty.edu\/aat\/300020093","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/period\/2"},"year_start":"-360","year_end":"-340","date_verbal":"ca. 360-340 v. Chr.","year_islam":"0","manufacturing":[{"ikmk_manufacturing_id":"21","manufacturing_name_de":"gepr\u00e4gt","manufacturing_name_en":"struck","nomisma_id":"http:\/\/nomisma.org\/id\/struck","ndp_uri":"https:\/\/ikmk.smb.museum\/ndp\/manufacture\/21"}],"linked_persons_corporations":{"50":{"ikmk_type_id":"50","type_name_de":"Vorbesitzer","type_name_en":"previous Owner","type_nomisma_id":"","type_concept_id":"http:\/\/d-nb.info\/gnd\/4447273-0","ndp_id":"https:\/\/ikmk.smb.museum\/ndp\/type_for_person_and_corporation\/50","items":{"5897":{"ikmk_person_id":"5897","title_de":null,"first_name_de":"Friedrich","last_name_de":"Imhoof-Blumer","vitalDates":"11.05.1838 - 26.04.1920","title_en":null,"first_name_en":"Friedrich","last_name_en":"Imhoof-Blumer","corporation":"0","lod":{"https:\/\/d-nb.info\/gnd\/117137332":"https:\/\/d-nb.info\/gnd\/117137332","https:\/\/de.wikipedia.org\/wiki\/Friedrich_